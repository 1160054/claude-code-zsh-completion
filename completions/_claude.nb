_claude_ultrareview() {
  _arguments \
    '--json[Skriv ut den rå bugs.json-nyttelasten i stedet for formaterte funn]' \
    '--timeout[Maksimalt antall minutter å vente på at gjennomgangen fullføres]:minutes:' \
