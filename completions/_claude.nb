#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Konfigurer og administrer MCP-servere'
    'plugin:Administrer Claude Code-tillegg'
    'agents:Administrer bakgrunnsagenter'
    'auth:Administrer autentisering'
    'auto-mode:Inspiser eller tilbakestill konfigurasjon for auto-modus-klassifisering'
    'gateway:Kjør enterprise-gateway for autentisering/telemetri'
    'project:Administrer Claude Code-prosjekttilstand'
    'ultrareview:Kjør en skybasert multi-agent kodegjennomgang og skriv ut funnene'
    'setup-token:Konfigurer langsiktig autentiseringstoken (krever Claude-abonnement)'
    'doctor:Helsekontroll for Claude Code automatisk oppdatering'
    'update:Søk etter og installer oppdateringer'
    'install:Installer Claude Code native build'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Aktiver feilsøkingsmodus med valgfri kategorifiltrering (f.eks. "api,hooks" eller "!statsig,!file")]:filter:'
    '--verbose[Overstyr detaljert modus fra konfigurasjonsfil]'
    '(-p --print)'{-p,--print}'[Skriv ut svar og avslutt (for bruk med pipes). Merk: bruk kun i betrodde mapper]'
    '--output-format[Utdataformat (med --print): "text" (standard), "json" (enkelt resultat) eller "stream-json" (sanntidsstrømming)]:format:(text json stream-json)'
    '--json-schema[JSON-skjema for strukturert utdatavalidering]:schema:'
    '--include-partial-messages[Inkluder delvise meldingsbiter når de ankommer (med --print og --output-format=stream-json)]'
    '--input-format[Inndataformat (med --print): "text" (standard) eller "stream-json" (sanntidsstrømming)]:format:(text stream-json)'
    '--mcp-debug[\[Foreldet. Bruk --debug i stedet\] Aktiver MCP-feilsøkingsmodus (viser MCP-serverfeil)]'
    '--dangerously-skip-permissions[Omgå alle tillatelseskontroller. Anbefales kun for sandkasser uten internettilgang]'
    '--allow-dangerously-skip-permissions[Aktiver mulighet for å omgå tillatelseskontroller uten å aktivere som standard]'
    '--max-budget-usd[Maksimalt dollarbeløp å bruke på API-kall (kun --print)]:amount:'
    '--replay-user-messages[Send brukermeldinger fra stdin på stdout for bekreftelse]'
    '--allowed-tools[Komma- eller mellomromseparert liste over tillatte verktøynavn (f.eks. "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Komma- eller mellomromseparert liste over tillatte verktøynavn (camelCase-format)]:tools:'
    '--tools[Angi liste over tilgjengelige verktøy fra innebygd sett. Kun utskriftsmodus]:tools:'
    '--disallowed-tools[Komma- eller mellomromseparert liste over ikke-tillatte verktøynavn (f.eks. "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Komma- eller mellomromseparert liste over ikke-tillatte verktøynavn (camelCase-format)]:tools:'
    '--mcp-config[Last inn MCP-servere fra JSON-fil eller streng (mellomromseparert)]:configs:'
    '--system-prompt[Systemprompt å bruke for økt]:prompt:'
    '--append-system-prompt[Legg til systemprompt til standard systemprompt]:prompt:'
    '--permission-mode[Tillatelsesmodus å bruke for økt]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Fortsett den siste samtalen]'
    '(-r --resume)'{-r,--resume}'[Gjenoppta en samtale - angi økt-ID eller velg interaktivt]:sessionId:_claude_sessions'
    '--fork-session[Opprett ny økt-ID i stedet for å gjenbruke original økt-ID ved gjenopptagelse (med --resume eller --continue)]'
    '--no-session-persistence[Deaktiver øktpersistens - økter vil ikke bli lagret (kun --print)]'
    '--model[Modell for gjeldende økt. Angi alias for nyeste modell (f.eks. '\''sonnet'\'' eller '\''opus'\'')]:model:'
    '--agent[Agent for gjeldende økt. Overstyrer '\''agent'\''-innstillingen]:agent:'
    '--betas[Beta-headere å inkludere i API-forespørsler (kun API-nøkkelbrukere)]:betas:'
    '--fallback-model[Aktiver automatisk tilbakefall til angitt modell når standardmodellen er overbelastet (kun --print)]:model:'
    '--settings[Sti til innstillinger JSON-fil eller JSON-streng for å laste ytterligere innstillinger]:file-or-json:_files'
    '--add-dir[Ytterligere mapper å tillate verktøytilgang]:directories:_directories'
    '--ide[Koble automatisk til IDE ved oppstart hvis nøyaktig én gyldig IDE er tilgjengelig]'
    '--strict-mcp-config[Bruk kun MCP-servere fra --mcp-config og ignorer alle andre MCP-innstillinger]'
    '--session-id[Spesifikk økt-ID å bruke for samtale (må være gyldig UUID)]:uuid:'
    '--agents[JSON-objekt som definerer tilpassede agenter]:json:'
    '--setting-sources[Kommaseparert liste over innstillingskilder å laste (user, project, local)]:sources:'
    '--plugin-dir[Mappe å laste tillegg fra kun for denne økten (kan gjentas)]:paths:_directories'
    '--disable-slash-commands[Deaktiver alle skråstrek-kommandoer]'
    '(--bg --background)'{--bg,--background}'[Start økten som en bakgrunnsagent og returner umiddelbart]'
    '(-w --worktree)'{-w,--worktree}'[Opprett et nytt git-arbeidstre for denne økten (angi eventuelt et navn)]::name:'
    '--tmux[Opprett en tmux-økt for arbeidstreet (krever --worktree)]'
    '(-n --name)'{-n,--name}'[Angi et visningsnavn for denne økten]:name:'
    '--effort[Innsatsnivå for gjeldende økt]:level:(low medium high xhigh max)'
    '--debug-file[Skriv feilsøkingslogger til en bestemt filsti (aktiverer implisitt feilsøkingsmodus)]:path:_files'
    '--from-pr[Gjenoppta en økt knyttet til en PR via nummer/URL, eller åpne interaktiv velger]::value:'
    '--remote-control[Start en interaktiv økt med fjernstyring aktivert (kan navngis)]::name:'
    '--remote-control-session-name-prefix[Prefiks for automatisk genererte fjernstyringsøktnavn]:prefix:'
    '--chrome[Aktiver Claude i Chrome-integrasjon]'
    '--no-chrome[Deaktiver Claude i Chrome-integrasjon]'
    '--plugin-url[Hent et tillegg .zip fra en URL kun for denne økten (kan gjentas)]:url:'
    '--file[Filressurser å laste ned ved oppstart (format: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Aktiver promptforslag (sender ut en forutsagt neste prompt i print/SDK-modus)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Videresend underagenttekst og tenkeblokker som meldinger (med --print og stream-json)]'
    '--include-hook-events[Inkluder alle hook-livssyklushendelser i utdatastrømmen (med stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Flytt per-maskin-seksjoner inn i den første brukermeldingen for å forbedre gjenbruk av promptcache]'
    '--brief[Aktiver SendUserMessage-verktøyet for agent-til-bruker-kommunikasjon]'
    '--safe-mode[Start med alle tilpasninger deaktivert (nyttig for feilsøking av en ødelagt konfigurasjon)]'
    '--bare[Minimal modus: hopp over hooks, LSP, tilleggssynkronisering, attribusjon, auto-minne og automatisk CLAUDE.md-oppdagelse]'
    '--ax-screen-reader[Gjengi skjermleservennlig utdata (flat tekst, ingen dekorative kanter eller animasjoner)]'
    '(-v --version)'{-v,--version}'[Vis versjonsnummer]'
    '(-h --help)'{-h,--help}'[Vis hjelp for kommando]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude-kommandoer' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "ingen argumenter"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Start en Claude Code MCP-server'
    'add:Legg til en MCP-server til Claude Code'
    'remove:Fjern en MCP-server'
    'list:Vis konfigurerte MCP-servere'
    'get:Hent MCP-serverdetaljer'
    'add-json:Legg til en MCP-server (stdio eller SSE) med JSON-streng'
    'add-from-claude-desktop:Importer MCP-servere fra Claude Desktop (kun Mac og WSL)'
    'reset-project-choices:Tilbakestill alle godkjente/avviste prosjektomfattende (.mcp.json) servere i dette prosjektet'
    'login:Autentiser med en MCP-server (HTTP, SSE eller claude.ai-kobling)'
    'logout:Fjern lagrede OAuth-legitimasjoner for en MCP-server'
    'help:Vis hjelp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp-kommandoer' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Aktiver feilsøkingsmodus]' \
            '--verbose[Overstyr detaljert modus fra konfigurasjonsfil]' \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Transporttype (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Angi miljøvariabel (f.eks. -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[Angi WebSocket-header]:header:' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project) - fjern fra eksisterende omfang hvis uspesifisert]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Valider et tillegg eller markedsplass-manifest'
    'marketplace:Administrer Claude Code-markedsplasser'
    'list:Vis installerte tillegg'
    'details:Vis komponentoversikt og estimert token-kostnad for et tillegg'
    'install:Installer et tillegg fra tilgjengelige markedsplasser'
    'i:Installer et tillegg fra tilgjengelige markedsplasser (kort for install)'
    'init:Opprett stillas for et nytt tillegg (lastes automatisk neste økt)'
    'uninstall:Avinstaller et installert tillegg'
    'remove:Avinstaller et installert tillegg (alias for uninstall)'
    'enable:Aktiver et deaktivert tillegg'
    'disable:Deaktiver et aktivert tillegg'
    'update:Oppdater et tillegg til nyeste versjon'
    'eval:Kjør eval-tilfeller mot et tillegg og rapporter poengsatte resultater'
    'prune:Fjern automatisk installerte avhengigheter som ikke lenger er nødvendige'
    'tag:Opprett en {name}--v{version} git-tag for en tilleggsutgivelse'
    'help:Vis hjelp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin-kommandoer' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Legg til en markedsplass fra URL, sti eller GitHub-repository'
    'list:Vis konfigurerte markedsplasser'
    'remove:Fjern en konfigurert markedsplass'
    'rm:Fjern en konfigurert markedsplass (alias for remove)'
    'update:Oppdater markedsplass fra kilde - oppdater alle hvis intet navn er angitt'
    'help:Vis hjelp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace-kommandoer' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Tving installasjon selv om allerede installert]' \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Ytterligere mappe å tillate verktøytilgang til i utsendte økter]:directory:_directories' \
    '--agent[Standardagent for økter utsendt fra agentvisning]:agent:' \
    '--all[Med --json: inkluder også fullførte bakgrunnsøkter]' \
    '--allow-dangerously-skip-permissions[Gjør bypass-permissions-modus tilgjengelig for utsendte økter]' \
    '--cwd[Vis kun bakgrunnsøkter startet under sti]:path:_directories' \
    '--dangerously-skip-permissions[Alias for --permission-mode bypassPermissions]' \
    '--effort[Standard innsatsnivå for utsendte økter]:level:(low medium high xhigh max)' \
    '--json[Skriv ut aktive økter som en JSON-array og avslutt]' \
    '*--mcp-config[MCP-serverkonfigurasjon å bruke på utsendte økter]:config:' \
    '--model[Standardmodell for økter utsendt fra agentvisning]:model:' \
    '--permission-mode[Standard tillatelsesmodus for utsendte økter]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Last tillegg fra mappe for agentvisningen og utsendte økter]:path:_directories' \
    '--setting-sources[Kommaseparert liste over innstillingskilder å laste (user, project, local)]:sources:' \
    '--settings[Innstillingsfil eller JSON-streng å bruke]:file-or-json:_files' \
    '--strict-mcp-config[Bruk kun MCP-servere fra --mcp-config i utsendte økter]' \
    '(-h --help)'{-h,--help}'[Vis hjelp for kommando]'
}

