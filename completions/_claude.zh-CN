_claude_gateway() {
  _arguments \
    '--config[网关YAML配置的路径]:path:_files' \
    '(-h --help)'{-h,--help}'[显示命令帮助]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:删除项目的所有Claude Code状态（记录、任务、文件历史、配置条目）'
    'help:显示帮助'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[显示命令帮助]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project命令' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[显示命令帮助]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[打印原始bugs.json负载而不是格式化的结果]' \
    '--timeout[等待审查完成的最长分钟数]:minutes:' \
    '(-h --help)'{-h,--help}'[显示命令帮助]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
