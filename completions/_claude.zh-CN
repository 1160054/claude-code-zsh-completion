#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:配置和管理MCP服务器'
    'plugin:管理Claude Code插件'
    'agents:管理后台代理'
    'auth:管理身份验证'
    'auto-mode:检查或重置自动模式分类器配置'
    'gateway:运行企业身份验证/遥测网关'
    'project:管理Claude Code项目状态'
    'ultrareview:运行云托管的多代理代码审查并打印结果'
    'setup-token:设置长期身份验证令牌（需要Claude订阅）'
    'doctor:Claude Code自动更新器健康检查'
    'update:检查并安装更新'
    'install:安装Claude Code原生构建'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[启用调试模式，可选类别过滤（例如："api,hooks"或"!statsig,!file"）]:filter:'
    '--verbose[覆盖配置文件中的详细模式设置]'
    '(-p --print)'{-p,--print}'[打印响应并退出（用于管道）。注意：仅在受信任的目录中使用]'
    '--output-format[输出格式（与--print一起使用）："text"（默认）、"json"（单个结果）或"stream-json"（实时流式传输）]:format:(text json stream-json)'
    '--json-schema[用于结构化输出验证的JSON模式]:schema:'
    '--include-partial-messages[在消息到达时包含部分消息块（与--print和--output-format=stream-json一起使用）]'
    '--input-format[输入格式（与--print一起使用）："text"（默认）或"stream-json"（实时流式输入）]:format:(text stream-json)'
    '--mcp-debug[\[已弃用。请改用--debug\] 启用MCP调试模式（显示MCP服务器错误）]'
    '--dangerously-skip-permissions[绕过所有权限检查。仅建议在没有互联网访问的沙箱中使用]'
    '--allow-dangerously-skip-permissions[启用绕过权限检查的选项，但默认不启用]'
    '--max-budget-usd[API调用花费的最大美元金额（仅--print）]:amount:'
    '--replay-user-messages[在stdout上重新发送来自stdin的用户消息以进行确认]'
    '--allowed-tools[允许的工具名称的逗号或空格分隔列表（例如："Bash(git:*) Edit"）]:tools:'
    '--allowedTools[允许的工具名称的逗号或空格分隔列表（驼峰命名格式）]:tools:'
    '--tools[从内置集中指定可用工具列表。仅打印模式]:tools:'
    '--disallowed-tools[禁止的工具名称的逗号或空格分隔列表（例如："Bash(git:*) Edit"）]:tools:'
    '--disallowedTools[禁止的工具名称的逗号或空格分隔列表（驼峰命名格式）]:tools:'
    '--mcp-config[从JSON文件或字符串加载MCP服务器（空格分隔）]:configs:'
    '--system-prompt[会话使用的系统提示]:prompt:'
    '--append-system-prompt[将系统提示附加到默认系统提示]:prompt:'
    '--permission-mode[会话使用的权限模式]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[继续最近的对话]'
    '(-r --resume)'{-r,--resume}'[恢复对话 - 指定会话ID或交互式选择]:sessionId:_claude_sessions'
    '--fork-session[恢复时创建新的会话ID而不是重用原始会话ID（与--resume或--continue一起使用）]'
    '--no-session-persistence[禁用会话持久化 - 会话将不会被保存（仅--print）]'
    '--model[当前会话的模型。指定最新模型的别名（例如，'\''sonnet'\''或'\''opus'\''）]:model:'
    '--agent[当前会话的代理。覆盖'\''agent'\''设置]:agent:'
    '--betas[要包含在API请求中的Beta标头（仅限API密钥用户）]:betas:'
    '--fallback-model[当默认模型过载时启用自动回退到指定模型（仅--print）]:model:'
    '--settings[设置JSON文件的路径或用于加载其他设置的JSON字符串]:file-or-json:_files'
    '--add-dir[允许工具访问的其他目录]:directories:_directories'
    '--ide[如果恰好有一个有效的IDE可用，则在启动时自动连接到IDE]'
    '--strict-mcp-config[仅使用--mcp-config中的MCP服务器并忽略所有其他MCP设置]'
    '--session-id[用于对话的特定会话ID（必须是有效的UUID）]:uuid:'
    '--agents[定义自定义代理的JSON对象]:json:'
    '--setting-sources[要加载的设置源的逗号分隔列表（user, project, local）]:sources:'
    '--plugin-dir[仅为此会话加载插件的目录（可重复）]:paths:_directories'
    '--disable-slash-commands[禁用所有斜杠命令]'
    '(--bg --background)'{--bg,--background}'[将会话作为后台代理启动并立即返回]'
    '(-w --worktree)'{-w,--worktree}'[为此会话创建新的git工作树（可选指定名称）]::name:'
    '--tmux[为工作树创建tmux会话（需要--worktree）]'
    '(-n --name)'{-n,--name}'[为此会话设置显示名称]:name:'
    '--effort[当前会话的努力程度]:level:(low medium high xhigh max)'
    '--debug-file[将调试日志写入特定文件路径（隐式启用调试模式）]:path:_files'
    '--from-pr[恢复通过编号/URL链接到PR的会话，或打开交互式选择器]::value:'
    '--remote-control[启动启用远程控制的交互式会话（可选命名）]::name:'
    '--remote-control-session-name-prefix[自动生成的远程控制会话名称的前缀]:prefix:'
    '--chrome[启用Chrome中的Claude集成]'
    '--no-chrome[禁用Chrome中的Claude集成]'
    '--plugin-url[仅为此会话从URL获取插件.zip（可重复）]:url:'
    '--file[启动时下载的文件资源（格式：file_id:relative_path）]:specs:'
    '--prompt-suggestions[启用提示建议（在打印/SDK模式下发出预测的下一个提示）]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[将子代理文本和思考块作为消息转发（与--print和stream-json一起使用）]'
    '--include-hook-events[在输出流中包含所有钩子生命周期事件（与stream-json一起使用）]'
    '--exclude-dynamic-system-prompt-sections[将每台机器的部分移到第一条用户消息中以提高提示缓存重用率]'
    '--brief[启用SendUserMessage工具用于代理到用户的通信]'
    '--safe-mode[在禁用所有自定义设置的情况下启动（用于排查损坏的配置）]'
    '--bare[最小模式：跳过钩子、LSP、插件同步、归因、自动记忆和CLAUDE.md自动发现]'
    '--ax-screen-reader[渲染屏幕阅读器友好的输出（纯文本，无装饰边框或动画）]'
    '(-v --version)'{-v,--version}'[输出版本号]'
    '(-h --help)'{-h,--help}'[显示命令帮助]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude命令' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "无参数"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:启动Claude Code MCP服务器'
    'add:向Claude Code添加MCP服务器'
    'remove:删除MCP服务器'
    'list:列出已配置的MCP服务器'
    'get:获取MCP服务器详细信息'
    'add-json:使用JSON字符串添加MCP服务器（stdio或SSE）'
    'add-from-claude-desktop:从Claude Desktop导入MCP服务器（仅限Mac和WSL）'
    'reset-project-choices:重置此项目中所有已批准/拒绝的项目范围（.mcp.json）服务器'
    'login:向MCP服务器进行身份验证（HTTP、SSE或claude.ai连接器）'
    'logout:清除MCP服务器存储的OAuth凭据'
    'help:显示帮助'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[显示帮助]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp命令' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[启用调试模式]' \
            '--verbose[覆盖配置文件中的详细模式设置]' \
            '(-h --help)'{-h,--help}'[显示帮助]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[配置范围（local, user, project）]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[传输类型（stdio, sse, http）]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[设置环境变量（例如，-e KEY=value）]:env:' \
            '(-H --header)'{-H,--header}'[设置WebSocket标头]:header:' \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[配置范围（local, user, project） - 如果未指定则从现有范围中删除]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[配置范围（local, user, project）]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[配置范围（local, user, project）]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[显示帮助]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:验证插件或市场清单'
    'marketplace:管理Claude Code市场'
    'list:列出已安装的插件'
    'details:显示插件的组件清单和预计令牌成本'
    'install:从可用市场安装插件'
    'i:从可用市场安装插件（install的简写）'
    'init:搭建新插件（下次会话自动加载）'
    'uninstall:卸载已安装的插件'
    'remove:卸载已安装的插件（uninstall的别名）'
    'enable:启用已禁用的插件'
    'disable:禁用已启用的插件'
    'update:将插件更新到最新版本'
    'eval:针对插件运行评估用例并报告评分结果'
    'prune:删除不再需要的自动安装依赖项'
    'tag:为插件发布创建{name}--v{version} git标签'
    'help:显示帮助'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[显示帮助]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin命令' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安装范围]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安装范围]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安装范围]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安装范围]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:从URL、路径或GitHub存储库添加市场'
    'list:列出已配置的市场'
    'remove:删除已配置的市场'
    'rm:删除已配置的市场（remove的别名）'
    'update:从源更新市场 - 如果未指定名称则更新所有'
    'help:显示帮助'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[显示帮助]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace命令' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[显示帮助]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[即使已安装也强制安装]' \
    '(-h --help)'{-h,--help}'[显示帮助]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[允许派发会话中工具访问的其他目录]:directory:_directories' \
    '--agent[从代理视图派发的会话的默认代理]:agent:' \
    '--all[与--json一起使用：同时包含已完成的后台会话]' \
    '--allow-dangerously-skip-permissions[使派发的会话可以使用绕过权限模式]' \
    '--cwd[仅显示在指定路径下启动的后台会话]:path:_directories' \
    '--dangerously-skip-permissions[--permission-mode bypassPermissions的别名]' \
    '--effort[派发会话的默认努力程度]:level:(low medium high xhigh max)' \
    '--json[将活动会话打印为JSON数组并退出]' \
    '*--mcp-config[应用于派发会话的MCP服务器配置]:config:' \
    '--model[从代理视图派发的会话的默认模型]:model:' \
    '--permission-mode[派发会话的默认权限模式]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[为代理视图和派发会话从目录加载插件]:path:_directories' \
    '--setting-sources[要加载的设置源的逗号分隔列表（user, project, local）]:sources:' \
    '--settings[要应用的设置文件或JSON字符串]:file-or-json:_files' \
    '--strict-mcp-config[在派发会话中仅使用--mcp-config中的MCP服务器]' \
    '(-h --help)'{-h,--help}'[显示命令帮助]'
}

