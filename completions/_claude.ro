#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Configurare și gestionare servere MCP'
    'plugin:Gestionare plugin-uri Claude Code'
    'agents:Gestionare agenți în fundal'
    'auth:Gestionare autentificare'
    'auto-mode:Inspectare sau resetare configurație clasificator mod automat'
    'gateway:Rulare gateway enterprise de autentificare/telemetrie'
    'project:Gestionare stare proiect Claude Code'
    'ultrareview:Rulare revizuire de cod multi-agent găzduită în cloud și afișare rezultate'
    'setup-token:Configurare token de autentificare pe termen lung (necesită abonament Claude)'
    'doctor:Verificare stare pentru actualizatorul automat Claude Code'
    'update:Verificare și instalare actualizări'
    'install:Instalare build nativ Claude Code'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Activare mod depanare cu filtrare opțională pe categorie (ex: "api,hooks" sau "!statsig,!file")]:filter:'
    '--verbose[Suprascrie setarea modului detaliat din fișierul de configurare]'
    '(-p --print)'{-p,--print}'[Afișare răspuns și ieșire (pentru utilizare cu pipe-uri). Notă: utilizați doar în directoare de încredere]'
    '--output-format[Format ieșire (cu --print): "text" (implicit), "json" (rezultat unic), sau "stream-json" (streaming în timp real)]:format:(text json stream-json)'
    '--json-schema[Schemă JSON pentru validare ieșire structurată]:schema:'
    '--include-partial-messages[Include fragmente de mesaje parțiale pe măsură ce sosesc (cu --print și --output-format=stream-json)]'
    '--input-format[Format intrare (cu --print): "text" (implicit) sau "stream-json" (intrare streaming în timp real)]:format:(text stream-json)'
    '--mcp-debug[\[Depreciat. Folosiți --debug în schimb\] Activare mod depanare MCP (afișează erori server MCP)]'
    '--dangerously-skip-permissions[Ocolire toate verificările de permisiuni. Recomandat doar pentru sandbox-uri fără acces la internet]'
    '--allow-dangerously-skip-permissions[Activare opțiune de ocolire a verificărilor de permisiuni fără activare implicită]'
    '--max-budget-usd[Suma maximă în dolari de cheltuit pe apeluri API (doar --print)]:amount:'
    '--replay-user-messages[Retrimiteri mesaje utilizator de la stdin pe stdout pentru confirmare]'
    '--allowed-tools[Listă separată prin virgule sau spații de nume de unelte permise (ex: "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Listă separată prin virgule sau spații de nume de unelte permise (format camelCase)]:tools:'
    '--tools[Specificare listă de unelte disponibile din setul integrat. Doar mod afișare]:tools:'
    '--disallowed-tools[Listă separată prin virgule sau spații de nume de unelte interzise (ex: "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Listă separată prin virgule sau spații de nume de unelte interzise (format camelCase)]:tools:'
    '--mcp-config[Încărcare servere MCP din fișier JSON sau șir (separate prin spații)]:configs:'
    '--system-prompt[Prompt sistem de utilizat pentru sesiune]:prompt:'
    '--append-system-prompt[Adăugare prompt sistem la promptul sistem implicit]:prompt:'
    '--permission-mode[Mod permisiuni de utilizat pentru sesiune]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Continuare conversația cea mai recentă]'
    '(-r --resume)'{-r,--resume}'[Reluare conversație - specificați ID sesiune sau selectați interactiv]:sessionId:_claude_sessions'
    '--fork-session[Creare ID sesiune nou în loc de reutilizare ID sesiune original la reluare (cu --resume sau --continue)]'
    '--no-session-persistence[Dezactivare persistență sesiune - sesiunile nu vor fi salvate (doar --print)]'
    '--model[Model pentru sesiunea curentă. Specificați alias pentru modelul cel mai recent (ex: '\''sonnet'\'' sau '\''opus'\'')]:model:'
    '--agent[Agent pentru sesiunea curentă. Suprascrie setarea '\''agent'\'']:agent:'
    '--betas[Antete beta de inclus în cererile API (doar utilizatori cu cheie API)]:betas:'
    '--fallback-model[Activare fallback automat la modelul specificat când modelul implicit este supraîncărcat (doar --print)]:model:'
    '--settings[Cale către fișier JSON de setări sau șir JSON pentru încărcare setări adiționale]:file-or-json:_files'
    '--add-dir[Directoare adiționale pentru permiteți accesul uneltelor]:directories:_directories'
    '--ide[Conectare automată la IDE la pornire dacă exact un IDE valid este disponibil]'
    '--strict-mcp-config[Utilizare doar servere MCP din --mcp-config și ignorare toate celelalte setări MCP]'
    '--session-id[ID sesiune specific de utilizat pentru conversație (trebuie să fie UUID valid)]:uuid:'
    '--agents[Obiect JSON definind agenți personalizați]:json:'
    '--setting-sources[Listă separată prin virgule de surse de setări de încărcat (user, project, local)]:sources:'
    '--plugin-dir[Director pentru încărcare plugin-uri doar pentru această sesiune (repetabil)]:paths:_directories'
    '--disable-slash-commands[Dezactivare toate comenzile slash]'
    '(--bg --background)'{--bg,--background}'[Pornire sesiune ca agent în fundal și revenire imediată]'
    '(-w --worktree)'{-w,--worktree}'[Creare worktree git nou pentru această sesiune (opțional specificați un nume)]::name:'
    '--tmux[Creare sesiune tmux pentru worktree (necesită --worktree)]'
    '(-n --name)'{-n,--name}'[Setare nume afișat pentru această sesiune]:name:'
    '--effort[Nivel de efort pentru sesiunea curentă]:level:(low medium high xhigh max)'
    '--debug-file[Scriere jurnale de depanare într-o cale de fișier specifică (activează implicit modul depanare)]:path:_files'
    '--from-pr[Reluare sesiune legată de un PR după număr/URL, sau deschidere selector interactiv]::value:'
    '--remote-control[Pornire sesiune interactivă cu Remote Control activat (opțional denumită)]::name:'
    '--remote-control-session-name-prefix[Prefix pentru numele de sesiune Remote Control generate automat]:prefix:'
    '--chrome[Activare integrare Claude în Chrome]'
    '--no-chrome[Dezactivare integrare Claude în Chrome]'
    '--plugin-url[Preluare .zip de plugin dintr-un URL doar pentru această sesiune (repetabil)]:url:'
    '--file[Resurse fișier de descărcat la pornire (format: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Activare sugestii de prompt (emite un prompt următor prezis în modul print/SDK)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Redirecționare text subagent și blocuri de gândire ca mesaje (cu --print și stream-json)]'
    '--include-hook-events[Includere toate evenimentele din ciclul de viață al hook-urilor în fluxul de ieșire (cu stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Mutare secțiuni per-mașină în primul mesaj utilizator pentru a îmbunătăți reutilizarea cache-ului de prompt]'
    '--brief[Activare unealtă SendUserMessage pentru comunicare agent-către-utilizator]'
    '--safe-mode[Pornire cu toate personalizările dezactivate (util pentru depanarea unei configurații defecte)]'
    '--bare[Mod minimal: omite hook-uri, LSP, sincronizare plugin-uri, atribuire, auto-memorie și descoperirea automată CLAUDE.md]'
    '--ax-screen-reader[Randare ieșire prietenoasă cu cititoarele de ecran (text plat, fără borduri decorative sau animații)]'
    '(-v --version)'{-v,--version}'[Afișare număr versiune]'
    '(-h --help)'{-h,--help}'[Afișare ajutor pentru comandă]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comenzi claude' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "fără argumente"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Pornire server MCP Claude Code'
    'add:Adăugare server MCP la Claude Code'
    'remove:Eliminare server MCP'
    'list:Listare servere MCP configurate'
    'get:Obținere detalii server MCP'
    'add-json:Adăugare server MCP (stdio sau SSE) cu șir JSON'
    'add-from-claude-desktop:Importare servere MCP din Claude Desktop (doar Mac și WSL)'
    'reset-project-choices:Resetare toate serverele cu domeniu de proiect (.mcp.json) aprobate/respinse în acest proiect'
    'login:Autentificare cu un server MCP (HTTP, SSE sau conector claude.ai)'
    'logout:Ștergere credențiale OAuth stocate pentru un server MCP'
    'help:Afișare ajutor'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Afișare ajutor]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comenzi mcp' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Activare mod depanare]' \
            '--verbose[Suprascrie setarea modului detaliat din fișierul de configurare]' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu configurare (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Tip transport (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Setare variabilă de mediu (ex: -e CHEIE=valoare)]:env:' \
            '(-H --header)'{-H,--header}'[Setare antet WebSocket]:header:' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu configurare (local, user, project) - eliminare din domeniu existent dacă nespecificat]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu configurare (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu configurare (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Validare plugin sau manifest marketplace'
    'marketplace:Gestionare marketplace-uri Claude Code'
    'list:Listare plugin-uri instalate'
    'details:Afișare inventar componente și cost estimat de token-uri pentru un plugin'
    'install:Instalare plugin din marketplace-urile disponibile'
    'i:Instalare plugin din marketplace-urile disponibile (formă scurtă pentru install)'
    'init:Schelet plugin nou (se încarcă automat în sesiunea următoare)'
    'uninstall:Dezinstalare plugin instalat'
    'remove:Dezinstalare plugin instalat (alias pentru uninstall)'
    'enable:Activare plugin dezactivat'
    'disable:Dezactivare plugin activat'
    'update:Actualizare plugin la cea mai recentă versiune'
    'eval:Rulare cazuri de evaluare pe un plugin și raportare rezultate punctate'
    'prune:Eliminare dependențe instalate automat care nu mai sunt necesare'
    'tag:Creare etichetă git {name}--v{version} pentru o lansare de plugin'
    'help:Afișare ajutor'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Afișare ajutor]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comenzi plugin' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu instalare]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu instalare]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu instalare]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Domeniu instalare]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Adăugare marketplace din URL, cale sau depozit GitHub'
    'list:Listare marketplace-uri configurate'
    'remove:Eliminare marketplace configurat'
    'rm:Eliminare marketplace configurat (alias pentru remove)'
    'update:Actualizare marketplace din sursă - actualizare toate dacă niciun nume specificat'
    'help:Afișare ajutor'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Afișare ajutor]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comenzi marketplace' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Forțare instalare chiar dacă este deja instalat]' \
    '(-h --help)'{-h,--help}'[Afișare ajutor]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Director adițional pentru a permite accesul uneltelor în sesiunile lansate]:directory:_directories' \
    '--agent[Agent implicit pentru sesiunile lansate din vizualizarea agent]:agent:' \
    '--all[Cu --json: include și sesiunile în fundal finalizate]' \
    '--allow-dangerously-skip-permissions[Face disponibil modul de ocolire a permisiunilor pentru sesiunile lansate]' \
    '--cwd[Afișare doar sesiunile în fundal pornite sub cale]:path:_directories' \
    '--dangerously-skip-permissions[Alias pentru --permission-mode bypassPermissions]' \
    '--effort[Nivel de efort implicit pentru sesiunile lansate]:level:(low medium high xhigh max)' \
    '--json[Afișare sesiuni active ca tablou JSON și ieșire]' \
    '*--mcp-config[Configurație server MCP de aplicat sesiunilor lansate]:config:' \
    '--model[Model implicit pentru sesiunile lansate din vizualizarea agent]:model:' \
    '--permission-mode[Mod permisiuni implicit pentru sesiunile lansate]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Încărcare plugin-uri din director pentru vizualizarea agent și sesiunile lansate]:path:_directories' \
    '--setting-sources[Listă separată prin virgule de surse de setări de încărcat (user, project, local)]:sources:' \
    '--settings[Fișier de setări sau șir JSON de aplicat]:file-or-json:_files' \
    '--strict-mcp-config[Utilizare doar servere MCP din --mcp-config în sesiunile lansate]' \
    '(-h --help)'{-h,--help}'[Afișare ajutor pentru comandă]'
}

