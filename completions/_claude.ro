  _arguments -C \
    '(-h --help)'{-h,--help}'[Afișare ajutor pentru comandă]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comenzi auth' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[Afișare ajutor pentru comandă]'
