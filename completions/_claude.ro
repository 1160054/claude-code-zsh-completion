_claude_ultrareview() {
  _arguments \
    '--json[Afișare payload brut bugs.json în loc de rezultate formatate]' \
    '--timeout[Numărul maxim de minute de așteptare pentru finalizarea revizuirii]:minutes:' \
    '(-h --help)'{-h,--help}'[Afișare ajutor pentru comandă]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
