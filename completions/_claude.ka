#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:MCP სერვერების კონფიგურაცია და მართვა'
    'plugin:Claude Code დამატებების მართვა'
    'agents:ფონური აგენტების მართვა'
    'auth:ავთენტიფიკაციის მართვა'
    'auto-mode:ავტო რეჟიმის კლასიფიკატორის კონფიგურაციის დათვალიერება ან გადატვირთვა'
    'gateway:საწარმოო ავთენტიფიკაცია/ტელემეტრიის gateway-ის გაშვება'
    'project:Claude Code პროექტის მდგომარეობის მართვა'
    'ultrareview:ღრუბელზე მასპინძლებული მრავალაგენტიანი კოდის მიმოხილვის გაშვება და შედეგების დაბეჭდვა'
    'setup-token:გრძელვადიანი ავთენტიფიკაციის ტოკენის დაყენება (საჭიროებს Claude გამოწერას)'
    'doctor:Claude Code ავტომატური განახლების ჯანმრთელობის შემოწმება'
    'update:განახლებების შემოწმება და ინსტალაცია'
    'install:Claude Code ნატიურ ბილდის ინსტალაცია'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[დებაგ რეჟიმის ჩართვა კატეგორიების ფილტრაციით (მაგ., "api,hooks" ან "!statsig,!file")]:filter:'
    '--verbose[ვერბოზ რეჟიმის პარამეტრის გადაფარვა კონფიგურაციის ფაილიდან]'
    '(-p --print)'{-p,--print}'[პასუხის დაბეჭდვა და გასვლა (pipe-ებთან გამოსაყენებლად). შენიშვნა: გამოიყენეთ მხოლოდ სანდო დირექტორიებში]'
    '--output-format[გამოტანის ფორმატი (--print-თან): "text" (ნაგულისხმევი), "json" (ცალკე შედეგი), ან "stream-json" (რეალურ დროში სტრიმინგი)]:format:(text json stream-json)'
    '--json-schema[JSON სქემა სტრუქტურირებული გამოტანის ვალიდაციისთვის]:schema:'
    '--include-partial-messages[ნაწილობრივი შეტყობინებების ჩართვა (--print და --output-format=stream-json-თან)]'
    '--input-format[შეტანის ფორმატი (--print-თან): "text" (ნაგულისხმევი) ან "stream-json" (რეალურ დროში სტრიმინგი)]:format:(text stream-json)'
    '--mcp-debug[\[მოძველებული. გამოიყენეთ --debug\] MCP დებაგ რეჟიმის ჩართვა (აჩვენებს MCP სერვერის შეცდომებს)]'
    '--dangerously-skip-permissions[ყველა ნებართვის შემოწმების გვერდის ავლა. რეკომენდებულია მხოლოდ ინტერნეტის გარეშე sandbox გარემოებისთვის]'
    '--allow-dangerously-skip-permissions[ნებართვის შემოწმების გვერდის ავლის ოფციის ჩართვა ნაგულისხმევად გააქტიურების გარეშე]'
    '--max-budget-usd[მაქსიმალური დოლარის ოდენობა API გამოძახებებზე დასახარჯად (მხოლოდ --print)]:amount:'
    '--replay-user-messages[მომხმარებლის შეტყობინებების ხელახალი გაგზავნა stdin-დან stdout-ზე დასადასტურებლად]'
    '--allowed-tools[მძიმით ან სივრცით გამოყოფილი დაშვებული ინსტრუმენტების სია (მაგ., "Bash(git:*) Edit")]:tools:'
    '--allowedTools[მძიმით ან სივრცით გამოყოფილი დაშვებული ინსტრუმენტების სია (camelCase ფორმატი)]:tools:'
    '--tools[ხელმისაწვდომი ინსტრუმენტების სიის მითითება ჩაშენებული ნაკრებიდან. მხოლოდ print რეჟიმი]:tools:'
    '--disallowed-tools[მძიმით ან სივრცით გამოყოფილი აკრძალული ინსტრუმენტების სია (მაგ., "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[მძიმით ან სივრცით გამოყოფილი აკრძალული ინსტრუმენტების სია (camelCase ფორმატი)]:tools:'
    '--mcp-config[MCP სერვერების ჩატვირთვა JSON ფაილიდან ან სტრიქონიდან (სივრცით გამოყოფილი)]:configs:'
    '--system-prompt[სისტემური prompt სესიისთვის]:prompt:'
    '--append-system-prompt[სისტემური prompt-ის დართვა ნაგულისხმევ სისტემურ prompt-ზე]:prompt:'
    '--permission-mode[ნებართვის რეჟიმი სესიისთვის]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[ბოლო საუბრის გაგრძელება]'
    '(-r --resume)'{-r,--resume}'[საუბრის განახლება - მიუთითეთ სესიის ID ან აირჩიეთ ინტერაქტიულად]:sessionId:_claude_sessions'
    '--fork-session[ახალი სესიის ID-ის შექმნა ორიგინალის ხელახლა გამოყენების ნაცვლად (--resume ან --continue-თან)]'
    '--no-session-persistence[სესიის შენახვის გამორთვა - სესიები არ შეინახება (მხოლოდ --print)]'
    '--model[მოდელი მიმდინარე სესიისთვის. მიუთითეთ ალიასი უახლესი მოდელისთვის (მაგ., '\''sonnet'\'' ან '\''opus'\'')]:model:'
    '--agent[აგენტი მიმდინარე სესიისთვის. გადაფარავს '\''agent'\'' პარამეტრს]:agent:'
    '--betas[ბეტა header-ები API მოთხოვნებში ჩასართავად (მხოლოდ API გასაღების მომხმარებლებისთვის)]:betas:'
    '--fallback-model[ავტომატური გადასვლის ჩართვა მითითებულ მოდელზე როცა ნაგულისხმევი მოდელი გადატვირთულია (მხოლოდ --print)]:model:'
    '--settings[პარამეტრების JSON ფაილის ან JSON სტრიქონის გზა დამატებითი პარამეტრების ჩასატვირთად]:file-or-json:_files'
    '--add-dir[დამატებითი დირექტორიები ინსტრუმენტების წვდომისთვის]:directories:_directories'
    '--ide[ავტომატური დაკავშირება IDE-სთან გაშვებისას თუ ხელმისაწვდომია ზუსტად ერთი ვალიდური IDE]'
    '--strict-mcp-config[გამოიყენეთ მხოლოდ MCP სერვერები --mcp-config-დან და იგნორირება სხვა MCP პარამეტრების]'
    '--session-id[სპეციფიკური სესიის ID საუბრისთვის (უნდა იყოს ვალიდური UUID)]:uuid:'
    '--agents[JSON ობიექტი რომელიც განსაზღვრავს მორგებულ აგენტებს]:json:'
    '--setting-sources[მძიმით გამოყოფილი პარამეტრების წყაროების სია ჩასატვირთად (user, project, local)]:sources:'
    '--plugin-dir[დირექტორია დამატებების ჩასატვირთად მხოლოდ ამ სესიისთვის (განმეორებადი)]:paths:_directories'
    '--disable-slash-commands[ყველა slash ბრძანების გამორთვა]'
    '(--bg --background)'{--bg,--background}'[სესიის გაშვება ფონურ აგენტად და დაუყოვნებლივ დაბრუნება]'
    '(-w --worktree)'{-w,--worktree}'[ახალი git worktree-ის შექმნა ამ სესიისთვის (სურვილისამებრ მიუთითეთ სახელი)]::name:'
    '--tmux[tmux სესიის შექმნა worktree-სთვის (საჭიროებს --worktree)]'
    '(-n --name)'{-n,--name}'[ამ სესიისთვის საჩვენებელი სახელის დაყენება]:name:'
    '--effort[ძალისხმევის დონე მიმდინარე სესიისთვის]:level:(low medium high xhigh max)'
    '--debug-file[დებაგ ლოგების ჩაწერა კონკრეტულ ფაილში (ავტომატურად რთავს დებაგ რეჟიმს)]:path:_files'
    '--from-pr[PR-თან დაკავშირებული სესიის განახლება ნომრით/URL-ით, ან ინტერაქტიული ამრჩევის გახსნა]::value:'
    '--remote-control[ინტერაქტიული სესიის დაწყება ჩართული Remote Control-ით (სურვილისამებრ დასახელებული)]::name:'
    '--remote-control-session-name-prefix[პრეფიქსი ავტომატურად გენერირებული Remote Control სესიის სახელებისთვის]:prefix:'
    '--chrome[Claude in Chrome ინტეგრაციის ჩართვა]'
    '--no-chrome[Claude in Chrome ინტეგრაციის გამორთვა]'
    '--plugin-url[დამატების .zip-ის მოტანა URL-დან მხოლოდ ამ სესიისთვის (განმეორებადი)]:url:'
    '--file[ფაილის რესურსები გაშვებისას ჩამოსატვირთად (ფორმატი: file_id:relative_path)]:specs:'
    '--prompt-suggestions[prompt-ის შემოთავაზებების ჩართვა (გამოსცემს პროგნოზირებულ შემდეგ prompt-ს print/SDK რეჟიმში)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[ქვეაგენტის ტექსტისა და ფიქრის ბლოკების გადაგზავნა შეტყობინებებად (--print და stream-json-თან)]'
    '--include-hook-events[ყველა hook სასიცოცხლო ციკლის მოვლენის ჩართვა გამოტანის სტრიმში (stream-json-თან)]'
    '--exclude-dynamic-system-prompt-sections[თითოეული მანქანის სექციების გადატანა პირველ მომხმარებლის შეტყობინებაში prompt-cache-ის ხელახალი გამოყენების გასაუმჯობესებლად]'
    '--brief[SendUserMessage ინსტრუმენტის ჩართვა აგენტი-მომხმარებელი კომუნიკაციისთვის]'
    '--safe-mode[გაშვება ყველა მორგების გამორთვით (სასარგებლოა გატეხილი კონფიგურაციის პრობლემების მოსაგვარებლად)]'
    '--bare[მინიმალური რეჟიმი: hooks-ის, LSP-ის, დამატებების სინქრონიზაციის, ატრიბუციის, ავტო-მეხსიერების და CLAUDE.md ავტო-აღმოჩენის გამოტოვება]'
    '--ax-screen-reader[ეკრანის წამკითხველისთვის მოსახერხებელი გამოტანის რენდერი (ბრტყელი ტექსტი, დეკორატიული ჩარჩოებისა და ანიმაციების გარეშე)]'
    '(-v --version)'{-v,--version}'[ვერსიის ნომრის გამოტანა]'
    '(-h --help)'{-h,--help}'[ბრძანების დახმარების ჩვენება]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude commands' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "არგუმენტების გარეშე"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Claude Code MCP სერვერის გაშვება'
    'add:MCP სერვერის დამატება Claude Code-ში'
    'remove:MCP სერვერის წაშლა'
    'list:კონფიგურირებული MCP სერვერების სია'
    'get:MCP სერვერის დეტალების მიღება'
    'add-json:MCP სერვერის დამატება (stdio ან SSE) JSON სტრიქონით'
    'add-from-claude-desktop:MCP სერვერების იმპორტი Claude Desktop-დან (მხოლოდ Mac და WSL)'
    'reset-project-choices:პროექტის დონის (.mcp.json) ყველა დამტკიცებული/უარყოფილი სერვერის გადატვირთვა ამ პროექტში'
    'login:ავთენტიფიკაცია MCP სერვერთან (HTTP, SSE, ან claude.ai კონექტორი)'
    'logout:MCP სერვერისთვის შენახული OAuth მონაცემების გასუფთავება'
    'help:დახმარების ჩვენება'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp commands' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[დებაგ რეჟიმის ჩართვა]' \
            '--verbose[ვერბოზ რეჟიმის პარამეტრის გადაფარვა კონფიგურაციის ფაილიდან]' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[კონფიგურაციის არეალი (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[ტრანსპორტის ტიპი (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[გარემოს ცვლადის დაყენება (მაგ., -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[WebSocket header-ის დაყენება]:header:' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[კონფიგურაციის არეალი (local, user, project) - არსებული არეალიდან წაშლა თუ არ არის მითითებული]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[კონფიგურაციის არეალი (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[კონფიგურაციის არეალი (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:დამატების ან marketplace მანიფესტის ვალიდაცია'
    'marketplace:Claude Code marketplace-ების მართვა'
    'list:დაინსტალირებული დამატებების სია'
    'details:დამატების კომპონენტების ინვენტარისა და პროგნოზირებული ტოკენების ღირებულების ჩვენება'
    'install:დამატების ინსტალაცია ხელმისაწვდომი marketplace-ებიდან'
    'i:დამატების ინსტალაცია ხელმისაწვდომი marketplace-ებიდან (install-ის შემოკლება)'
    'init:ახალი დამატების ჩარჩოს შექმნა (ავტომატურად იტვირთება შემდეგ სესიაზე)'
    'uninstall:დაინსტალირებული დამატების წაშლა'
    'remove:დაინსტალირებული დამატების წაშლა (uninstall-ის ალიასი)'
    'enable:გამორთული დამატების ჩართვა'
    'disable:ჩართული დამატების გამორთვა'
    'update:დამატების განახლება უახლეს ვერსიამდე'
    'eval:eval შემთხვევების გაშვება დამატებაზე და შეფასებული შედეგების მოხსენება'
    'prune:ავტომატურად დაინსტალირებული აღარ საჭირო დამოკიდებულებების წაშლა'
    'tag:{name}--v{version} git ტეგის შექმნა დამატების რელიზისთვის'
    'help:დახმარების ჩვენება'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin commands' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[ინსტალაციის არეალი]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[ინსტალაციის არეალი]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[ინსტალაციის არეალი]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[ინსტალაციის არეალი]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:marketplace-ის დამატება URL-დან, გზიდან ან GitHub რეპოზიტორიიდან'
    'list:კონფიგურირებული marketplace-ების სია'
    'remove:კონფიგურირებული marketplace-ის წაშლა'
    'rm:კონფიგურირებული marketplace-ის წაშლა (remove-ის ალიასი)'
    'update:marketplace-ის განახლება წყაროდან - ყველას განახლება თუ სახელი არ არის მითითებული'
    'help:დახმარების ჩვენება'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace commands' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[იძულებითი ინსტალაცია თუ უკვე დაინსტალირებულია]' \
    '(-h --help)'{-h,--help}'[დახმარების ჩვენება]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[დამატებითი დირექტორია ინსტრუმენტების წვდომისთვის გაშვებულ სესიებში]:directory:_directories' \
    '--agent[ნაგულისხმევი აგენტი აგენტების ხედიდან გაშვებული სესიებისთვის]:agent:' \
    '--all[--json-თან: ასევე დასრულებული ფონური სესიების ჩართვა]' \
    '--allow-dangerously-skip-permissions[bypass-permissions რეჟიმის ხელმისაწვდომობა გაშვებული სესიებისთვის]' \
    '--cwd[მხოლოდ მითითებული გზის ქვეშ დაწყებული ფონური სესიების ჩვენება]:path:_directories' \
    '--dangerously-skip-permissions[--permission-mode bypassPermissions-ის ალიასი]' \
    '--effort[ნაგულისხმევი ძალისხმევის დონე გაშვებული სესიებისთვის]:level:(low medium high xhigh max)' \
    '--json[აქტიური სესიების დაბეჭდვა JSON მასივად და გასვლა]' \
    '*--mcp-config[MCP სერვერის კონფიგურაცია გაშვებულ სესიებზე გამოსაყენებლად]:config:' \
    '--model[ნაგულისხმევი მოდელი აგენტების ხედიდან გაშვებული სესიებისთვის]:model:' \
    '--permission-mode[ნაგულისხმევი ნებართვის რეჟიმი გაშვებული სესიებისთვის]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[დამატებების ჩატვირთვა დირექტორიიდან აგენტების ხედისა და გაშვებული სესიებისთვის]:path:_directories' \
    '--setting-sources[მძიმით გამოყოფილი პარამეტრების წყაროების სია ჩასატვირთად (user, project, local)]:sources:' \
    '--settings[პარამეტრების ფაილი ან JSON სტრიქონი გამოსაყენებლად]:file-or-json:_files' \
    '--strict-mcp-config[მხოლოდ --mcp-config-დან MCP სერვერების გამოყენება გაშვებულ სესიებში]' \
    '(-h --help)'{-h,--help}'[ბრძანების დახმარების ჩვენება]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:თქვენს Anthropic ანგარიშში შესვლა'
    'logout:თქვენი Anthropic ანგარიშიდან გამოსვლა'
    'status:ავთენტიფიკაციის სტატუსის ჩვენება'
    'help:დახმარების ჩვენება'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[ბრძანების დახმარების ჩვენება]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth commands' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[ბრძანების დახმარების ჩვენება]'
          ;;
      esac
      ;;
  esac
}

