_claude_ultrareview() {
  _arguments \
    '--json[დაუმუშავებელი bugs.json payload-ის დაბეჭდვა ფორმატირებული შედეგების ნაცვლად]' \
    '--timeout[მაქსიმალური წუთები მიმოხილვის დასრულებამდე მოსაცდელად]:minutes:' \
    '(-h --help)'{-h,--help}'[ბრძანების დახმარების ჩვენება]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
