      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[แสดงวิธีการใช้งานของคำสั่ง]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[แสดง payload bugs.json แบบดิบแทนผลการตรวจพบที่จัดรูปแบบแล้ว]' \
    '--timeout[จำนวนนาทีสูงสุดที่จะรอให้การรีวิวเสร็จสิ้น]:minutes:' \
    '(-h --help)'{-h,--help}'[แสดงวิธีการใช้งานของคำสั่ง]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
