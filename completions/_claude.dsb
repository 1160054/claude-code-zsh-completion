#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Konfiguruj a zastoj MCP-serwery'
    'plugin:Zastoj tykace Claude Code'
    'agents:Zastoj slězynowe agenty'
    'auth:Zastoj awtentifikaciju'
    'auto-mode:Pśeglědaj abo slědk staj konfiguraciju klasifikatora awtomatiskego modusa'
    'gateway:Startuj pśedewześowu awtentifikacijowu/telemetrijowu bramu'
    'project:Zastoj staw projekta Claude Code'
    'ultrareview:Startuj wobłakowu multiagentowu pśeglědku koda a wupiš wuslědki'
    'setup-token:Konfiguruj dłujkodobny awtentifikaciski token (trjeba abonement Claude)'
    'doctor:Pśeglědka strowoty awtomatiskego aktualizatora Claude Code'
    'update:Pśeglědaj a instaluj aktualizacije'
    'install:Instaluj natiwny build Claude Code'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Zmóžni debug-modus z opcionalnym filtrowanim kategorijow (na pś. "api,hooks" abo "!statsig,!file")]:filter:'
    '--verbose[Pśepiš nastajenje wobšyrnego modusa z konfiguraciskeje dataje]'
    '(-p --print)'{-p,--print}'[Wupiš wótegrono a skóńc (za wužywanje z pipes). Pokazka: wužywaj jano w dowěriwych zarědnikach]'
    '--output-format[Wudaśowy format (z --print): "text" (standard), "json" (jaden wuslědk) abo "stream-json" (streaming w realnem casu)]:format:(text json stream-json)'
    '--json-schema[JSON-schema za walidaciju strukturěrowanego wudaśa]:schema:'
    '--include-partial-messages[Zapśimej źělne kuski powěsćow, gaž pśidu (z --print a --output-format=stream-json)]'
    '--input-format[Zapódaśowy format (z --print): "text" (standard) abo "stream-json" (zapódaśe streaming w realnem casu)]:format:(text stream-json)'
    '--mcp-debug[\[Zestarjone. Wužywaj město togo --debug\] Zmóžni MCP-debug-modus (pokazujo zmólki MCP-serwera)]'
    '--dangerously-skip-permissions[Wobejź wšykne kontrole pšawow. Póraźone jano za sandboxy bźez internetowego pśistupa]'
    '--allow-dangerously-skip-permissions[Zmóžni opciju za wobejśe kontrolow pšawow, bźez toho aby ju standardnje zmóžnił]'
    '--max-budget-usd[Maksimalna suma dolarow za API-wołanja (jano --print)]:amount:'
    '--replay-user-messages[Sćel wužywarske powěsći ze stdin znowego na stdout za wobkšuśenje]'
    '--allowed-tools[Z komu abo prozninu źělona lisćina dowólonych mjenjow rědow (na pś. "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Z komu abo prozninu źělona lisćina dowólonych mjenjow rědow (format camelCase)]:tools:'
    '--tools[Pódaj lisćinu k dispoziciji stojecych rědow ze zatwarjoneje sajźby. Jano print-modus]:tools:'
    '--disallowed-tools[Z komu abo prozninu źělona lisćina njedowólonych mjenjow rědow (na pś. "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Z komu abo prozninu źělona lisćina njedowólonych mjenjow rědow (format camelCase)]:tools:'
    '--mcp-config[Zacytaj MCP-serwery z JSON-dataje abo znamuškoweje smuže (z prozninu źělone)]:configs:'
    '--system-prompt[Systemowy prompt za pósejźenje]:prompt:'
    '--append-system-prompt[Pśidaj systemowy prompt k standardnemu systemowemu promptoju]:prompt:'
    '--permission-mode[Modus pšawow za pósejźenje]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Pókšacuj z nejnowšeju rozgronu]'
    '(-r --resume)'{-r,--resume}'[Pókšacuj rozgronu - pódaj ID pósejźenja abo wubjeŕ interaktiwnje]:sessionId:_claude_sessions'
    '--fork-session[Napórej nowe ID pósejźenja město wóspjetnego wužywanja originalnego ID pśi pókšacowanju (z --resume abo --continue)]'
    '--no-session-persistence[Znjemóžni trajnosć pósejźenjow - pósejźenja se njeskłaźuju (jano --print)]'
    '--model[Model za aktualne pósejźenje. Pódaj alias za nejnowšy model (na pś. '\''sonnet'\'' abo '\''opus'\'')]:model:'
    '--agent[Agent za aktualne pósejźenje. Pśepisujo nastajenje '\''agent'\'']:agent:'
    '--betas[Beta-głowowe smuški za zapśimjeśe do API-napšašowanjow (jano wužywarje API-kluca)]:betas:'
    '--fallback-model[Zmóžni awtomatiske pśešaltowanje na pódany model, gaž standardny model jo pśeśěžony (jano --print)]:model:'
    '--settings[Sćažka k JSON-dataji z nastajenjami abo JSON-smuga za zacytanje pśidatnych nastajenjow]:file-or-json:_files'
    '--add-dir[Pśidatne zarědniki za dowólenje pśistupa rědow]:directories:_directories'
    '--ide[Awtomatiski zwěź z IDE pśi starśe, jolic akle jaden płaśiwy IDE jo k dispoziciji]'
    '--strict-mcp-config[Wužywaj jano MCP-serwery z --mcp-config a ignoruj wšykne druge MCP-nastajenja]'
    '--session-id[Wěste ID pósejźenja za rozgronu (musy płaśiwy UUID byś)]:uuid:'
    '--agents[JSON-objekt, kótaryž definěrujo swójske agenty]:json:'
    '--setting-sources[Z komu źělona lisćina žrědłow nastajenjow za zacytanje (user, project, local)]:sources:'
    '--plugin-dir[Zarědnik, z kótaregož se tykace za jano toś to pósejźenje zacytaju (wóspjetujobne)]:paths:_directories'
    '--disable-slash-commands[Znjemóžni wšykne slash-pśikaze]'
    '(--bg --background)'{--bg,--background}'[Startuj pósejźenje ako slězynowy agent a wrośej se ned]'
    '(-w --worktree)'{-w,--worktree}'[Napórej nowy git-worktree za toś to pósejźenje (opcionalnje pódaj mě)]::name:'
    '--tmux[Napórej tmux-pósejźenje za worktree (trjeba --worktree)]'
    '(-n --name)'{-n,--name}'[Nastaj pokazowańske mě za toś to pósejźenje]:name:'
    '--effort[Rownina procowanja za aktualne pósejźenje]:level:(low medium high xhigh max)'
    '--debug-file[Pisaj debug-protokole do wěsteje datajoweje sćažki (zmóžnijo implicitnje debug-modus)]:path:_files'
    '--from-pr[Pókšacuj pósejźenje zwězane z PR pśez numer/URL, abo wócyń interaktiwny wuběrak]::value:'
    '--remote-control[Startuj interaktiwne pósejźenje ze zmóžnjonym Remote Control (opcionalnje z mjenim)]::name:'
    '--remote-control-session-name-prefix[Prefiks za awtomatiski generěrowane mjenja pósejźenjow Remote Control]:prefix:'
    '--chrome[Zmóžni integraciju Claude in Chrome]'
    '--no-chrome[Znjemóžni integraciju Claude in Chrome]'
    '--plugin-url[Wobstaraj tykac .zip z URL za jano toś to pósejźenje (wóspjetujobne)]:url:'
    '--file[Datajowe resurse za ześěgnjenje pśi starśe (format: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Zmóžni pórucenja promptow (emitěrujo pśedwiźony pśiducy prompt w print/SDK-modusu)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Dalej dawaj tekst a myslenske bloki subagenta ako powěsći (z --print a stream-json)]'
    '--include-hook-events[Zapśimej wšykne tšojenja žywjeńskego cyklusa hookow do wudaśowego strima (z stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Pśesuń wótrězki specifiske za mašinu do prědneje wužywarskeje powěsći, aby se wužywanje prompt-cache pólěpšyło]'
    '--brief[Zmóžni rěd SendUserMessage za komunikaciju agent-wužywaŕ]'
    '--safe-mode[Startuj ze wšyknymi znjemóžnjonymi pśiměrjenjami (wužytne za pytanje zmólkow w wobškóźonej konfiguraciji)]'
    '--bare[Minimalny modus: pśeskóc hooks, LSP, synchronizaciju tykacow, atribuciju, awto-skład a awtomatiske namakanje CLAUDE.md]'
    '--ax-screen-reader[Renderěruj wudaśe pśijazne za cytak wobrazowki (płony tekst, žedne dekoratiwne kšomy abo animacije)]'
    '(-v --version)'{-v,--version}'[Wudaj wersijowy numer]'
    '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude pśikaze' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "žedne argumenty"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Startuj Claude Code MCP-serwer'
    'add:Pśidaj MCP-serwer do Claude Code'
    'remove:Wótwónoźej MCP-serwer'
    'list:Pokaž lisćinu skonfigurěrowanych MCP-serwerow'
    'get:Wobstaraj drobnostki MCP-serwera'
    'add-json:Pśidaj MCP-serwer (stdio abo SSE) z JSON-smugu'
    'add-from-claude-desktop:Importěruj MCP-serwery z Claude Desktop (jano Mac a WSL)'
    'reset-project-choices:Slědk staj wšykne pśiwólone/wótpokazane serwery na projektowej rowninje (.mcp.json) w toś tom projekśe'
    'login:Awtentifikěruj se z MCP-serwerom (HTTP, SSE abo konektor claude.ai)'
    'logout:Wuprozni skłaźone OAuth-pśizjawjeńske daty za MCP-serwer'
    'help:Pokaž pomoc'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp pśikaze' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Zmóžni debug-modus]' \
            '--verbose[Pśepiš nastajenje wobšyrnego modusa z konfiguraciskeje dataje]' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfiguraciska rownina (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Typ transporta (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Nastaj wokolinowu wariablu (na pś. -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[Nastaj WebSocket-głowowu smušku]:header:' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfiguraciska rownina (local, user, project) - wótwónoźej z eksistěrujuceje rowniny, jolic njepódane]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfiguraciska rownina (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfiguraciska rownina (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Waliděruj manifest tykaca abo torhošća'
    'marketplace:Zastoj torhošća Claude Code'
    'list:Pokaž lisćinu instalěrowanych tykacow'
    'details:Pokaž inwentar komponentow a pśedwiźone kosty tokenow za tykac'
    'install:Instaluj tykac z k dispoziciji stojecych torhošćow'
    'i:Instaluj tykac z k dispoziciji stojecych torhošćow (skrotconka za install)'
    'init:Napórej strukturu nowego tykaca (zacytajo se awtomatiski w pśiducem pósejźenju)'
    'uninstall:Deinstaluj instalěrowany tykac'
    'remove:Deinstaluj instalěrowany tykac (alias za uninstall)'
    'enable:Zmóžni znjemóžnjony tykac'
    'disable:Znjemóžni zmóžnjony tykac'
    'update:Aktualizěruj tykac na nejnowšu wersiju'
    'eval:Startuj eval-pady pśeśiwo tykacoju a rozprawiaj wugódnośone wuslědki'
    'prune:Wótwónoźej awtomatiski instalěrowane wótwisnosći, kótarež wěcej trjebne njejsu'
    'tag:Napórej git-tag {name}--v{version} za wózjawjenje tykaca'
    'help:Pokaž pomoc'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'tykack pśikaze' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Instalaciska rownina]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Instalaciska rownina]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Instalaciska rownina]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Instalaciska rownina]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Pśidaj torhošćo z URL, sćažki abo GitHub-repozitorija'
    'list:Pokaž lisćinu skonfigurěrowanych torhošćow'
    'remove:Wótwónoźej skonfigurěrowane torhošćo'
    'rm:Wótwónoźej skonfigurěrowane torhošćo (alias za remove)'
    'update:Aktualizěruj torhošćo ze žrědła - aktualizěruj wšykne, jolic žedne mě njepódane'
    'help:Pokaž pomoc'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'wiki pśikaze' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Wunuzuj instalaciju, samo jolic južo instalěrowane]' \
    '(-h --help)'{-h,--help}'[Pokaž pomoc]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Pśidatny zarědnik za dowólenje pśistupa rědow w wótpósłanych pósejźenjach]:directory:_directories' \
    '--agent[Standardny agent za pósejźenja wótpósłane z naglěda agentow]:agent:' \
    '--all[Z --json: zapśimej teke dokóńcone slězynowe pósejźenja]' \
    '--allow-dangerously-skip-permissions[Daj modus wobejśa pšawow k dispoziciji wótpósłanym pósejźenjam]' \
    '--cwd[Pokaž jano slězynowe pósejźenja startowane pód sćažku]:path:_directories' \
    '--dangerously-skip-permissions[Alias za --permission-mode bypassPermissions]' \
    '--effort[Standardna rownina procowanja za wótpósłane pósejźenja]:level:(low medium high xhigh max)' \
    '--json[Wupiš aktiwne pósejźenja ako JSON-pólo a skóńc]' \
    '*--mcp-config[Konfiguracija MCP-serwera za nałožowanje na wótpósłane pósejźenja]:config:' \
    '--model[Standardny model za pósejźenja wótpósłane z naglěda agentow]:model:' \
    '--permission-mode[Standardny modus pšawow za wótpósłane pósejźenja]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Zacytaj tykace ze zarědnika za naglěd agentow a wótpósłane pósejźenja]:path:_directories' \
    '--setting-sources[Z komu źělona lisćina žrědłow nastajenjow za zacytanje (user, project, local)]:sources:' \
    '--settings[Dataja nastajenjow abo JSON-smuga za nałožowanje]:file-or-json:_files' \
    '--strict-mcp-config[Wužywaj jano MCP-serwery z --mcp-config we wótpósłanych pósejźenjach]' \
    '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:Pśizjaw se do swójogo konta Anthropic'
    'logout:Wótzjaw se ze swójogo konta Anthropic'
    'status:Pokaž status awtentifikacije'
    'help:Pokaž pomoc'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth pśikaze' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]'
          ;;
      esac
      ;;
  esac
}

_claude_auto_mode() {
  local -a auto_mode_commands
  auto_mode_commands=(
    'config:Wupiš efektiwnu konfiguraciju awtomatiskego modusa ako JSON'
    'critique:Wobstaraj AI-reakciju na swóje swójske regle awtomatiskego modusa'
    'defaults:Wupiš standardne regle awtomatiskego modusa ako JSON'
    'reset:Slědk staj konfiguraciju awtomatiskego modusa na dodane standardne gódnoty'
    'help:Pokaž pomoc'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode pśikaze' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Sćažka ku gateway-YAML-konfiguraciji]:path:_files' \
    '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Wulašuj wšykon staw Claude Code za projekt (transkripty, nadawki, historija datajow, konfiguraciski zapisk)'
    'help:Pokaž pomoc'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project pśikaze' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Wupiš surowe bugs.json-daty město formatěrowanych wuslědkow]' \
    '--timeout[Maksimalne minuty cakanja na skóńcenje pśeglědki]:minutes:' \
    '(-h --help)'{-h,--help}'[Pokaž pomoc za pśikaz]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
