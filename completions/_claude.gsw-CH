_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Alli Claude Code-Status für e Projäkt lösche (Transkript, Ufgabe, Dateiverlauf, Konfigurationsiitrag)'
    'help:Hilf aazeige'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Hilf für Befehl aazeige]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project-Befehle' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilf für Befehl aazeige]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Rohi bugs.json-Nutzlast statt formatierti Ergebnis usgäh]' \
    '--timeout[Maximali Minute, wo uf de Abschluss vo de Überprüefig gwartet wird]:minutes:' \
    '(-h --help)'{-h,--help}'[Hilf für Befehl aazeige]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
