  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mostrar ayuda del comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandos de project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Mostrar ayuda del comando]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Imprimir el payload bruto de bugs.json en lugar de los hallazgos formateados]' \
    '--timeout[Minutos máximos a esperar a que finalice la revisión]:minutes:' \
    '(-h --help)'{-h,--help}'[Mostrar ayuda del comando]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
