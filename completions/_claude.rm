_claude_gateway() {
  _arguments \
    '--config[Via a la configuraziun YAML dal gateway]:path:_files' \
    '(-h --help)'{-h,--help}'[Mussar l'\''agid per il cumond]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Stizzar tut il stadi da Claude Code per in project (transcripziuns, incumbensas, cronologia da files, endataziun da configuraziun)'
    'help:Mussar l'\''agid'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mussar l'\''agid per il cumond]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'cumonds project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Mussar l'\''agid per il cumond]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Stampar il payload brut bugs.json empè dals resultats formatads]' \
    '--timeout[Minutas maximalas d'\''spetgar fin che la revisiun è finida]:minutes:' \
    '(-h --help)'{-h,--help}'[Mussar l'\''agid per il cumond]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
