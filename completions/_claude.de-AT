  _arguments -C \
    '(-h --help)'{-h,--help}'[Hilfe für Befehl anzeigen]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth-Befehle' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe für Befehl anzeigen]'
          ;;
      esac
      ;;
  esac
}

