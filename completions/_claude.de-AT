_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Alle Claude Code-Status für ein Projekt löschen (Transkripte, Aufgaben, Dateiverlauf, Konfigurationseintrag)'
    'help:Hilfe anzeigen'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Hilfe für Befehl anzeigen]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project-Befehle' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe für Befehl anzeigen]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Rohe bugs.json-Nutzlast statt formatierter Ergebnisse ausgeben]' \
    '--timeout[Maximale Minuten, die auf den Abschluss der Überprüfung gewartet wird]:minutes:' \
    '(-h --help)'{-h,--help}'[Hilfe für Befehl anzeigen]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
