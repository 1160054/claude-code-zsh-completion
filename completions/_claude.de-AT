#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:MCP-Server konfigurieren und verwalten'
    'plugin:Claude Code-Erweiterungen verwalten'
    'agents:Hintergrund-Agenten verwalten'
    'auth:Authentifizierung verwalten'
    'auto-mode:Auto-Modus-Klassifizierer-Konfiguration prüfen oder zurücksetzen'
    'gateway:Enterprise-Authentifizierungs-/Telemetrie-Gateway ausführen'
    'project:Claude Code-Projektstatus verwalten'
    'ultrareview:Cloud-gehostete Multi-Agent-Code-Überprüfung ausführen und Ergebnisse ausgeben'
    'setup-token:Langzeit-Authentifizierungstoken einrichten (benötigt Claude-Abonnement)'
    'doctor:Zustandsprüfung für Claude Code Auto-Updater'
    'update:Nach Updates suchen und installieren'
    'install:Claude Code native Build installieren'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Debug-Modus mit optionaler Kategoriefilterung aktivieren (z.B. "api,hooks" oder "!statsig,!file")]:filter:'
    '--verbose[Verbose-Modus aus Konfigurationsdatei überschreiben]'
    '(-p --print)'{-p,--print}'[Antwort ausgeben und beenden (für Verwendung mit Pipes). Hinweis: nur in vertrauenswürdigen Verzeichnissen verwenden]'
    '--output-format[Ausgabeformat (mit --print): "text" (Standard), "json" (einzelnes Ergebnis) oder "stream-json" (Echtzeit-Streaming)]:format:(text json stream-json)'
    '--json-schema[JSON-Schema für strukturierte Ausgabe-Validierung]:schema:'
    '--include-partial-messages[Teilweise Nachrichtenstücke bei Ankunft einschließen (mit --print und --output-format=stream-json)]'
    '--input-format[Eingabeformat (mit --print): "text" (Standard) oder "stream-json" (Echtzeit-Streaming-Eingabe)]:format:(text stream-json)'
    '--mcp-debug[\[Veraltet. Verwenden Sie stattdessen --debug\] MCP-Debug-Modus aktivieren (zeigt MCP-Serverfehler)]'
    '--dangerously-skip-permissions[Alle Berechtigungsprüfungen umgehen. Nur für Sandboxes ohne Internetzugang empfohlen]'
    '--allow-dangerously-skip-permissions[Option zum Umgehen von Berechtigungsprüfungen aktivieren, ohne standardmäßig zu aktivieren]'
    '--max-budget-usd[Maximaler Dollarbetrag für API-Aufrufe (nur --print)]:amount:'
    '--replay-user-messages[Benutzernachrichten von stdin auf stdout zur Bestätigung erneut senden]'
    '--allowed-tools[Komma- oder leerzeichengetrennte Liste erlaubter Werkzeugnamen (z.B. "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Komma- oder leerzeichengetrennte Liste erlaubter Werkzeugnamen (camelCase-Format)]:tools:'
    '--tools[Liste verfügbarer Werkzeuge aus eingebautem Set angeben. Nur Druckmodus]:tools:'
    '--disallowed-tools[Komma- oder leerzeichengetrennte Liste nicht erlaubter Werkzeugnamen (z.B. "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Komma- oder leerzeichengetrennte Liste nicht erlaubter Werkzeugnamen (camelCase-Format)]:tools:'
    '--mcp-config[MCP-Server aus JSON-Datei oder String laden (leerzeichengetrennt)]:configs:'
    '--system-prompt[System-Prompt für Sitzung verwenden]:prompt:'
    '--append-system-prompt[System-Prompt an Standard-System-Prompt anhängen]:prompt:'
    '--permission-mode[Berechtigungsmodus für Sitzung verwenden]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Die letzte Konversation fortsetzen]'
    '(-r --resume)'{-r,--resume}'[Konversation fortsetzen - Sitzungs-ID angeben oder interaktiv auswählen]:sessionId:_claude_sessions'
    '--fork-session[Neue Sitzungs-ID erstellen statt ursprüngliche Sitzungs-ID beim Fortsetzen wiederzuverwenden (mit --resume oder --continue)]'
    '--no-session-persistence[Sitzungspersistenz deaktivieren - Sitzungen werden nicht gespeichert (nur --print)]'
    '--model[Modell für aktuelle Sitzung. Alias für neuestes Modell angeben (z.B. '\''sonnet'\'' oder '\''opus'\'')]:model:'
    '--agent[Agent für die aktuelle Sitzung. Überschreibt die '\''agent'\''-Einstellung]:agent:'
    '--betas[Beta-Header für API-Anfragen einschließen (nur API-Schlüssel-Benutzer)]:betas:'
    '--fallback-model[Automatisches Zurückfallen auf angegebenes Modell aktivieren, wenn Standardmodell überlastet ist (nur --print)]:model:'
    '--settings[Pfad zu Einstellungen-JSON-Datei oder JSON-String zum Laden zusätzlicher Einstellungen]:file-or-json:_files'
    '--add-dir[Zusätzliche Verzeichnisse für Werkzeugzugriff erlauben]:directories:_directories'
    '--ide[Automatisch mit IDE beim Start verbinden, wenn genau eine gültige IDE verfügbar ist]'
    '--strict-mcp-config[Nur MCP-Server aus --mcp-config verwenden und alle anderen MCP-Einstellungen ignorieren]'
    '--session-id[Spezifische Sitzungs-ID für Konversation verwenden (muss gültige UUID sein)]:uuid:'
    '--agents[JSON-Objekt zur Definition benutzerdefinierter Agenten]:json:'
    '--setting-sources[Kommagetrennte Liste von Einstellungsquellen zum Laden (user, project, local)]:sources:'
    '--plugin-dir[Verzeichnis zum Laden von Erweiterungen nur für diese Sitzung (wiederholbar)]:paths:_directories'
    '--disable-slash-commands[Alle Slash-Befehle deaktivieren]'
    '(--bg --background)'{--bg,--background}'[Sitzung als Hintergrund-Agent starten und sofort zurückkehren]'
    '(-w --worktree)'{-w,--worktree}'[Neuen Git-Worktree für diese Sitzung erstellen (optional Namen angeben)]::name:'
    '--tmux[tmux-Sitzung für den Worktree erstellen (erfordert --worktree)]'
    '(-n --name)'{-n,--name}'[Anzeigenamen für diese Sitzung festlegen]:name:'
    '--effort[Aufwandsstufe für die aktuelle Sitzung]:level:(low medium high xhigh max)'
    '--debug-file[Debug-Protokolle in einen bestimmten Dateipfad schreiben (aktiviert implizit den Debug-Modus)]:path:_files'
    '--from-pr[Mit einem PR verknüpfte Sitzung nach Nummer/URL fortsetzen oder interaktive Auswahl öffnen]::value:'
    '--remote-control[Interaktive Sitzung mit aktivierter Fernsteuerung starten (optional benannt)]::name:'
    '--remote-control-session-name-prefix[Präfix für automatisch generierte Fernsteuerungs-Sitzungsnamen]:prefix:'
    '--chrome[Claude in Chrome-Integration aktivieren]'
    '--no-chrome[Claude in Chrome-Integration deaktivieren]'
    '--plugin-url[Erweiterungs-ZIP-Datei von einer URL nur für diese Sitzung abrufen (wiederholbar)]:url:'
    '--file[Dateiressourcen, die beim Start heruntergeladen werden (Format: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Prompt-Vorschläge aktivieren (gibt einen vorhergesagten nächsten Prompt im Druck-/SDK-Modus aus)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Subagent-Text und Denkblöcke als Nachrichten weiterleiten (mit --print und stream-json)]'
    '--include-hook-events[Alle Hook-Lebenszyklusereignisse in den Ausgabestream einschließen (mit stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Maschinenspezifische Abschnitte in die erste Benutzernachricht verschieben, um die Prompt-Cache-Wiederverwendung zu verbessern]'
    '--brief[SendUserMessage-Werkzeug für Agent-zu-Benutzer-Kommunikation aktivieren]'
    '--safe-mode[Mit allen deaktivierten Anpassungen starten (nützlich zur Fehlerbehebung einer defekten Konfiguration)]'
    '--bare[Minimalmodus: Hooks, LSP, Erweiterungs-Synchronisierung, Attribution, Auto-Memory und CLAUDE.md-Auto-Erkennung überspringen]'
    '--ax-screen-reader[Bildschirmleser-freundliche Ausgabe rendern (flacher Text, keine dekorativen Rahmen oder Animationen)]'
    '(-v --version)'{-v,--version}'[Versionsnummer ausgeben]'
    '(-h --help)'{-h,--help}'[Hilfe für Befehl anzeigen]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude-Befehle' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "keine Argumente"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Claude Code MCP-Server starten'
    'add:MCP-Server zu Claude Code hinzufügen'
    'remove:MCP-Server entfernen'
    'list:Konfigurierte MCP-Server auflisten'
    'get:MCP-Serverdetails abrufen'
    'add-json:MCP-Server (stdio oder SSE) mit JSON-String hinzufügen'
    'add-from-claude-desktop:MCP-Server von Claude Desktop importieren (nur Mac und WSL)'
    'reset-project-choices:Alle genehmigten/abgelehnten projektbezogenen (.mcp.json) Server in diesem Projekt zurücksetzen'
    'login:Bei einem MCP-Server authentifizieren (HTTP, SSE oder claude.ai-Connector)'
    'logout:Gespeicherte OAuth-Anmeldedaten für einen MCP-Server löschen'
    'help:Hilfe anzeigen'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp-Befehle' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Debug-Modus aktivieren]' \
            '--verbose[Verbose-Modus aus Konfigurationsdatei überschreiben]' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurationsbereich (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Transporttyp (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Umgebungsvariable festlegen (z.B. -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[WebSocket-Header festlegen]:header:' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurationsbereich (local, user, project) - aus bestehendem Bereich entfernen, falls nicht angegeben]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurationsbereich (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurationsbereich (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Erweiterung oder Marketplace-Manifest validieren'
    'marketplace:Claude Code-Marktplätze verwalten'
    'list:Installierte Erweiterungen auflisten'
    'details:Komponenteninventar und voraussichtliche Token-Kosten für eine Erweiterung anzeigen'
    'install:Erweiterung von verfügbaren Marktplätzen installieren'
    'i:Erweiterung von verfügbaren Marktplätzen installieren (Kurzform für install)'
    'init:Gerüst für eine neue Erweiterung erstellen (wird in nächster Sitzung automatisch geladen)'
    'uninstall:Installierte Erweiterung deinstallieren'
    'remove:Installierte Erweiterung deinstallieren (Alias für uninstall)'
    'enable:Deaktivierte Erweiterung aktivieren'
    'disable:Aktivierte Erweiterung deaktivieren'
    'update:Erweiterung auf die neueste Version aktualisieren'
    'eval:Eval-Fälle gegen eine Erweiterung ausführen und bewertete Ergebnisse melden'
    'prune:Automatisch installierte Abhängigkeiten entfernen, die nicht mehr benötigt werden'
    'tag:Einen {name}--v{version} Git-Tag für eine Erweiterungs-Veröffentlichung erstellen'
    'help:Hilfe anzeigen'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin-Befehle' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installationsbereich]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installationsbereich]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installationsbereich]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installationsbereich]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Marktplatz von URL, Pfad oder GitHub-Repository hinzufügen'
    'list:Konfigurierte Marktplätze auflisten'
    'remove:Konfigurierten Marktplatz entfernen'
    'rm:Konfigurierten Marktplatz entfernen (Alias für remove)'
    'update:Marktplatz von Quelle aktualisieren - alle aktualisieren, wenn kein Name angegeben'
    'help:Hilfe anzeigen'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace-Befehle' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Installation erzwingen, auch wenn bereits installiert]' \
    '(-h --help)'{-h,--help}'[Hilfe anzeigen]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Zusätzliches Verzeichnis für Werkzeugzugriff in versendeten Sitzungen zulassen]:directory:_directories' \
    '--agent[Standard-Agent für aus der Agentenansicht versendete Sitzungen]:agent:' \
    '--all[Mit --json: auch abgeschlossene Hintergrundsitzungen einschließen]' \
    '--allow-dangerously-skip-permissions[Bypass-Berechtigungsmodus für versendete Sitzungen verfügbar machen]' \
    '--cwd[Nur unter Pfad gestartete Hintergrundsitzungen anzeigen]:path:_directories' \
    '--dangerously-skip-permissions[Alias für --permission-mode bypassPermissions]' \
    '--effort[Standard-Aufwandsstufe für versendete Sitzungen]:level:(low medium high xhigh max)' \
    '--json[Aktive Sitzungen als JSON-Array ausgeben und beenden]' \
    '*--mcp-config[MCP-Server-Konfiguration für versendete Sitzungen anwenden]:config:' \
    '--model[Standardmodell für aus der Agentenansicht versendete Sitzungen]:model:' \
    '--permission-mode[Standard-Berechtigungsmodus für versendete Sitzungen]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Erweiterungen aus Verzeichnis für die Agentenansicht und versendete Sitzungen laden]:path:_directories' \
    '--setting-sources[Kommagetrennte Liste von Einstellungsquellen zum Laden (user, project, local)]:sources:' \
    '--settings[Einstellungsdatei oder JSON-String zum Anwenden]:file-or-json:_files' \
    '--strict-mcp-config[Nur MCP-Server aus --mcp-config in versendeten Sitzungen verwenden]' \
    '(-h --help)'{-h,--help}'[Hilfe für Befehl anzeigen]'
}

