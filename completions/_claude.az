  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Əmr üçün kömək göstər]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode commands' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Əmr üçün kömək göstər]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Şlüz YAML konfiqurasiyasına yol]:path:_files' \
    '(-h --help)'{-h,--help}'[Əmr üçün kömək göstər]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Layihə üçün bütün Claude Code vəziyyətini sil (transkriptlər, tapşırıqlar, fayl tarixçəsi, konfiqurasiya qeydi)'
    'help:Kömək göstər'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Əmr üçün kömək göstər]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Əmr üçün kömək göstər]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Formatlanmış nəticələr əvəzinə xam bugs.json yükünü çap et]' \
    '--timeout[Nəzərdən keçirmənin bitməsini gözləmək üçün maksimum dəqiqə]:minutes:' \
    '(-h --help)'{-h,--help}'[Əmr üçün kömək göstər]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
