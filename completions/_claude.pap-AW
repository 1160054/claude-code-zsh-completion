#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Konfigurá i manehá servidornan MCP'
    'plugin:Manehá pluginnan di Claude Code'
    'agents:Manehá agentenan di background'
    'auth:Manehá outentikashon'
    'auto-mode:Inspekshoná òf resetiá e konfigurashon di klasifikadó di modo outomátiko'
    'gateway:Kore e gateway di outentikashon/telemetria di empresa'
    'project:Manehá e estado di proyekto di Claude Code'
    'ultrareview:Kore un revishon di kódigo multi-agente den nube i mustra e resultadonan'
    'setup-token:Konfigurá un token di outentikashon di largu plaso (mester tin suskripshon di Claude)'
    'doctor:Chèk di salú pa e outo-aktualisadó di Claude Code'
    'update:Chèk pa i instalá aktualisashonnan'
    'install:Instalá e build nativo di Claude Code'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Habilitá modo debug ku filtrashon opshonal di kategoria (p.e., "api,hooks" òf "!statsig,!file")]:filter:'
    '--verbose[Anulá e konfigurashon di modo verbose for di e archivo di konfigurashon]'
    '(-p --print)'{-p,--print}'[Mustra e respuesta i sali (pa usa ku pipes). Nota: usa solamente den directorionan konfiabel]'
    '--output-format[Formato di salida (ku --print): "text" (default), "json" (un resultado), òf "stream-json" (streaming na tempo real)]:format:(text json stream-json)'
    '--json-schema[Skema JSON pa validashon di salida strukturá]:schema:'
    '--include-partial-messages[Inkluí pida-pida parsial di mensahe segun nan ta yega (ku --print i --output-format=stream-json)]'
    '--input-format[Formato di entrada (ku --print): "text" (default) òf "stream-json" (entrada streaming na tempo real)]:format:(text stream-json)'
    '--mcp-debug[\[Obsoleto. Usa --debug na su lugá\] Habilitá modo debug di MCP (ta mustra erornan di servidó MCP)]'
    '--dangerously-skip-permissions[Salta tur chèk di permiso. Rekomendá solamente pa sandbox sin akseso na internet]'
    '--allow-dangerously-skip-permissions[Habilitá e opshon pa salta chèk di permiso sin habilitá pa default]'
    '--max-budget-usd[Kantidat máksimo di dòler pa gasta na yamadanan API (solamente --print)]:amount:'
    '--replay-user-messages[Re-manda mensahenan di usuario for di stdin riba stdout pa konfirmashon]'
    '--allowed-tools[Lista separá ku koma òf espasio di nòmbernan di hèrmènt permití (p.e., "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Lista separá ku koma òf espasio di nòmbernan di hèrmènt permití (formato camelCase)]:tools:'
    '--tools[Spesifiká lista di hèrmèntnan disponibel for di e set inkorporá. Solamente modo print]:tools:'
    '--disallowed-tools[Lista separá ku koma òf espasio di nòmbernan di hèrmènt no permití (p.e., "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Lista separá ku koma òf espasio di nòmbernan di hèrmènt no permití (formato camelCase)]:tools:'
    '--mcp-config[Karga servidornan MCP for di archivo JSON òf string (separá ku espasio)]:configs:'
    '--system-prompt[Prompt di sistema pa usa pa e seshon]:prompt:'
    '--append-system-prompt[Añadí prompt di sistema na e prompt di sistema default]:prompt:'
    '--permission-mode[Modo di permiso pa usa pa e seshon]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Kontinuá e konbersashon mas resiente]'
    '(-r --resume)'{-r,--resume}'[Retomá un konbersashon - spesifiká session ID òf selektá interaktivamente]:sessionId:_claude_sessions'
    '--fork-session[Krea un session ID nobo en bes di reutilisá e session ID original ora ta retomá (ku --resume òf --continue)]'
    '--no-session-persistence[Desactivá persistensia di seshon - seshonnan lo no ser wardá (solamente --print)]'
    '--model[Modèl pa e seshon aktual. Spesifiká alias pa e modèl mas resiente (p.e., '\''sonnet'\'' òf '\''opus'\'')]:model:'
    '--agent[Agente pa e seshon aktual. Ta anulá e konfigurashon '\''agent'\'']:agent:'
    '--betas[Header beta pa inkluí den petishonnan API (solamente usuarionan di API key)]:betas:'
    '--fallback-model[Habilitá fallback outomátiko na e modèl spesifiká ora e modèl default ta sobrekargá (solamente --print)]:model:'
    '--settings[Kaminda na e archivo JSON di konfigurashon òf string JSON pa karga konfigurashon adishonal]:file-or-json:_files'
    '--add-dir[Directorionan adishonal pa permití akseso di hèrmènt]:directories:_directories'
    '--ide[Konektá outomátikamente na IDE na inisio si tin eksaktamente un IDE válido disponibel]'
    '--strict-mcp-config[Usa solamente servidornan MCP for di --mcp-config i ignorá tur otro konfigurashon MCP]'
    '--session-id[Session ID spesífiko pa usa pa e konbersashon (mester ta un UUID válido)]:uuid:'
    '--agents[Opheto JSON ku ta definí agentenan personalisá]:json:'
    '--setting-sources[Lista separá ku koma di fuentenan di konfigurashon pa karga (user, project, local)]:sources:'
    '--plugin-dir[Directorio pa karga plugin solamente pa e seshon aki (repetibel)]:paths:_directories'
    '--disable-slash-commands[Desactivá tur komando slash]'
    '(--bg --background)'{--bg,--background}'[Kuminsá e seshon komo un agente di background i bolbe mesora]'
    '(-w --worktree)'{-w,--worktree}'[Krea un git worktree nobo pa e seshon aki (opshonalmente spesifiká un nòmber)]::name:'
    '--tmux[Krea un seshon tmux pa e worktree (mester tin --worktree)]'
    '(-n --name)'{-n,--name}'[Pone un nòmber di mustra pa e seshon aki]:name:'
    '--effort[Nivel di esfuerso pa e seshon aktual]:level:(low medium high xhigh max)'
    '--debug-file[Skirbi log di debug na un kaminda di archivo spesífiko (ta habilitá modo debug implísitamente)]:path:_files'
    '--from-pr[Retomá un seshon konektá na un PR pa number/URL, òf habri e selektor interaktivo]::value:'
    '--remote-control[Kuminsá un seshon interaktivo ku Remote Control habilitá (opshonalmente ku nòmber)]::name:'
    '--remote-control-session-name-prefix[Prefiho pa nòmbernan di seshon Remote Control generá outomátikamente]:prefix:'
    '--chrome[Habilitá integrashon di Claude den Chrome]'
    '--no-chrome[Desactivá integrashon di Claude den Chrome]'
    '--plugin-url[Baha un .zip di plugin for di un URL solamente pa e seshon aki (repetibel)]:url:'
    '--file[Rekursonan di archivo pa baha na inisio (formato: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Habilitá sugerensianan di prompt (ta emití un siguiente prompt prediktá den modo print/SDK)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Reenvia teksto di subagente i blòki di pensamentu komo mensahe (ku --print i stream-json)]'
    '--include-hook-events[Inkluí tur evento di siklo di bida di hook den e stream di salida (ku stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Move e sekshonnan pa-máshin den e promé mensahe di usuario pa mehorá reutilisashon di prompt-cache]'
    '--brief[Habilitá e hèrmènt SendUserMessage pa komunikashon di agente pa usuario]'
    '--safe-mode[Kuminsá ku tur personalisashon desactivá (útil pa resolvé un konfigurashon kibrá)]'
    '--bare[Modo mínimo: salta hooks, LSP, sinkronisashon di plugin, atribushon, auto-memory, i outo-deskubrimentu di CLAUDE.md]'
    '--ax-screen-reader[Mustra salida amigabel pa lesadó di pantaya (teksto plat, sin borchi dekorativo ni animashon)]'
    '(-v --version)'{-v,--version}'[Mustra e number di vershon]'
    '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'komandonan claude' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "sin argumentonan"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Kuminsá un servidó MCP di Claude Code'
    'add:Añadí un servidó MCP na Claude Code'
    'remove:Kita un servidó MCP'
    'list:Lista e servidornan MCP konfigurá'
    'get:Haña detaye di servidó MCP'
    'add-json:Añadí un servidó MCP (stdio òf SSE) ku string JSON'
    'add-from-claude-desktop:Importá servidornan MCP for di Claude Desktop (solamente Mac i WSL)'
    'reset-project-choices:Resetiá tur servidó aprobá/rechasá na nivel di proyekto (.mcp.json) den e proyekto aki'
    'login:Outentiká ku un servidó MCP (HTTP, SSE, òf konektadó di claude.ai)'
    'logout:Kita e kredensialnan OAuth wardá pa un servidó MCP'
    'help:Mustra yudansa'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mustra yudansa]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'komandonan mcp' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Habilitá modo debug]' \
            '--verbose[Anulá e konfigurashon di modo verbose for di e archivo di konfigurashon]' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di konfigurashon (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Tipo di transporte (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Pone variabel di ambiente (p.e., -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[Pone header di WebSocket]:header:' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di konfigurashon (local, user, project) - kita for di e alkanse eksistente si no ta spesifiká]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di konfigurashon (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di konfigurashon (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Validá un manifest di plugin òf merkado'
    'marketplace:Manehá merkadonan di Claude Code'
    'list:Lista e pluginnan instalá'
    'details:Mustra inventario di komponente i kosto di token proyektá pa un plugin'
    'install:Instalá un plugin for di e merkadonan disponibel'
    'i:Instalá un plugin for di e merkadonan disponibel (kòrtiku pa install)'
    'init:Krea e struktura di un plugin nobo (ta karga outomátikamente e siguiente seshon)'
    'uninstall:Desinstalá un plugin instalá'
    'remove:Desinstalá un plugin instalá (alias pa uninstall)'
    'enable:Habilitá un plugin desactivá'
    'disable:Desactivá un plugin habilitá'
    'update:Aktualisá un plugin na e vershon mas resiente'
    'eval:Kore kasonan di eval kontra un plugin i reportá resultadonan ku punto'
    'prune:Kita dependensianan instalá outomátikamente ku no ta nesesario mas'
    'tag:Krea un git tag {name}--v{version} pa un release di plugin'
    'help:Mustra yudansa'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mustra yudansa]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'komandonan di plugin' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di instalashon]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di instalashon]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di instalashon]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Alkanse di instalashon]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Añadí un merkado for di URL, kaminda, òf repositorio GitHub'
    'list:Lista e merkadonan konfigurá'
    'remove:Kita un merkado konfigurá'
    'rm:Kita un merkado konfigurá (alias pa remove)'
    'update:Aktualisá merkado for di fuente - aktualisá tur si no ta spesifiká nòmber'
    'help:Mustra yudansa'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mustra yudansa]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'komandonan di merkado' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Forsá instalashon asta si ya ta instalá]' \
    '(-h --help)'{-h,--help}'[Mustra yudansa]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Directorio adishonal pa permití akseso di hèrmènt den seshonnan despachá]:directory:_directories' \
    '--agent[Agente default pa seshonnan despachá for di e bista di agente]:agent:' \
    '--all[Ku --json: inkluí tambe seshonnan di background kompletá]' \
    '--allow-dangerously-skip-permissions[Hasi modo bypass-permissions disponibel pa seshonnan despachá]' \
    '--cwd[Mustra solamente seshonnan di background kuminsá bou di e kaminda]:path:_directories' \
    '--dangerously-skip-permissions[Alias pa --permission-mode bypassPermissions]' \
    '--effort[Nivel di esfuerso default pa seshonnan despachá]:level:(low medium high xhigh max)' \
    '--json[Mustra seshonnan aktivo komo un array JSON i sali]' \
    '*--mcp-config[Konfigurashon di servidó MCP pa aplika na seshonnan despachá]:config:' \
    '--model[Modèl default pa seshonnan despachá for di e bista di agente]:model:' \
    '--permission-mode[Modo di permiso default pa seshonnan despachá]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Karga plugin for di directorio pa e bista di agente i seshonnan despachá]:path:_directories' \
    '--setting-sources[Lista separá ku koma di fuentenan di konfigurashon pa karga (user, project, local)]:sources:' \
    '--settings[Archivo di konfigurashon òf string JSON pa aplika]:file-or-json:_files' \
    '--strict-mcp-config[Usa solamente servidornan MCP for di --mcp-config den seshonnan despachá]' \
    '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:Login den bo kuenta di Anthropic'
    'logout:Log out for di bo kuenta di Anthropic'
    'status:Mustra e estado di outentikashon'
    'help:Mustra yudansa'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'komandonan auth' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]'
          ;;
      esac
      ;;
  esac
}

