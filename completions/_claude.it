}

_claude_ultrareview() {
  _arguments \
    '--json[Stampa il payload grezzo bugs.json invece dei risultati formattati]' \
    '--timeout[Minuti massimi di attesa per il completamento della revisione]:minutes:' \
    '(-h --help)'{-h,--help}'[Mostra la guida per il comando]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
