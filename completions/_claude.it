  local -a auth_commands
  auth_commands=(
    'login:Accedi al tuo account Anthropic'
    'logout:Disconnetti dal tuo account Anthropic'
    'status:Mostra lo stato dell'\''autenticazione'
    'help:Mostra la guida'
