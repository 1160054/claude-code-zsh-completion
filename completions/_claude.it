  _arguments -C \
    '(-h --help)'{-h,--help}'[Mostra la guida per il comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode commands' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Mostra la guida per il comando]'
          ;;
      esac
      ;;
  esac
}

