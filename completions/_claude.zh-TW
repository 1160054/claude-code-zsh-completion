#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:設定和管理 MCP 伺服器'
    'plugin:管理 Claude Code 外掛程式'
    'agents:管理背景代理程式'
    'auth:管理驗證'
    'auto-mode:檢查或重設自動模式分類器設定'
    'gateway:執行企業驗證/遙測閘道'
    'project:管理 Claude Code 專案狀態'
    'ultrareview:執行雲端託管的多代理程式程式碼審查並列印結果'
    'setup-token:設定長期驗證權杖（需要 Claude 訂閱）'
    'doctor:Claude Code 自動更新程式的健全狀況檢查'
    'update:檢查並安裝更新'
    'install:安裝 Claude Code 原生組建'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[啟用偵錯模式，可選類別篩選（例如 "api,hooks" 或 "!statsig,!file"）]:filter:'
    '--verbose[覆寫設定檔中的詳細資訊模式設定]'
    '(-p --print)'{-p,--print}'[列印回應並結束（用於管線）。注意：僅在受信任的目錄中使用]'
    '--output-format[輸出格式（搭配 --print）："text"（預設）、"json"（單一結果）或 "stream-json"（即時串流）]:format:(text json stream-json)'
    '--json-schema[用於結構化輸出驗證的 JSON 結構描述]:schema:'
    '--include-partial-messages[包含部分訊息區塊（搭配 --print 和 --output-format=stream-json）]'
    '--input-format[輸入格式（搭配 --print）："text"（預設）或 "stream-json"（即時串流輸入）]:format:(text stream-json)'
    '--mcp-debug[\[已淘汰。請改用 --debug\] 啟用 MCP 偵錯模式（顯示 MCP 伺服器錯誤）]'
    '--dangerously-skip-permissions[略過所有權限檢查。僅建議用於無網際網路存取的沙箱]'
    '--allow-dangerously-skip-permissions[啟用略過權限檢查的選項，但預設不啟用]'
    '--max-budget-usd[花費在 API 呼叫上的美元金額上限（僅限 --print）]:amount:'
    '--replay-user-messages[在 stdout 上重新傳送來自 stdin 的使用者訊息以進行確認]'
    '--allowed-tools[以逗號或空格分隔的允許工具名稱清單（例如 "Bash(git:*) Edit"）]:tools:'
    '--allowedTools[以逗號或空格分隔的允許工具名稱清單（駝峰式大小寫格式）]:tools:'
    '--tools[指定來自內建集的可用工具清單。僅列印模式]:tools:'
    '--disallowed-tools[以逗號或空格分隔的不允許工具名稱清單（例如 "Bash(git:*) Edit"）]:tools:'
    '--disallowedTools[以逗號或空格分隔的不允許工具名稱清單（駝峰式大小寫格式）]:tools:'
    '--mcp-config[從 JSON 檔案或字串載入 MCP 伺服器（以空格分隔）]:configs:'
    '--system-prompt[工作階段使用的系統提示]:prompt:'
    '--append-system-prompt[將系統提示附加至預設系統提示]:prompt:'
    '--permission-mode[工作階段使用的權限模式]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[繼續最近的對話]'
    '(-r --resume)'{-r,--resume}'[繼續對話 - 指定工作階段 ID 或互動式選取]:sessionId:_claude_sessions'
    '--fork-session[在繼續時建立新的工作階段 ID，而不是重複使用原始工作階段 ID（搭配 --resume 或 --continue）]'
    '--no-session-persistence[停用工作階段持續性 - 工作階段將不會儲存（僅限 --print）]'
    '--model[目前工作階段的模型。指定最新模型的別名（例如 '\''sonnet'\'' 或 '\''opus'\''）]:model:'
    '--agent[目前工作階段的代理程式。覆寫 '\''agent'\'' 設定]:agent:'
    '--betas[要包含在 API 要求中的 Beta 標頭（僅限 API 金鑰使用者）]:betas:'
    '--fallback-model[當預設模型過載時自動遞補至指定模型（僅限 --print）]:model:'
    '--settings[設定 JSON 檔案路徑或 JSON 字串以載入其他設定]:file-or-json:_files'
    '--add-dir[允許工具存取的其他目錄]:directories:_directories'
    '--ide[如果恰好有一個有效的 IDE，則在啟動時自動連線至 IDE]'
    '--strict-mcp-config[僅使用 --mcp-config 中的 MCP 伺服器，忽略所有其他 MCP 設定]'
    '--session-id[用於對話的特定工作階段 ID（必須是有效的 UUID）]:uuid:'
    '--agents[定義自訂代理程式的 JSON 物件]:json:'
    '--setting-sources[以逗號分隔的要載入的設定來源清單（user、project、local）]:sources:'
    '--plugin-dir[僅為此工作階段載入外掛程式的目錄（可重複）]:paths:_directories'
    '--disable-slash-commands[停用所有斜線命令]'
    '(--bg --background)'{--bg,--background}'[以背景代理程式啟動工作階段並立即返回]'
    '(-w --worktree)'{-w,--worktree}'[為此工作階段建立新的 git 工作樹（可選擇指定名稱）]::name:'
    '--tmux[為工作樹建立 tmux 工作階段（需要 --worktree）]'
    '(-n --name)'{-n,--name}'[為此工作階段設定顯示名稱]:name:'
    '--effort[目前工作階段的努力程度]:level:(low medium high xhigh max)'
    '--debug-file[將偵錯記錄寫入特定檔案路徑（隱含啟用偵錯模式）]:path:_files'
    '--from-pr[繼續依編號/URL 連結至 PR 的工作階段，或開啟互動式選擇器]::value:'
    '--remote-control[啟動已啟用遠端控制的互動式工作階段（可選擇命名）]::name:'
    '--remote-control-session-name-prefix[自動產生遠端控制工作階段名稱的前綴]:prefix:'
    '--chrome[啟用 Claude in Chrome 整合]'
    '--no-chrome[停用 Claude in Chrome 整合]'
    '--plugin-url[僅為此工作階段從 URL 擷取外掛程式 .zip（可重複）]:url:'
    '--file[啟動時要下載的檔案資源（格式：file_id:relative_path）]:specs:'
    '--prompt-suggestions[啟用提示建議（在列印/SDK 模式下發出預測的下一個提示）]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[將子代理程式文字和思考區塊轉送為訊息（搭配 --print 和 stream-json）]'
    '--include-hook-events[在輸出串流中包含所有 hook 生命週期事件（搭配 stream-json）]'
    '--exclude-dynamic-system-prompt-sections[將每台機器的區段移至第一則使用者訊息以改善提示快取重複使用]'
    '--brief[啟用 SendUserMessage 工具以進行代理程式對使用者的通訊]'
    '--safe-mode[停用所有自訂項目啟動（適合疑難排解損毀的設定）]'
    '--bare[最小模式：略過 hooks、LSP、外掛程式同步、屬性標示、自動記憶體和 CLAUDE.md 自動探索]'
    '--ax-screen-reader[呈現螢幕助讀程式友善的輸出（純文字，無裝飾性邊框或動畫）]'
    '(-v --version)'{-v,--version}'[輸出版本號碼]'
    '(-h --help)'{-h,--help}'[顯示命令說明]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude commands' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "no arguments"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:啟動 Claude Code MCP 伺服器'
    'add:將 MCP 伺服器新增至 Claude Code'
    'remove:移除 MCP 伺服器'
    'list:列出已設定的 MCP 伺服器'
    'get:取得 MCP 伺服器詳細資料'
    'add-json:使用 JSON 字串新增 MCP 伺服器（stdio 或 SSE）'
    'add-from-claude-desktop:從 Claude Desktop 匯入 MCP 伺服器（僅限 Mac 和 WSL）'
    'reset-project-choices:重設此專案中所有已核准/已拒絕的專案範圍（.mcp.json）伺服器'
    'login:向 MCP 伺服器驗證（HTTP、SSE 或 claude.ai 連接器）'
    'logout:清除 MCP 伺服器的已儲存 OAuth 認證'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp commands' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[啟用偵錯模式]' \
            '--verbose[覆寫設定檔中的詳細資訊模式設定]' \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project）]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[傳輸類型（stdio、sse、http）]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[設定環境變數（例如 -e KEY=value）]:env:' \
            '(-H --header)'{-H,--header}'[設定 WebSocket 標頭]:header:' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project） - 若未指定則從現有範圍移除]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project）]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project）]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:驗證外掛程式或市集資訊清單'
    'marketplace:管理 Claude Code 市集'
    'list:列出已安裝的外掛程式'
    'details:顯示外掛程式的元件清單和預估權杖成本'
    'install:從可用市集安裝外掛程式'
    'i:從可用市集安裝外掛程式（install 的簡寫）'
    'init:建立新外掛程式的骨架（下次工作階段自動載入）'
    'uninstall:解除安裝已安裝的外掛程式'
    'remove:解除安裝已安裝的外掛程式（uninstall 的別名）'
    'enable:啟用已停用的外掛程式'
    'disable:停用已啟用的外掛程式'
    'update:將外掛程式更新至最新版本'
    'eval:對外掛程式執行評估案例並回報評分結果'
    'prune:移除不再需要的自動安裝相依項目'
    'tag:為外掛程式版本建立 {name}--v{version} git 標籤'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin commands' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:從 URL、路徑或 GitHub 存放庫新增市集'
    'list:列出已設定的市集'
    'remove:移除已設定的市集'
    'rm:移除已設定的市集（remove 的別名）'
    'update:從來源更新市集 - 如未指定名稱則更新全部'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace commands' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[即使已安裝仍強制安裝]' \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[在派發的工作階段中允許工具存取的其他目錄]:directory:_directories' \
    '--agent[從代理程式檢視派發之工作階段的預設代理程式]:agent:' \
    '--all[搭配 --json：同時包含已完成的背景工作階段]' \
    '--allow-dangerously-skip-permissions[讓派發的工作階段可使用略過權限模式]' \
    '--cwd[僅顯示在路徑下啟動的背景工作階段]:path:_directories' \
    '--dangerously-skip-permissions[--permission-mode bypassPermissions 的別名]' \
    '--effort[派發之工作階段的預設努力程度]:level:(low medium high xhigh max)' \
    '--json[將作用中工作階段列印為 JSON 陣列並結束]' \
    '*--mcp-config[要套用至派發之工作階段的 MCP 伺服器設定]:config:' \
    '--model[從代理程式檢視派發之工作階段的預設模型]:model:' \
    '--permission-mode[派發之工作階段的預設權限模式]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[為代理程式檢視和派發的工作階段從目錄載入外掛程式]:path:_directories' \
    '--setting-sources[以逗號分隔的要載入的設定來源清單（user、project、local）]:sources:' \
    '--settings[要套用的設定檔或 JSON 字串]:file-or-json:_files' \
    '--strict-mcp-config[在派發的工作階段中僅使用 --mcp-config 中的 MCP 伺服器]' \
    '(-h --help)'{-h,--help}'[顯示命令說明]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:登入您的 Anthropic 帳戶'
    'logout:登出您的 Anthropic 帳戶'
    'status:顯示驗證狀態'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth commands' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示命令說明]'
          ;;
      esac
      ;;
  esac
}

_claude_auto_mode() {
  local -a auto_mode_commands
  auto_mode_commands=(
    'config:將有效的自動模式設定列印為 JSON'
    'critique:取得 AI 對您的自訂自動模式規則的回饋'
    'defaults:將預設的自動模式規則列印為 JSON'
    'reset:將自動模式設定重設為出廠預設值'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode commands' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示命令說明]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[閘道 YAML 設定的路徑]:path:_files' \
    '(-h --help)'{-h,--help}'[顯示命令說明]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:刪除專案的所有 Claude Code 狀態（記錄稿、工作、檔案歷程記錄、設定項目）'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示命令說明]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[列印原始 bugs.json 承載而非格式化的結果]' \
    '--timeout[等待審查完成的最長分鐘數]:minutes:' \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
