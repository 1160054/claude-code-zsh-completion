  _arguments -C \
    '(-h --help)'{-h,--help}'[نمایش راهنما برای دستور]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode commands' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[نمایش راهنما برای دستور]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[مسیر فایل پیکربندی YAML دروازه]:path:_files' \
    '(-h --help)'{-h,--help}'[نمایش راهنما برای دستور]'
}

