_claude_ultrareview() {
  _arguments \
    '--json[چاپ داده خام bugs.json به جای یافته‌های قالب‌بندی‌شده]' \
    '--timeout[حداکثر دقیقه‌ها برای انتظار تا پایان بازبینی]:minutes:' \
