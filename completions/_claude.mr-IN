      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[कमांडसाठी मदत प्रदर्शित करा]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[स्वरूपित निष्कर्षांऐवजी कच्चा bugs.json पेलोड प्रिंट करा]' \
    '--timeout[पुनरावलोकन पूर्ण होण्याची वाट पाहण्यासाठी कमाल मिनिटे]:minutes:' \
    '(-h --help)'{-h,--help}'[कमांडसाठी मदत प्रदर्शित करा]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
