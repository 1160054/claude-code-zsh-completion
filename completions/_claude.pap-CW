    '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'komandunan auto-mode' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Kaminda na e konfigurashon YAML di gateway]:path:_files' \
    '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Elimná tur estado di Claude Code pa un proyekto (transkripshon, tareanan, historia di archivo, entrada di konfigurashon)'
    'help:Mustra yudansa'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'komandunan di proyekto' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Imprimí e payload bruto di bugs.json en bes di resultadonan formatiá]' \
    '--timeout[Máksimo di minüt pa spera te ora e revishon kaba]:minutes:' \
    '(-h --help)'{-h,--help}'[Mustra yudansa pa e komando]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
