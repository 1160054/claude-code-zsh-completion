_claude_ultrareview() {
  _arguments \
    '--json[Udskriv den rå bugs.json-nyttelast i stedet for formaterede resultater]' \
    '--timeout[Maksimalt antal minutter at vente på at gennemgangen bliver færdig]:minutes:' \
