      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Percors ae configurazion YAML dal gateway]:path:_files' \
    '(-h --help)'{-h,--help}'[Mostrâ jutori pal comant]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Eliminâ dut il stât di Claude Code par un progjet (trascrizions, ativitâts, storic dai file, vôs di configurazion)'
    'help:Mostrâ jutori'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mostrâ jutori pal comant]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comants project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Mostrâ jutori pal comant]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Stampâ il payload grês bugs.json invezit dai risultâts formatâts]' \
    '--timeout[Minûts massims di spietâ che la revision e finissi]:minutes:' \
    '(-h --help)'{-h,--help}'[Mostrâ jutori pal comant]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
