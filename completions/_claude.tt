_claude_agents() {
  _arguments \
    '*--add-dir[Җибәрелгән сессияләрдә корал керүенә рөхсәт бирү өчен өстәмә каталог]:directory:_directories' \
    '--agent[Агент күренешеннән җибәрелгән сессияләр өчен килешенгән агент]:agent:' \
    '--all[--json белән: тәмамланган фон сессияләрен дә кертү]' \
    '--allow-dangerously-skip-permissions[Җибәрелгән сессияләргә рөхсәт-узу режимын мөмкин итү]' \
    '--cwd[Тик юл астында башланган фон сессияләрен күрсәтү]:path:_directories' \
    '--dangerously-skip-permissions[--permission-mode bypassPermissions өчен лакап исем]' \
    '--effort[Җибәрелгән сессияләр өчен килешенгән көч дәрәҗәсе]:level:(low medium high xhigh max)' \
    '--json[Актив сессияләрне JSON массивы буларак бастыру һәм чыгу]' \
    '*--mcp-config[Җибәрелгән сессияләргә куллану өчен MCP сервер көйләүе]:config:' \
    '--model[Агент күренешеннән җибәрелгән сессияләр өчен килешенгән модель]:model:' \
    '--permission-mode[Җибәрелгән сессияләр өчен килешенгән рөхсәт режимы]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Агент күренеше һәм җибәрелгән сессияләр өчен каталогтан плагиннар йөкләү]:path:_directories' \
    '--setting-sources[Йөкләү өчен өтер белән аерылган көйләү чыганаклары исемлеге (user, project, local)]:sources:' \
    '--settings[Куллану өчен көйләүләр файлы яки JSON юлы]:file-or-json:_files' \
    '--strict-mcp-config[Җибәрелгән сессияләрдә тик --mcp-config-тан MCP серверларын куллану]' \
    '(-h --help)'{-h,--help}'[Боерык өчен ярдәм күрсәтү]'
}

