_claude_ultrareview() {
  _arguments \
    '--json[Skriv ut den rå bugs.json-nyttelasta i staden for formaterte funn]' \
    '--timeout[Maksimalt tal minutt å vente på at gjennomgangen skal fullførast]:minutes:' \
    '(-h --help)'{-h,--help}'[Vis hjelp for kommando]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
