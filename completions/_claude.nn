#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Konfigurer og administrer MCP-tenarar'
    'plugin:Administrer Claude Code-tillegg'
    'agents:Administrer bakgrunnsagentar'
    'auth:Administrer autentisering'
    'auto-mode:Inspiser eller tilbakestill konfigurasjon for auto-modus-klassifisering'
    'gateway:Køyr autentiserings-/telemetrigatewayen for verksemd'
    'project:Administrer Claude Code-prosjekttilstand'
    'ultrareview:Køyr ein skybasert kodegjennomgang med fleire agentar og skriv ut funna'
    'setup-token:Konfigurer langsiktig autentiseringstoken (krev Claude-abonnement)'
    'doctor:Helsekontroll for Claude Code automatisk oppdatering'
    'update:Søk etter og installer oppdateringar'
    'install:Installer Claude Code native build'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Aktiver feilsøkingsmodus med valfri kategorifiltrering (t.d. "api,hooks" eller "!statsig,!file")]:filter:'
    '--verbose[Overstyr detaljert modus frå konfigurasjonsfil]'
    '(-p --print)'{-p,--print}'[Skriv ut svar og avslutt (for bruk med pipes). Merk: bruk berre i betrodde mapper]'
    '--output-format[Utdataformat (med --print): "text" (standard), "json" (enkelt resultat) eller "stream-json" (sanntidsstrøyming)]:format:(text json stream-json)'
    '--json-schema[JSON-skjema for strukturert utdatavalidering]:schema:'
    '--include-partial-messages[Inkluder delvise meldingsbitar når dei kjem (med --print og --output-format=stream-json)]'
    '--input-format[Inndataformat (med --print): "text" (standard) eller "stream-json" (sanntidsstrøyming)]:format:(text stream-json)'
    '--mcp-debug[\[Forelda. Bruk --debug i staden\] Aktiver MCP-feilsøkingsmodus (viser MCP-tenarar feil)]'
    '--dangerously-skip-permissions[Omgå alle tillatelseskontrollar. Tilrådd berre for sandkasser utan internettilgang]'
    '--allow-dangerously-skip-permissions[Aktiver moglegheit for å omgå tillatelseskontrollar utan å aktivere som standard]'
    '--max-budget-usd[Maksimalt dollarbeløp å bruke på API-kall (berre --print)]:amount:'
    '--replay-user-messages[Send brukarmeldingar frå stdin på stdout for stadfesting]'
    '--allowed-tools[Komma- eller mellomromseparert liste over tillatne verktøynamn (t.d. "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Komma- eller mellomromseparert liste over tillatne verktøynamn (camelCase-format)]:tools:'
    '--tools[Angi liste over tilgjengelege verktøy frå innebygd sett. Berre utskriftsmodus]:tools:'
    '--disallowed-tools[Komma- eller mellomromseparert liste over ikkje-tillatne verktøynamn (t.d. "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Komma- eller mellomromseparert liste over ikkje-tillatne verktøynamn (camelCase-format)]:tools:'
    '--mcp-config[Last inn MCP-tenarar frå JSON-fil eller streng (mellomromseparert)]:configs:'
    '--system-prompt[Systemprompt å bruke for økt]:prompt:'
    '--append-system-prompt[Legg til systemprompt til standard systemprompt]:prompt:'
    '--permission-mode[Tillatelsesmodus å bruke for økt]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Hald fram den siste samtalen]'
    '(-r --resume)'{-r,--resume}'[Gjenoppta ei samtale - angi økt-ID eller vel interaktivt]:sessionId:_claude_sessions'
    '--fork-session[Opprett ny økt-ID i staden for å gjenbruke original økt-ID ved gjenopptak (med --resume eller --continue)]'
    '--no-session-persistence[Deaktiver øktpersistens - økter vert ikkje lagra (berre --print)]'
    '--model[Modell for gjeldande økt. Angi alias for nyaste modell (t.d. '\''sonnet'\'' eller '\''opus'\'')]:model:'
    '--agent[Agent for gjeldande økt. Overstyrer '\''agent'\''-innstillinga]:agent:'
    '--betas[Beta-headerar å inkludere i API-førespurnader (berre API-nøkkelbrukarar)]:betas:'
    '--fallback-model[Aktiver automatisk tilbakefall til angitt modell når standardmodellen er overbelasta (berre --print)]:model:'
    '--settings[Sti til innstillingar JSON-fil eller JSON-streng for å laste ytterlegare innstillingar]:file-or-json:_files'
    '--add-dir[Ytterlegare mapper å tillate verktøytilgang]:directories:_directories'
    '--ide[Kople automatisk til IDE ved oppstart dersom nøyaktig éin gyldig IDE er tilgjengeleg]'
    '--strict-mcp-config[Bruk berre MCP-tenarar frå --mcp-config og ignorer alle andre MCP-innstillingar]'
    '--session-id[Spesifikk økt-ID å bruke for samtale (må vere gyldig UUID)]:uuid:'
    '--agents[JSON-objekt som definerer tilpassa agentar]:json:'
    '--setting-sources[Kommaseparert liste over innstillingskjelder å laste (user, project, local)]:sources:'
    '--plugin-dir[Mappe å laste tillegg frå berre for denne økta (kan gjentakast)]:paths:_directories'
    '--disable-slash-commands[Deaktiver alle skråstrekkommandoar]'
    '(--bg --background)'{--bg,--background}'[Start økta som ein bakgrunnsagent og returner umiddelbart]'
    '(-w --worktree)'{-w,--worktree}'[Opprett eit nytt git-arbeidstre for denne økta (angi eventuelt eit namn)]::name:'
    '--tmux[Opprett ei tmux-økt for arbeidstreet (krev --worktree)]'
    '(-n --name)'{-n,--name}'[Set eit visingsnamn for denne økta]:name:'
    '--effort[Innsatsnivå for gjeldande økt]:level:(low medium high xhigh max)'
    '--debug-file[Skriv feilsøkingsloggar til ein spesifikk filsti (aktiverer implisitt feilsøkingsmodus)]:path:_files'
    '--from-pr[Gjenoppta ei økt kopla til ein PR via nummer/URL, eller opne interaktiv veljar]::value:'
    '--remote-control[Start ei interaktiv økt med Fjernstyring aktivert (eventuelt namngitt)]::name:'
    '--remote-control-session-name-prefix[Prefiks for automatisk genererte Fjernstyring-øktnamn]:prefix:'
    '--chrome[Aktiver Claude i Chrome-integrasjon]'
    '--no-chrome[Deaktiver Claude i Chrome-integrasjon]'
    '--plugin-url[Hent eit tillegg .zip frå ein URL berre for denne økta (kan gjentakast)]:url:'
    '--file[Filressursar å laste ned ved oppstart (format: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Aktiver promptforslag (sender ut ein forventa neste prompt i print-/SDK-modus)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Vidaresend delagenttekst og tenkeblokker som meldingar (med --print og stream-json)]'
    '--include-hook-events[Inkluder alle hook-livssyklushendingar i utdatastraumen (med stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Flytt maskinspesifikke seksjonar inn i den første brukarmeldinga for å forbetre gjenbruk av promptcache]'
    '--brief[Aktiver SendUserMessage-verktøyet for kommunikasjon frå agent til brukar]'
    '--safe-mode[Start med alle tilpassingar deaktiverte (nyttig for feilsøking av ein øydelagd konfigurasjon)]'
    '--bare[Minimal modus: hopp over hooks, LSP, tilleggssynkronisering, attribusjon, auto-minne og CLAUDE.md-autooppdaging]'
    '--ax-screen-reader[Vis skjermlesarvenleg utdata (flat tekst, ingen dekorative kantar eller animasjonar)]'
    '(-v --version)'{-v,--version}'[Vis versjonsnummer]'
    '(-h --help)'{-h,--help}'[Vis hjelp for kommando]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude-kommandoar' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "ingen argument"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Start ein Claude Code MCP-tenar'
    'add:Legg til ein MCP-tenar til Claude Code'
    'remove:Fjern ein MCP-tenar'
    'list:Vis konfigurerte MCP-tenarar'
    'get:Hent MCP-tenardetaljar'
    'add-json:Legg til ein MCP-tenar (stdio eller SSE) med JSON-streng'
    'add-from-claude-desktop:Importer MCP-tenarar frå Claude Desktop (berre Mac og WSL)'
    'reset-project-choices:Tilbakestill alle godkjende/avviste prosjektomfattande (.mcp.json) tenarar i dette prosjektet'
    'login:Autentiser med ein MCP-tenar (HTTP, SSE eller claude.ai-koplar)'
    'logout:Fjern lagra OAuth-legitimasjon for ein MCP-tenar'
    'help:Vis hjelp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp-kommandoar' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Aktiver feilsøkingsmodus]' \
            '--verbose[Overstyr detaljert modus frå konfigurasjonsfil]' \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Transporttype (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Angi miljøvariabel (t.d. -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[Angi WebSocket-header]:header:' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project) - fjern frå eksisterande omfang dersom uspesifisert]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasjonsomfang (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Valider eit tillegg eller marknadsplassmanifest'
    'marketplace:Administrer Claude Code-marknadsplassar'
    'list:Vis installerte tillegg'
    'details:Vis komponentoversikt og forventa tokenkostnad for eit tillegg'
    'install:Installer eit tillegg frå tilgjengelege marknadsplassar'
    'i:Installer eit tillegg frå tilgjengelege marknadsplassar (kort for install)'
    'init:Lag stillas for eit nytt tillegg (autolastar neste økt)'
    'uninstall:Avinstaller eit installert tillegg'
    'remove:Avinstaller eit installert tillegg (alias for uninstall)'
    'enable:Aktiver eit deaktivert tillegg'
    'disable:Deaktiver eit aktivert tillegg'
    'update:Oppdater eit tillegg til nyaste versjon'
    'eval:Køyr evalueringstilfelle mot eit tillegg og rapporter poengsette resultat'
    'prune:Fjern autoinstallerte avhengigheiter som ikkje lenger trengst'
    'tag:Opprett ein {name}--v{version} git-tag for ei tilleggsutgjeving'
    'help:Vis hjelp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin-kommandoar' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasjonsomfang]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Legg til ein marknadsplassfrå URL, sti eller GitHub-repository'
    'list:Vis konfigurerte marknadsplassar'
    'remove:Fjern ein konfigurert marknadsplassplassett'
    'rm:Fjern ein konfigurert marknadsplassplassett (alias for remove)'
    'update:Oppdater marknadsplassfrå kjelde - oppdater alle dersom intet namn er angitt'
    'help:Vis hjelp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace-kommandoar' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Vis hjelp]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Tving installasjon sjølv om allereie installert]' \
    '(-h --help)'{-h,--help}'[Vis hjelp]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Ytterlegare mappe å tillate verktøytilgang til i utsende økter]:directory:_directories' \
    '--agent[Standardagent for økter utsende frå agentvisinga]:agent:' \
    '--all[Med --json: inkluder òg fullførte bakgrunnsøkter]' \
    '--allow-dangerously-skip-permissions[Gjer omgå-tillatelsar-modus tilgjengeleg for utsende økter]' \
    '--cwd[Vis berre bakgrunnsøkter starta under sti]:path:_directories' \
    '--dangerously-skip-permissions[Alias for --permission-mode bypassPermissions]' \
    '--effort[Standard innsatsnivå for utsende økter]:level:(low medium high xhigh max)' \
    '--json[Skriv ut aktive økter som ein JSON-array og avslutt]' \
    '*--mcp-config[MCP-tenarkonfigurasjon å bruke på utsende økter]:config:' \
    '--model[Standardmodell for økter utsende frå agentvisinga]:model:' \
    '--permission-mode[Standard tillatelsesmodus for utsende økter]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Last tillegg frå mappe for agentvisinga og utsende økter]:path:_directories' \
    '--setting-sources[Kommaseparert liste over innstillingskjelder å laste (user, project, local)]:sources:' \
    '--settings[Innstillingsfil eller JSON-streng å bruke]:file-or-json:_files' \
    '--strict-mcp-config[Bruk berre MCP-tenarar frå --mcp-config i utsende økter]' \
    '(-h --help)'{-h,--help}'[Vis hjelp for kommando]'
}

