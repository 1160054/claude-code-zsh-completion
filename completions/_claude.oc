      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Camin vèrs la configuracion YAML de la palanca]:path:_files' \
    '(-h --help)'{-h,--help}'[Afichar l'\''ajuda per la comanda]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Suprimir tot l'\''estat Claude Code per un projècte (transcripcions, prètzfaches, istoric dels fichièrs, entrada de configuracion)'
    'help:Afichar l'\''ajuda'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Afichar l'\''ajuda per la comanda]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandas project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Afichar l'\''ajuda per la comanda]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Afichar la carga bugs.json bruta al luòc dels resultats formatats]' \
    '--timeout[Nombre maximal de minutas d'\''esperar que la revision s'\''acabe]:minutes:' \
    '(-h --help)'{-h,--help}'[Afichar l'\''ajuda per la comanda]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
