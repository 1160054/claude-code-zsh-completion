#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Konfigure te yor ay serwëer MCP'
    'plugin:Yor ay plugin bu Claude Code'
    'agents:Yor ay ajaŋ bu background'
    'auth:Yor autentifikasion'
    'auto-mode:Seet walla reset konfigurasion classifier bu auto mode'
    'gateway:Doxal gateway auth/telemetry bu entreprise'
    'project:Yor état projet bu Claude Code'
    'ultrareview:Doxal ab review kode multi-agent ci cloud te wone li ñu gis'
    'setup-token:Defar token autentifikasion bu yàgg (soxla na abonnement Claude)'
    'doctor:Saytu wér-gu-yaram bu auto-updater bu Claude Code'
    'update:Seet te instale ay mise à jour'
    'install:Instale build native bu Claude Code'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Tàggat mode debug ak filtre kategori bu optionel (misaal, "api,hooks" walla "!statsig,!file")]:filter:'
    '--verbose[Soppi réglaas mode verbose bu jóge ci fiise config]'
    '(-p --print)'{-p,--print}'[Wone réponse te génn (ngir jëfandikoo ak pipes). Njël: jëfandikoo rekk ci ay répertoire bu ñu wóolu]'
    '--output-format[Format bu output (ak --print): "text" (default), "json" (benn résultat), walla "stream-json" (streaming ci waxtu wu jaadu)]:format:(text json stream-json)'
    '--json-schema[Schema JSON ngir validasion output bu structuré]:schema:'
    '--include-partial-messages[Boole ay chunk bataaxal bu partiel ci saa yu ñuy ñów (ak --print ak --output-format=stream-json)]'
    '--input-format[Format bu input (ak --print): "text" (default) walla "stream-json" (input streaming ci waxtu wu jaadu)]:format:(text stream-json)'
    '--mcp-debug[\[Bàyyeeku. Jëfandikoo --debug\] Tàggat mode debug MCP (dafay wone ay erreur serwëer MCP)]'
    '--dangerously-skip-permissions[Weesu ëpp saytu permission yépp. Ñu koy digal rekk ngir sandbox yu amul access internet]'
    '--allow-dangerously-skip-permissions[Tàggat opsion bu weesu saytu permission te taggatul ko par défaut]'
    '--max-budget-usd[Xaalis dollar bu gëna kawe ngir jëfandikoo ci ay appel API (--print rekk)]:amount:'
    '--replay-user-messages[Yónnee ci at ay bataaxal utilisateur bu jóge stdin ci stdout ngir konfirmasion]'
    '--allowed-tools[Limu tur bu outil bu ñu may, ratax ak virgule walla espaas (misaal, "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Limu tur bu outil bu ñu may, ratax ak virgule walla espaas (format camelCase)]:tools:'
    '--tools[Wone limu outil yu am ci ansàmb built-in. Mode print rekk]:tools:'
    '--disallowed-tools[Limu tur bu outil bu ñu tere, ratax ak virgule walla espaas (misaal, "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Limu tur bu outil bu ñu tere, ratax ak virgule walla espaas (format camelCase)]:tools:'
    '--mcp-config[Yeb ay serwëer MCP bu jóge ci fiise JSON walla string (ratax ak espaas)]:configs:'
    '--system-prompt[Prompt système bu ñuy jëfandikoo ngir session]:prompt:'
    '--append-system-prompt[Yokk prompt système ci prompt système bu default]:prompt:'
    '--permission-mode[Mode permission bu ñuy jëfandikoo ngir session]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Wéyal waxtaan bi gëna yees]'
    '(-r --resume)'{-r,--resume}'[Dellu ci ab waxtaan - wone session ID walla tànn ci anteraktivite]:sessionId:_claude_sessions'
    '--fork-session[Sos session ID bu bees ci lu dul jëfandikooti session ID bu njëkk bu ñuy delluwaat (ak --resume walla --continue)]'
    '--no-session-persistence[Tere persistence bu session - session yi duñu denc (--print rekk)]'
    '--model[Model ngir session bi nekk. Wone alias ngir model bi gëna yees (misaal, '\''sonnet'\'' walla '\''opus'\'')]:model:'
    '--agent[Ajaŋ ngir session bi nekk. Dafay soppi réglaas '\''agent'\'']:agent:'
    '--betas[Header beta yu ñuy boole ci ay requête API (jëfandikookat bu API key rekk)]:betas:'
    '--fallback-model[Tàggat fallback otomatik ci model bu ñu wone bu model bu default chargé lool (--print rekk)]:model:'
    '--settings[Yoon ci fiise JSON réglaas walla string JSON ngir yeb réglaas yu yokk]:file-or-json:_files'
    '--add-dir[Ay répertoire yu yokk ngir may access outil]:directories:_directories'
    '--ide[Jokkoo otomatik ak IDE ci tàmbali bu benn IDE bu baax rekk am]'
    '--strict-mcp-config[Jëfandikoo rekk ay serwëer MCP bu jóge --mcp-config te bàyyi réglaas MCP yépp yu ci des]'
    '--session-id[Session ID bu wóor ngir jëfandikoo ci waxtaan (fàww mu doon UUID bu baax)]:uuid:'
    '--agents[Objet JSON bu wone ay ajaŋ bu custom]:json:'
    '--setting-sources[Limu source réglaas bu ñuy yeb, ratax ak virgule (user, project, local)]:sources:'
    '--plugin-dir[Répertoire bu ñuy yeb ay plugin ngir session bii rekk (mën na ñu ko baamtu)]:paths:_directories'
    '--disable-slash-commands[Tere komond slash yépp]'
    '(--bg --background)'{--bg,--background}'[Tàmbali session bi ni ab ajaŋ background te dellu ci saa si]'
    '(-w --worktree)'{-w,--worktree}'[Sos ab worktree git bu bees ngir session bii (mën nga wone tur bu optionel)]::name:'
    '--tmux[Sos ab session tmux ngir worktree bi (soxla na --worktree)]'
    '(-n --name)'{-n,--name}'[Def ab tur bu wone ngir session bii]:name:'
    '--effort[Niveau effort ngir session bi nekk]:level:(low medium high xhigh max)'
    '--debug-file[Bind ay log debug ci ab yoon fiise bu wóor (dafay tàggat mode debug ci lu wóoral)]:path:_files'
    '--from-pr[Dellu ci ab session bu ñu boole ak ab PR ci nimero/URL, walla ubbi picker anteraktif]::value:'
    '--remote-control[Tàmbali session anteraktif ak Remote Control bu ñu tàggat (mën na am tur bu optionel)]::name:'
    '--remote-control-session-name-prefix[Prefix ngir tur session Remote Control bu ñu génère otomatik]:prefix:'
    '--chrome[Tàggat integrasion Claude ci Chrome]'
    '--no-chrome[Tere integrasion Claude ci Chrome]'
    '--plugin-url[Jël ab plugin .zip bu jóge ci ab URL ngir session bii rekk (mën na ñu ko baamtu)]:url:'
    '--file[Ay ressource fiise bu ñuy télécharge ci tàmbali (format: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Tàggat suggestion prompt (dafay génne prompt bu ñuy topp bu ñu prédire ci mode print/SDK)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Yónnee text subagent ak bloc xalaat ni ay bataaxal (ak --print ak stream-json)]'
    '--include-hook-events[Boole event lifecycle hook yépp ci stream output (ak stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Yóbbu section per-machine ci bataaxal utilisateur bu njëkk ngir gëna baax reuse bu prompt-cache]'
    '--brief[Tàggat outil SendUserMessage ngir jokkoo ajaŋ-ci-utilisateur]'
    '--safe-mode[Tàmbali ak customisation yépp yu ñu tere (baax na ngir saytu ab konfigurasion bu yàqu)]'
    '--bare[Mode minimal: dee hooks, LSP, sync plugin, attribution, auto-memory, ak auto-discovery CLAUDE.md]'
    '--ax-screen-reader[Wone output bu jaadu ak screen-reader (text bu flat, amul border walla animasion decoratif)]'
    '(-v --version)'{-v,--version}'[Wone nimero version]'
    '(-h --help)'{-h,--help}'[Wone ndimbal ci komond bi]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'ay commande claude' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "amul argument"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Tàmbali ab serwëer MCP bu Claude Code'
    'add:Yokk ab serwëer MCP ci Claude Code'
    'remove:Dindi ab serwëer MCP'
    'list:Wone limu serwëer MCP yu ñu konfigure'
    'get:Jël détails serwëer MCP'
    'add-json:Yokk ab serwëer MCP (stdio walla SSE) ak string JSON'
    'add-from-claude-desktop:Import ay serwëer MCP bu jóge Claude Desktop (Mac ak WSL rekk)'
    'reset-project-choices:Reset serwëer yépp yu ñu nangu/ban yu project-scoped (.mcp.json) ci projet bii'
    'login:Autentifie ak ab serwëer MCP (HTTP, SSE, walla connector claude.ai)'
    'logout:Dindi credentials OAuth yu ñu denc ngir ab serwëer MCP'
    'help:Wone ndimbal'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Wone ndimbal]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'ay commande mcp' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Tàggat mode debug]' \
            '--verbose[Soppi réglaas mode verbose bu jóge ci fiise config]' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ config (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Xeetu transport (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Def variable environnement (misaal, -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[Def header WebSocket]:header:' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ config (local, user, project) - dindi ci waññ bi am bu ñu ko wonewul]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ config (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ config (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Validate manifest bu plugin walla marché'
    'marketplace:Yor ay marché bu Claude Code'
    'list:Wone limu plugin yu ñu instale'
    'details:Wone inventaire composant ak coût token bu ñu prédire ngir ab plugin'
    'install:Instale ab plugin bu jóge ci ay marché yu am'
    'i:Instale ab plugin bu jóge ci ay marché yu am (raccourci bu install)'
    'init:Defar ab plugin bu bees (dafay yeb otomatik ci session bu ñëw)'
    'uninstall:Dindi ab plugin bu ñu instale'
    'remove:Dindi ab plugin bu ñu instale (alias bu uninstall)'
    'enable:Tàggat ab plugin bu ñu tere'
    'disable:Tere ab plugin bu ñu tàggat'
    'update:Mettre à jour ab plugin ci version bi gëna yees'
    'eval:Doxal ay cas eval ci ab plugin te wone résultat yu ñu noté'
    'prune:Dindi ay dépendance yu ñu instale otomatik yu ñu soxlaatul'
    'tag:Sos ab tag git {name}--v{version} ngir ab release plugin'
    'help:Wone ndimbal'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Wone ndimbal]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'ay commande plugin' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ instalasion]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ instalasion]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ instalasion]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Waññ instalasion]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

