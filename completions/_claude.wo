_claude_ultrareview() {
  _arguments \
    '--json[Wone payload bugs.json bu raw ci lu dul li ñu gis bu ñu formaté]' \
    '--timeout[Nombre minute bu gëna kawe ngir xaar review bi jeex]:minutes:' \
    '(-h --help)'{-h,--help}'[Wone ndimbal ci komond bi]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
