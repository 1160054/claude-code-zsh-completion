          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Wone ndimbal]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Force instalasion doonte bu ñu ko instale ba noppi]' \
    '(-h --help)'{-h,--help}'[Wone ndimbal]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Répertoire yu yokk ngir may access outil ci session yu ñu dispatch]:directory:_directories' \
    '--agent[Ajaŋ default ngir session yu ñu dispatch bu jóge agent view]:agent:' \
    '--all[Ak --json: boole itam session background yu ñu jeexal]' \
    '--allow-dangerously-skip-permissions[Def mode bypass-permissions bu am ngir session yu ñu dispatch]' \
    '--cwd[Wone rekk session background yu ñu tàmbali ci yoon wi]:path:_directories' \
    '--dangerously-skip-permissions[Alias bu --permission-mode bypassPermissions]' \
    '--effort[Niveau effort default ngir session yu ñu dispatch]:level:(low medium high xhigh max)' \
    '--json[Wone session yu doxal ni array JSON te génn]' \
    '*--mcp-config[Konfigurasion serwëer MCP bu ñuy applique ci session yu ñu dispatch]:config:' \
    '--model[Model default ngir session yu ñu dispatch bu jóge agent view]:model:' \
    '--permission-mode[Mode permission default ngir session yu ñu dispatch]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Yeb ay plugin bu jóge répertoire ngir agent view ak session yu ñu dispatch]:path:_directories' \
    '--setting-sources[Limu source réglaas bu ñuy yeb, ratax ak virgule (user, project, local)]:sources:' \
    '--settings[Fiise réglaas walla string JSON bu ñuy applique]:file-or-json:_files' \
    '--strict-mcp-config[Jëfandikoo rekk ay serwëer MCP bu jóge --mcp-config ci session yu ñu dispatch]' \
    '(-h --help)'{-h,--help}'[Wone ndimbal ci komond bi]'
}

