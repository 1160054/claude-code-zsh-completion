#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:бһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһ“бһ·бһ„бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP'
    'plugin:бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷ Claude Code'
    'agents:бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһ—бҹ’бһ“бһ¶бһҖбҹӢбһ„бһ¶бһҡбһ•бҹ’бһ‘бҹғбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҷ'
    'auth:бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһ¶бһҡбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢ'
    'auto-mode:бһ–бһ·бһ“бһ·бһҸбҹ’бһҷ бһ¬бһҖбҹҶбһҺбһҸбҹӢбһЎбһҫбһ„бһңбһ·бһүбһ“бһјбһңбһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһ…бһ¶бһҸбҹӢбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҡбһ”бҹҖбһ”бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·'
    'gateway:бһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡ gateway бһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢ/telemetry бһҹбһ бһӮбҹ’бһҡбһ¶бһҹ'
    'project:бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ–бһӮбһҳбҹ’бһҡбҹ„бһ„ Claude Code'
    'ultrareview:бһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҖбһ¶бһҡбһҸбҹ’бһҡбһҪбһҸбһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҖбһјбһҠбһ–бһ бһ»бһ—бҹ’бһ“бһ¶бһҖбҹӢбһ„бһ¶бһҡбһҠбҹӮбһӣбһ”бһ„бҹ’бһ бҹ„бҹҮбһӣбһҫ cloud бһ бһҫбһҷбһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһҖбһ¶бһҡбһҡбһҖбһғбһҫбһү'
    'setup-token:бһҖбҹҶбһҺбһҸбҹӢбһҗбһјбһҒбһ№бһ“бһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢбһҡбһҷбҹҲбһ–бҹҒбһӣбһңбҹӮбһ„ (бһҸбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһҖбһ¶бһҡбһҮбһ¶бһң Claude)'
    'doctor:бһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҹбһ»бһҒбһ—бһ¶бһ–бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһ’бҹ’бһңбһҫбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“бһ—бһ¶бһ–бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ· Claude Code'
    'update:бһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһ“бһ·бһ„бһҠбҹҶбһЎбһҫбһ„бһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“бһ—бһ¶бһ–'
    'install:бһҠбҹҶбһЎбһҫбһ„ Claude Code бһҹбҹҶбһҺбһ„бҹӢбһҠбһҫбһҳ'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[бһ”бһҫбһҖбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҡбһ”бҹҖбһ”бһ”бҹҶбһ”бһ¶бһҸбҹӢбһҖбҹҶбһ бһ»бһҹ бһҮбһ¶бһҳбһҪбһҷбһҖбһ¶бһҡбһҸбҹ’бһҡбһ„бһ”бҹ’бһҡбһ—бҹҒбһ‘бһҹбҹ’бһҡбҹҒбһ…бһ…бһ·бһҸбҹ’бһҸ (бһ§. "api,hooks" бһ¬ "!statsig,!file")]:filter:'
    '--verbose[бһ”бһҠбһ·бһҹбҹҒбһ’бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ”бҹҖбһ”бһӣбһҳбҹ’бһўбһ·бһҸбһ–бһёбһҜбһҖбһҹбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’]'
    '(-p --print)'{-p,--print}'[бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһҖбһ¶бһҡбһҶбҹ’бһӣбһҫбһҷбһҸбһ”бһ бһҫбһҷбһ…бҹҒбһү (бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ”бҹ’бһҡбһҫбһҮбһ¶бһҳбһҪбһҷбһ”бҹҶбһ–бһ„бҹӢ)бҹ” бһҹбҹҶбһӮбһ¶бһӣбҹӢбҹ– бһ”бҹ’бһҡбһҫбһҸбҹӮбһҖбҹ’бһ“бһ»бһ„бһҗбһҸбһҠбҹӮбһӣбһ‘бһ»бһҖбһ…бһ·бһҸбҹ’бһҸбһ”бҹүбһ»бһҺбҹ’бһҺбҹ„бҹҮ]'
    '--output-format[бһ‘бһҳбҹ’бһҡбһ„бҹӢбһӣбһ‘бҹ’бһ’бһ•бһӣ (бһҮбһ¶бһҳбһҪбһҷ --print)бҹ– "text" (бһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳ), "json" (бһӣбһ‘бҹ’бһ’бһ•бһӣбһҸбҹӮбһҳбһҪбһҷ) бһ¬ "stream-json" (бһҹбҹ’бһ‘бҹ’бһҡбһёбһҳбһ–бҹҒбһӣбһңбҹҒбһӣбһ¶бһҮбһ¶бһҖбҹӢбһҹбҹ’бһҸбҹӮбһ„)]:format:(text json stream-json)'
    '--json-schema[бһҹбҹ’бһӮбһёбһҳ JSON бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢбһӣбһ‘бҹ’бһ’бһ•бһӣбһҠбҹӮбһӣбһҳбһ¶бһ“бһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’]:schema:'
    '--include-partial-messages[бһҡбһҪбһҳбһ”бһүбҹ’бһ…бһјбһӣбһ•бҹ’бһ“бҹӮбһҖбһҹбһ¶бһҡбһҡбһ„бҹ— (бһҮбһ¶бһҳбһҪбһҷ --print бһ“бһ·бһ„ --output-format=stream-json)]'
    '--input-format[бһ‘бһҳбҹ’бһҡбһ„бҹӢбһ”бһүбҹ’бһ…бһјбһӣ (бһҮбһ¶бһҳбһҪбһҷ --print)бҹ– "text" (бһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳ) бһ¬ "stream-json" (бһҹбҹ’бһ‘бҹ’бһҡбһёбһҳбһ”бһүбҹ’бһ…бһјбһӣбһ–бҹҒбһӣбһңбҹҒбһӣбһ¶бһҮбһ¶бһҖбҹӢбһҹбҹ’бһҸбҹӮбһ„)]:format:(text stream-json)'
    '--mcp-debug[гҖҗбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһ”бҹ„бҹҮбһ”бһ„бҹӢбһ…бҹ„бһӣбҹ” бһҹбһјбһҳбһ”бҹ’бһҡбһҫ --debug бһҮбҹҶбһ“бһҪбһҹбһңбһ·бһүгҖ‘ бһ”бһҫбһҖбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҡбһ”бҹҖбһ”бһ”бҹҶбһ”бһ¶бһҸбҹӢбһҖбҹҶбһ бһ»бһҹ MCP (бһ”бһ„бҹ’бһ бһ¶бһүбһҖбҹҶбһ бһ»бһҹбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP)]'
    '--dangerously-skip-permissions[бһҡбҹҶбһӣбһ„бһҖбһ¶бһҡбһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҹбһ·бһ‘бҹ’бһ’бһ·бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбҹ” бһ•бҹ’бһҸбһӣбҹӢбһўбһ“бһ»бһҹбһ¶бһҹбһ“бҹҚбһҸбҹӮбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢ sandbox бһҠбҹӮбһӣбһӮбҹ’бһҳбһ¶бһ“бһҖбһ¶бһҡбһ…бһјбһӣбһ”бҹ’бһҡбһҫбһўбҹҠбһёбһ“бһ’бһәбһҺбһ·бһҸбһ”бҹүбһ»бһҺбҹ’бһҺбҹ„бҹҮ]'
    '--allow-dangerously-skip-permissions[бһ”бһҫбһҖбһҮбһҳбҹ’бһҡбһҫбһҹбһҡбҹҶбһӣбһ„бһҖбһ¶бһҡбһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҹбһ·бһ‘бҹ’бһ’бһ· бһ”бҹүбһ»бһ“бҹ’бһҸбҹӮбһҳбһ·бһ“бһ”бһҫбһҖбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҮбһ¶бһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбһ‘бҹҒ]'
    '--max-budget-usd[бһ…бҹҶбһ“бһҪбһ“бһ”бҹ’бһҡбһ¶бһҖбҹӢбһҠбһ»бһӣбҹ’бһӣбһ¶бһҡбһўбһҸбһ·бһ”бһҡбһҳбһ¶бһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңбһ…бҹҶбһҺбһ¶бһҷбһӣбһҫбһҖбһ¶бһҡбһ бҹ… API (бһҸбҹӮ --print бһ”бҹүбһ»бһҺбҹ’бһҺбҹ„бҹҮ)]:amount:'
    '--replay-user-messages[бһ•бҹ’бһүбһҫбһҹбһ¶бһҡбһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһҳбҹ’бһҸбһ„бһ‘бҹҖбһҸбһ–бһё stdin бһ“бҹ…бһӣбһҫ stdout бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһ”бһүбҹ’бһҮбһ¶бһҖбҹӢ]'
    '--allowed-tools[бһ”бһүбҹ’бһҮбһёбһҲбҹ’бһҳбҹ„бҹҮбһ§бһ”бһҖбһҡбһҺбҹҚбһҠбҹӮбһӣбһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸ (бһ•бҹ’бһҸбһ¶бһ…бҹӢбһҠбҹ„бһҷбһҹбһүбҹ’бһүбһ¶бһҖбҹ’бһ”бҹҖбһҹ бһ¬бһҠбһҖбһғбҹ’бһӣбһ¶ бһ§. "Bash(git:*) Edit")]:tools:'
    '--allowedTools[бһ”бһүбҹ’бһҮбһёбһҲбҹ’бһҳбҹ„бҹҮбһ§бһ”бһҖбһҡбһҺбҹҚбһҠбҹӮбһӣбһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸ (бһ‘бһҳбҹ’бһҡбһ„бҹӢ camelCase)]:tools:'
    '--tools[бһ”бһүбҹ’бһҮбһ¶бһҖбҹӢбһ”бһүбҹ’бһҮбһёбһ§бһ”бһҖбһҡбһҺбҹҚбһҠбҹӮбһӣбһҳбһ¶бһ“бһ–бһёбһҹбҹҶбһҺбһ»бҹҶбһҠбҹӮбһӣбһ”бһ„бҹ’бһҖбһ”бҹӢбһҳбһҖбҹ” бһҸбҹӮбһҡбһ”бҹҖбһ”бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһ”бҹүбһ»бһҺбҹ’бһҺбҹ„бҹҮ]:tools:'
    '--disallowed-tools[бһ”бһүбҹ’бһҮбһёбһҲбҹ’бһҳбҹ„бҹҮбһ§бһ”бһҖбһҡбһҺбҹҚбһҠбҹӮбһӣбһҳбһ·бһ“бһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸ (бһ•бҹ’бһҸбһ¶бһ…бҹӢбһҠбҹ„бһҷбһҹбһүбҹ’бһүбһ¶бһҖбҹ’бһ”бҹҖбһҹ бһ¬бһҠбһҖбһғбҹ’бһӣбһ¶ бһ§. "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[бһ”бһүбҹ’бһҮбһёбһҲбҹ’бһҳбҹ„бҹҮбһ§бһ”бһҖбһҡбһҺбҹҚбһҠбҹӮбһӣбһҳбһ·бһ“бһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸ (бһ‘бһҳбҹ’бһҡбһ„бҹӢ camelCase)]:tools:'
    '--mcp-config[бһ•бҹ’бһ‘бһ»бһҖбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһ–бһёбһҜбһҖбһҹбһ¶бһҡ JSON бһ¬бһҒбҹ’бһҹбҹӮбһўбһҖбҹ’бһҹбһҡ (бһ•бҹ’бһҸбһ¶бһ…бҹӢбһҠбҹ„бһҷбһҠбһҖбһғбҹ’бһӣбһ¶)]:configs:'
    '--system-prompt[бһҖбһ¶бһҡбһҮбҹҶбһҡбһ»бһүбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһӮбҹ’бһӮ]:prompt:'
