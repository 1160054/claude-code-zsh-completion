    '--plugin-url[бһ‘бһ¶бһүбһҷбһҖ .zip бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһ–бһё URL бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһӮбҹ’бһӮбһ“бҹҒбҹҮбһҸбҹӮбһ”бҹүбһ»бһҺбҹ’бһҺбҹ„бҹҮ (бһўбһ¶бһ…бһ’бҹ’бһңбһҫбһҳбҹ’бһҸбһ„бһ‘бҹҖбһҸ)]:url:'
    '--file[бһ’бһ“бһ’бһ¶бһ“бһҜбһҖбһҹбһ¶бһҡбһҠбҹӮбһӣбһҸбҹ’бһҡбһјбһңбһ‘бһ¶бһүбһҷбһҖбһ“бҹ…бһ–бҹҒбһӣбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ (бһ‘бһҳбҹ’бһҡбһ„бҹӢбҹ– file_id:relative_path)]:specs:'
    '--prompt-suggestions[бһ”бһҫбһҖбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҖбһ¶бһҡбһҺбҹӮбһ“бһ¶бҹҶбһҖбһ¶бһҡбһҮбҹҶбһҡбһ»бһү (бһ”бһүбҹ’бһ…бҹҒбһүбһҖбһ¶бһҡбһҮбҹҶбһҡбһ»бһүбһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢбһҠбҹӮбһӣбһ”бһ¶бһ“бһ‘бһҹбҹ’бһҹбһ“бҹҚбһ‘бһ¶бһҷбһҖбҹ’бһ“бһ»бһ„бһҡбһ”бҹҖбһ” print/SDK)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[бһ”бһүбҹ’бһҮбһјбһ“бһўбһҸбҹ’бһҗбһ”бһ‘ subagent бһ“бһ·бһ„бһ”бҹ’бһӣбһ»бһҖбһӮбҹҶбһ“бһ·бһҸбһҮбһ¶бһҹбһ¶бһҡ (бһҮбһ¶бһҳбһҪбһҷ --print бһ“бһ·бһ„ stream-json)]'
    '--include-hook-events[бһҡбһҪбһҳбһ”бһүбҹ’бһ…бһјбһӣбһ–бҹ’бһҡбһ№бһҸбҹ’бһҸбһ·бһҖбһ¶бһҡбһҺбҹҚбһңбһҠбҹ’бһҸбһҮбһёбһңбһ·бһҸ hook бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбһҖбҹ’бһ“бһ»бһ„бһҹбҹ’бһ‘бҹ’бһҡбһёбһҳбһӣбһ‘бҹ’бһ’бһ•бһӣ (бһҮбһ¶бһҳбһҪбһҷ stream-json)]'
    '--exclude-dynamic-system-prompt-sections[бһ•бҹ’бһӣбһ¶бһҹбҹӢбһ‘бһёбһ•бҹ’бһ“бҹӮбһҖбһҸбһ¶бһҳбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһ‘бҹ…бһҹбһ¶бһҡбһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫбһҠбҹҶбһ”бһјбһ„ бһҠбһҫбһҳбҹ’бһ”бһёбһҖбҹӮбһӣбһҳбҹ’бһўбһҖбһ¶бһҡбһ”бҹ’бһҡбһҫбһЎбһҫбһ„бһңбһ·бһүбһ“бҹғ prompt-cache]'
    '--brief[бһ”бһҫбһҖбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһ§бһ”бһҖбһҡбһҺбҹҚ SendUserMessage бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһ—бҹ’бһ“бһ¶бһҖбҹӢбһ„бһ¶бһҡбһ‘бҹ…бһўбҹ’бһ“бһҖбһ”бҹ’бһҡбһҫ]'
    '--safe-mode[бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһҠбҹ„бһҷбһ”бһ·бһ‘бһҖбһ¶бһҡбһ”бҹ’бһҸбһјбһҡбһҸбһ¶бһҳбһ”бҹҶбһҺбһ„бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ (бһҳбһ¶бһ“бһ”бҹ’бһҡбһҷбҹ„бһҮбһ“бҹҚбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһҠбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһ”бһүбҹ’бһ бһ¶бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҠбҹӮбһӣбһҒбһјбһ…)]'
    '--bare[бһҡбһ”бҹҖбһ”бһўбһ”бҹ’бһ”бһ”бһҡбһҳбһ¶бҹ– бһҡбҹҶбһӣбһ„ hooks, LSP, бһҖбһ¶бһҡбһ’бҹ’бһңбһҫбһҹбһҳбһҖбһ¶бһӣбһҖбһҳбҹ’бһҳбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷ, attribution, auto-memory бһ“бһ·бһ„бһҖбһ¶бһҡбһҡбһҖбһғбһҫбһү CLAUDE.md бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·]'
    '--ax-screen-reader[бһ”бһ„бҹ’бһ бһ¶бһүбһӣбһ‘бҹ’бһ’бһ•бһӣбһҠбҹӮбһӣбһ„бһ¶бһҷбһҹбҹ’бһҡбһҪбһӣбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһўбһ¶бһ“бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢ (бһўбһҸбҹ’бһҗбһ”бһ‘бһҡбһ¶бһ”бһҹбҹ’бһҳбһҫ бһӮбҹ’бһҳбһ¶бһ“бһҹбҹҠбһ»бһҳбһҸбһ»бһ”бһҸбҹӮбһ„ бһ¬бһ…бһӣбһ“бһ¶)]'
    '(-v --version)'{-v,--version}'[бһ”бһүбҹ’бһ…бҹҒбһүбһӣбҹҒбһҒбһҖбҹҶбһҺбҹӮ]'
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude commands' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "бһӮбҹ’бһҳбһ¶бһ“бһўбһ¶бһӮбһ»бһҷбһҳбҹүбһ„бҹӢ"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһҡбһ”бһҹбҹӢ Claude Code'
    'add:бһ”бһ“бҹ’бһҗбҹӮбһҳбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһ‘бҹ… Claude Code'
    'remove:бһӣбһ»бһ”бһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP'
    'list:бһҡбһ¶бһҷбһ”бһүбҹ’бһҮбһёбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһҠбҹӮбһӣбһ”бһ¶бһ“бһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’'
    'get:бһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһӣбһҳбҹ’бһўбһ·бһҸбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP'
    'add-json:бһ”бһ“бҹ’бһҗбҹӮбһҳбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһҮбһ¶бһҳбһҪбһҷбһҒбҹ’бһҹбҹӮбһўбһҖбҹ’бһҹбһҡ JSON (stdio бһ¬ SSE)'
    'add-from-claude-desktop:бһ“бһ¶бҹҶбһ…бһјбһӣбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһ–бһё Claude Desktop (бһҸбҹӮ Mac бһ“бһ·бһ„ WSL бһ”бҹүбһ»бһҺбҹ’бһҺбҹ„бҹҮ)'
    'reset-project-choices:бһҖбҹҶбһҺбһҸбҹӢбһЎбһҫбһ„бһңбһ·бһүбһ“бһјбһңбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒбһҠбҹӮбһӣбһҳбһ¶бһ“бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһӮбһҳбҹ’бһҡбҹ„бһ„ (.mcp.json) бһҠбҹӮбһӣбһ”бһ¶бһ“бһўбһ“бһ»бһҳбҹҗбһҸ/бһ”бһҠбһ·бһҹбҹҒбһ’бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбһҖбҹ’бһ“бһ»бһ„бһӮбһҳбҹ’бһҡбҹ„бһ„бһ“бҹҒбҹҮ'
    'login:бһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢбһҮбһ¶бһҳбһҪбһҷбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP (HTTP, SSE бһ¬бһ§бһ”бһҖбһҡбһҺбҹҚбһ—бҹ’бһҮбһ¶бһ”бҹӢ claude.ai)'
    'logout:бһҹбһҳбҹ’бһўбһ¶бһҸбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһҹбһҳбҹ’бһӮбһ¶бһӣбҹӢ OAuth бһҠбҹӮбһӣбһ”бһ¶бһ“бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP'
    'help:бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp commands' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[бһ”бһҫбһҖбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҡбһ”бҹҖбһ”бһ”бҹҶбһ”бһ¶бһҸбҹӢбһҖбҹҶбһ бһ»бһҹ]' \
            '--verbose[бһ”бһҠбһ·бһҹбҹҒбһ’бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ”бҹҖбһ”бһӣбһҳбҹ’бһўбһ·бһҸбһ–бһёбһҜбһҖбһҹбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’]' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[бһ”бҹ’бһҡбһ—бҹҒбһ‘бһҖбһ¶бһҡбһҠбһ№бһҖбһҮбһүбҹ’бһҮбһјбһ“ (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[бһҖбҹҶбһҺбһҸбҹӢбһўбһҗбҹҒбһҡбһ”бһҡбһ·бһҹбҹ’бһҗбһ¶бһ“ (бһ§. -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[бһҖбҹҶбһҺбһҸбҹӢбһ”бһӢбһҳбһҖбһҗбһ¶ WebSocket]:header:' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ (local, user, project) - бһӣбһ»бһ”бһ–бһёбһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҠбҹӮбһӣбһҳбһ¶бһ“бһҹбҹ’бһҡбһ¶бһ”бҹӢ бһ”бҹ’бһҡбһҹбһ·бһ“бһ”бһҫбһҳбһ·бһ“бһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһ¶бһҖбҹӢ]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:бһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷ бһ¬бһ”бһүбҹ’бһҮбһёбһҹбҹҒбһ…бһҖбҹ’бһҸбһёбһӣбһҳбҹ’бһўбһ·бһҸбһ‘бһёбһ•бҹ’бһҹбһ¶бһҡ'
    'marketplace:бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһ‘бһёбһ•бҹ’бһҹбһ¶бһҡ Claude Code'
    'list:бһҡбһ¶бһҷбһ”бһүбҹ’бһҮбһёбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһҠбҹӮбһӣбһ”бһ¶бһ“бһҠбҹҶбһЎбһҫбһ„'
    'details:бһ”бһ„бҹ’бһ бһ¶бһүбһ”бһүбҹ’бһҮбһёбһҹбһҳбһ¶бһҹбһ—бһ¶бһӮ бһ“бһ·бһ„бһҸбһҳбҹ’бһӣбҹғбһҗбһјбһҒбһ№бһ“бһ”бҹүбһ¶бһ“бҹӢбһҹбҹ’бһҳбһ¶бһ“бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷ'
    'install:бһҠбҹҶбһЎбһҫбһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһ–бһёбһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһҠбҹӮбһӣбһҳбһ¶бһ“'
    'i:бһҠбҹҶбһЎбһҫбһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһ–бһёбһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһҠбҹӮбһӣбһҳбһ¶бһ“ (бһ‘бһҳбҹ’бһҡбһ„бҹӢбһҒбҹ’бһӣбһёбһ“бҹғ install)'
    'init:бһ”бһ„бҹ’бһҖбһҫбһҸбһӮбҹ’бһҡбҹ„бһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһҗбҹ’бһҳбһё (бһ•бҹ’бһ‘бһ»бһҖбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһңбһӮбҹ’бһӮбһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢ)'
    'uninstall:бһӣбһ»бһ”бһҖбһ¶бһҡбһҠбҹҶбһЎбһҫбһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһҠбҹӮбһӣбһ”бһ¶бһ“бһҠбҹҶбһЎбһҫбһ„'
    'remove:бһӣбһ»бһ”бһҖбһ¶бһҡбһҠбҹҶбһЎбһҫбһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһҠбҹӮбһӣбһ”бһ¶бһ“бһҠбҹҶбһЎбһҫбһ„ (бһҲбҹ’бһҳбҹ„бҹҮбһ•бҹ’бһҹбҹҒбһ„бһ“бҹғ uninstall)'
    'enable:бһ”бһҫбһҖбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһ·бһ‘'
    'disable:бһ”бһ·бһ‘бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһҫбһҖ'
    'update:бһ’бҹ’бһңбһҫбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“бһ—бһ¶бһ–бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһ‘бҹ…бһҖбҹҶбһҺбҹӮбһҗбҹ’бһҳбһёбһ”бҹҶбһ•бһ»бһҸ'
    'eval:бһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡбһҖбһҡбһҺбһё eval бһ”бҹ’бһҡбһҶбһ¶бҹҶбһ„бһ“бһ№бһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷ бһ бһҫбһҷбһҡбһ¶бһҷбһҖбһ¶бһҡбһҺбҹҚбһӣбһ‘бҹ’бһ’бһ•бһӣбһҠбҹӮбһӣбһ”бһ¶бһ“бһҠбһ¶бһҖбҹӢбһ–бһ·бһ“бҹ’бһ‘бһ»'
    'prune:бһӣбһ»бһ”бһ—бһ¶бһ–бһўбһ¶бһҹбҹ’бһҡбҹҗбһҷбһҠбҹӮбһӣбһ”бһ¶бһ“бһҠбҹҶбһЎбһҫбһ„бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҠбҹӮбһӣбһӣбҹӮбһ„бһҸбҹ’бһҡбһјбһңбһҖбһ¶бһҡ'
    'tag:бһ”бһ„бҹ’бһҖбһҫбһҸ git tag {name}--v{version} бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһ…бҹҒбһүбһ•бҹ’бһҹбһ¶бһҷбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷ'
    'help:бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin commands' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҠбҹҶбһЎбһҫбһ„]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҠбҹҶбһЎбһҫбһ„]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҠбҹҶбһЎбһҫбһ„]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[бһңбһ·бһҹбһ¶бһӣбһ—бһ¶бһ–бһҖбһ¶бһҡбһҠбҹҶбһЎбһҫбһ„]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:бһ”бһ“бҹ’бһҗбҹӮбһҳбһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһ–бһё URL, бһ•бҹ’бһӣбһјбһң бһ¬бһғбҹ’бһӣбһ¶бҹҶбһ„ GitHub'
    'list:бһҡбһ¶бһҷбһ”бһүбҹ’бһҮбһёбһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһҠбҹӮбһӣбһ”бһ¶бһ“бһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’'
    'remove:бһӣбһ»бһ”бһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһҠбҹӮбһӣбһ”бһ¶бһ“бһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’'
    'rm:бһӣбһ»бһ”бһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһҠбҹӮбһӣбһ”бһ¶бһ“бһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ (бһҲбҹ’бһҳбҹ„бҹҮбһ•бҹ’бһҹбҹҒбһ„бһ“бҹғ remove)'
    'update:бһ’бҹ’бһңбһҫбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“бһ—бһ¶бһ–бһ‘бһёбһ•бҹ’бһҹбһ¶бһҡбһ–бһёбһ”бҹ’бһҡбһ—бһ– - бһ’бҹ’бһңбһҫбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“бһ—бһ¶бһ–бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ бһ”бҹ’бһҡбһҹбһ·бһ“бһ”бһҫбһҳбһ·бһ“бһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһ¶бһҖбҹӢбһҲбҹ’бһҳбҹ„бҹҮ'
    'help:бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace commands' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[бһ”бһ„бҹ’бһҒбҹҶбһұбҹ’бһҷбһҠбҹҶбһЎбһҫбһ„ бһ‘бҹ„бҹҮбһ”бһёбһҮбһ¶бһ”бһ¶бһ“бһҠбҹҶбһЎбһҫбһ„бһҡбһҪбһ…бһ бһҫбһҷбһҖбҹҸбһҠбҹ„бһҷ]' \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[бһҗбһҸбһ”бһ“бҹ’бһҗбҹӮбһҳбһҠбһҫбһҳбҹ’бһ”бһёбһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸбһұбҹ’бһҷбһ§бһ”бһҖбһҡбһҺбҹҚбһ…бһјбһӣбһ”бҹ’бһҡбһҫбһҖбҹ’бһ“бһ»бһ„бһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“]:directory:_directories' \
    '--agent[бһ—бҹ’бһ“бһ¶бһҖбҹӢбһ„бһ¶бһҡбһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“бһ–бһёбһ‘бһ·бһҠбҹ’бһӢбһ—бһ¶бһ–бһ—бҹ’бһ“бһ¶бһҖбҹӢбһ„бһ¶бһҡ]:agent:' \
    '--all[бһҮбһ¶бһҳбһҪбһҷ --jsonбҹ– бһҡбһҪбһҳбһ”бһүбҹ’бһ…бһјбһӣбһ•бһ„бһҠбҹӮбһҡбһ“бһјбһңбһңбһӮбҹ’бһӮбһ•бҹ’бһ‘бҹғбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҷбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһ…бһ”бҹӢ]' \
    '--allow-dangerously-skip-permissions[бһ’бҹ’бһңбһҫбһұбҹ’бһҷбһҡбһ”бҹҖбһ”бһҡбҹҶбһӣбһ„бһҹбһ·бһ‘бҹ’бһ’бһ·бһўбһ¶бһ…бһ”бҹ’бһҡбһҫбһ”бһ¶бһ“бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“]' \
    '--cwd[бһ”бһ„бҹ’бһ бһ¶бһүбһҸбҹӮбһңбһӮбҹ’бһӮбһ•бҹ’бһ‘бҹғбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҷбһҠбҹӮбһӣбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳбһҖбҹ’бһҡбҹ„бһҳбһ•бҹ’бһӣбһјбһң]:path:_directories' \
    '--dangerously-skip-permissions[бһҲбҹ’бһҳбҹ„бҹҮбһ•бҹ’бһҹбҹҒбһ„бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢ --permission-mode bypassPermissions]' \
    '--effort[бһҖбһҳбҹ’бһҡбһ·бһҸбһҖбһ¶бһҡбһҒбһ·бһҸбһҒбҹҶбһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“]:level:(low medium high xhigh max)' \
    '--json[бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһңбһӮбҹ’бһӮбһҹбһҖбһҳбҹ’бһҳбһҮбһ¶ JSON array бһ бһҫбһҷбһ…бҹҒбһү]' \
    '*--mcp-config[бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһҠбһҫбһҳбҹ’бһ”бһёбһўбһ“бһ»бһңбһҸбҹ’бһҸбһ…бҹҶбһ–бҹ„бҹҮбһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“]:config:' \
    '--model[бһӮбҹҶбһҡбһјбһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“бһ–бһёбһ‘бһ·бһҠбҹ’бһӢбһ—бһ¶бһ–бһ—бҹ’бһ“бһ¶бһҖбҹӢбһ„бһ¶бһҡ]:model:' \
    '--permission-mode[бһҡбһ”бҹҖбһ”бһҹбһ·бһ‘бҹ’бһ’бһ·бһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[бһ•бҹ’бһ‘бһ»бһҖбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҮбҹҶбһ“бһҪбһҷбһ–бһёбһҗбһҸбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ‘бһ·бһҠбҹ’бһӢбһ—бһ¶бһ–бһ—бҹ’бһ“бһ¶бһҖбҹӢбһ„бһ¶бһҡ бһ“бһ·бһ„бһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“]:path:_directories' \
    '--setting-sources[бһ”бһүбҹ’бһҮбһёбһ”бҹ’бһҡбһ—бһ–бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҠбһҫбһҳбҹ’бһ”бһёбһ•бҹ’бһ‘бһ»бһҖ (бһ•бҹ’бһҸбһ¶бһ…бҹӢбһҠбҹ„бһҷбһҹбһүбҹ’бһүбһ¶бһҖбҹ’бһ”бҹҖбһҹбҹ– user, project, local)]:sources:' \
    '--settings[бһҜбһҖбһҹбһ¶бһҡбһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢ бһ¬бһҒбҹ’бһҹбҹӮбһўбһҖбҹ’бһҹбһҡ JSON бһҠбһҫбһҳбҹ’бһ”бһёбһўбһ“бһ»бһңбһҸбҹ’бһҸ]:file-or-json:_files' \
    '--strict-mcp-config[бһ”бҹ’бһҡбһҫбһҸбҹӮбһҳбҹүбһ¶бһҹбҹҠбһёбһ“бһҳбҹҒ MCP бһ–бһё --mcp-config бһҖбҹ’бһ“бһ»бһ„бһңбһӮбҹ’бһӮбһҠбҹӮбһӣбһ”бһ¶бһ“бһ”бһүбҹ’бһҮбһјбһ“]' \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:бһ…бһјбһӣбһ‘бҹ…бһӮбһҺбһ“бһё Anthropic бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ'
    'logout:бһ…бҹҒбһүбһ–бһёбһӮбһҺбһ“бһё Anthropic бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ'
    'status:бһ”бһ„бҹ’бһ бһ¶бһүбһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ–бһҖбһ¶бһҡбһ•бҹ’бһ‘бҹҖбһ„бһ•бҹ’бһ‘бһ¶бһҸбҹӢ'
    'help:бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth commands' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]'
          ;;
      esac
      ;;
  esac
}

_claude_auto_mode() {
  local -a auto_mode_commands
  auto_mode_commands=(
    'config:бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҡбһ”бҹҖбһ”бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҠбҹӮбһӣбһҳбһ¶бһ“бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ—бһ¶бһ–бһҮбһ¶ JSON'
    'critique:бһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһҳбһҸбһ·бһҖбҹӮбһӣбһҳбҹ’бһў AI бһӣбһҫбһ…бҹ’бһ”бһ¶бһ”бҹӢбһҡбһ”бҹҖбһ”бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһ•бҹ’бһ‘бһ¶бһӣбҹӢбһҒбҹ’бһӣбһҪбһ“бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ'
    'defaults:бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ–бһ…бҹ’бһ”бһ¶бһ”бҹӢбһҡбһ”бҹҖбһ”бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбһҮбһ¶ JSON'
    'reset:бһҖбҹҶбһҺбһҸбҹӢбһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’бһҡбһ”бҹҖбһ”бһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһЎбһҫбһ„бһңбһ·бһүбһ‘бҹ…бһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳбһҠбҹӮбһӣбһ”бһ¶бһ“бһ•бҹ’бһҸбһӣбҹӢбһҳбһҖ'
    'help:бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode commands' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[бһ•бҹ’бһӣбһјбһңбһ‘бҹ…бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’ YAML gateway]:path:_files' \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:бһӣбһ»бһ”бһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ– Claude Code бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһӮбһҳбҹ’бһҡбҹ„бһ„ (бһ”бҹ’бһҡбһҸбһ·бһ…бһ¶бһҡбһ·бһҖ, бһҖбһ·бһ…бҹ’бһ…бһҖбһ¶бһҡ, бһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҜбһҖбһҹбһ¶бһҡ, бһ’бһ¶бһҸбһ»бһҖбҹҶбһҺбһҸбҹӢбһҡбһ…бһ“бһ¶бһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’)'
    'help:бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷ'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[бһ”бҹ„бҹҮбһ–бһ»бһҳбҹ’бһ– payload bugs.json бһҠбһҫбһҳбһҮбҹҶбһ“бһҪбһҹбһұбҹ’бһҷбһҖбһ¶бһҡбһҡбһҖбһғбһҫбһүбһҠбҹӮбһӣбһ”бһ¶бһ“бһ’бҹ’бһңбһҫбһ‘бҹ’бһҡбһ„бҹӢбһ‘бҹ’бһҡбһ¶бһҷ]' \
    '--timeout[бһ“бһ¶бһ‘бһёбһўбһҸбһ·бһ”бһҡбһҳбһ¶бһҠбһҫбһҳбҹ’бһ”бһёбһҡбһ„бҹӢбһ…бһ¶бҹҶбһҖбһ¶бһҡбһҸбҹ’бһҡбһҪбһҸбһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһ”бһүбҹ’бһ…бһ”бҹӢ]:minutes:' \
    '(-h --help)'{-h,--help}'[бһ”бһ„бҹ’бһ бһ¶бһүбһҮбҹҶбһ“бһҪбһҷбһ–бһ¶бһҖбҹ’бһҷбһ”бһүбҹ’бһҮбһ¶]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
