  local -a project_commands
  project_commands=(
    'purge:Eliminar todo o estado de Claude Code dun proxecto (transcricións, tarefas, historial de ficheiros, entrada de configuración)'
    'help:Mostrar axuda'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mostrar axuda para o comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandos project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Mostrar axuda para o comando]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Imprimir a carga bruta bugs.json no lugar dos resultados formatados]' \
    '--timeout[Minutos máximos a esperar a que remate a revisión]:minutes:' \
    '(-h --help)'{-h,--help}'[Mostrar axuda para o comando]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
