  local -a auto_mode_commands
  auto_mode_commands=(
    'config:Imprimir a configuración efectiva do modo automático como JSON'
    'critique:Obter comentarios da IA sobre as túas regras personalizadas do modo automático'
    'defaults:Imprimir as regras predeterminadas do modo automático como JSON'
    'reset:Restablecer a configuración do modo automático aos valores predeterminados de fábrica'
    'help:Mostrar axuda'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mostrar axuda para o comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandos auto-mode' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Mostrar axuda para o comando]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Ruta ao ficheiro de configuración YAML da pasarela]:path:_files' \
    '(-h --help)'{-h,--help}'[Mostrar axuda para o comando]'
}

