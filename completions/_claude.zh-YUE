#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:設定同管理 MCP 伺服器'
    'plugin:管理 Claude Code 插件'
    'agents:管理背景代理'
    'auth:管理認證'
    'auto-mode:檢查或重設自動模式分類器設定'
    'gateway:執行企業認證/遙測閘道'
    'project:管理 Claude Code 專案狀態'
    'ultrareview:執行雲端託管嘅多代理程式碼審查並列印結果'
    'setup-token:設定長期認證令牌（需要 Claude 訂閱）'
    'doctor:Claude Code 自動更新程式嘅健康檢查'
    'update:檢查同安裝更新'
    'install:安裝 Claude Code 原生建構版本'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[啟用除錯模式，可選類別篩選（例如 "api,hooks" 或 "!statsig,!file"）]:filter:'
    '--verbose[覆寫設定檔入面嘅詳細模式設定]'
    '(-p --print)'{-p,--print}'[輸出回應然後結束（用於管道）。注意：淨係喺受信任嘅目錄入面用]'
    '--output-format[輸出格式（配合 --print）："text"（預設）、"json"（單一結果）或 "stream-json"（即時串流）]:format:(text json stream-json)'
    '--json-schema[用於結構化輸出驗證嘅 JSON 結構描述]:schema:'
    '--include-partial-messages[包含部分訊息區塊（配合 --print 同 --output-format=stream-json）]'
    '--input-format[輸入格式（配合 --print）："text"（預設）或 "stream-json"（即時串流輸入）]:format:(text stream-json)'
    '--mcp-debug[\[已棄用。請改用 --debug\] 啟用 MCP 除錯模式（顯示 MCP 伺服器錯誤）]'
    '--dangerously-skip-permissions[略過所有權限檢查。只建議喺冇網絡存取嘅沙箱入面用]'
    '--allow-dangerously-skip-permissions[啟用略過權限檢查嘅選項，但唔會預設啟用]'
    '--max-budget-usd[花喺 API 呼叫上嘅美元金額上限（僅限 --print）]:amount:'
    '--replay-user-messages[喺 stdout 重新發送由 stdin 嚟嘅用戶訊息以便確認]'
    '--allowed-tools[以逗號或空格分隔嘅允許工具名稱列表（例如 "Bash(git:*) Edit"）]:tools:'
    '--allowedTools[以逗號或空格分隔嘅允許工具名稱列表（駝峰式格式）]:tools:'
    '--tools[指定由內建集合入面可用嘅工具列表。僅限輸出模式]:tools:'
    '--disallowed-tools[以逗號或空格分隔嘅禁用工具名稱列表（例如 "Bash(git:*) Edit"）]:tools:'
    '--disallowedTools[以逗號或空格分隔嘅禁用工具名稱列表（駝峰式格式）]:tools:'
    '--mcp-config[由 JSON 檔案或字串載入 MCP 伺服器（以空格分隔）]:configs:'
    '--system-prompt[會話使用嘅系統提示]:prompt:'
    '--append-system-prompt[將系統提示附加到預設系統提示]:prompt:'
    '--permission-mode[會話使用嘅權限模式]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[繼續最近嘅對話]'
    '(-r --resume)'{-r,--resume}'[恢復對話 - 指定會話 ID 或互動式選擇]:sessionId:_claude_sessions'
    '--fork-session[喺恢復時建立新嘅會話 ID，而唔係重用原有會話 ID（配合 --resume 或 --continue）]'
    '--no-session-persistence[停用會話持續性 - 會話唔會儲存（僅限 --print）]'
    '--model[目前會話嘅模型。指定最新模型嘅別名（例如 '\''sonnet'\'' 或 '\''opus'\''）]:model:'
    '--agent[目前會話嘅代理。覆寫 '\''agent'\'' 設定]:agent:'
    '--betas[要包含喺 API 要求入面嘅 Beta 標頭（僅限 API 金鑰用戶）]:betas:'
    '--fallback-model[當預設模型負載過重時自動後備到指定模型（僅限 --print）]:model:'
    '--settings[設定 JSON 檔案路徑或 JSON 字串以載入額外設定]:file-or-json:_files'
    '--add-dir[允許工具存取嘅額外目錄]:directories:_directories'
    '--ide[如果啱啱有一個有效嘅 IDE，喺啟動時自動連接到 IDE]'
    '--strict-mcp-config[只使用 --mcp-config 入面嘅 MCP 伺服器，忽略所有其他 MCP 設定]'
    '--session-id[用於對話嘅特定會話 ID（必須係有效嘅 UUID）]:uuid:'
    '--agents[定義自訂代理嘅 JSON 物件]:json:'
    '--setting-sources[以逗號分隔嘅要載入嘅設定來源列表（user、project、local）]:sources:'
    '--plugin-dir[只為呢個會話載入插件嘅目錄（可重複）]:paths:_directories'
    '--disable-slash-commands[停用所有斜線命令]'
    '(--bg --background)'{--bg,--background}'[以背景代理啟動會話並即時返回]'
    '(-w --worktree)'{-w,--worktree}'[為呢個會話建立新嘅 git worktree（可選擇指定名稱）]::name:'
    '--tmux[為 worktree 建立 tmux 會話（需要 --worktree）]'
    '(-n --name)'{-n,--name}'[為呢個會話設定顯示名稱]:name:'
    '--effort[目前會話嘅努力程度]:level:(low medium high xhigh max)'
    '--debug-file[將除錯記錄寫入特定檔案路徑（隱含啟用除錯模式）]:path:_files'
    '--from-pr[恢復依編號/URL 連結到 PR 嘅會話，或開啟互動式選擇器]::value:'
    '--remote-control[啟動已啟用遠端控制嘅互動式會話（可選擇命名）]::name:'
    '--remote-control-session-name-prefix[自動產生嘅遠端控制會話名稱嘅前綴]:prefix:'
    '--chrome[啟用 Claude in Chrome 整合]'
    '--no-chrome[停用 Claude in Chrome 整合]'
    '--plugin-url[只為呢個會話由 URL 擷取插件 .zip（可重複）]:url:'
    '--file[啟動時要下載嘅檔案資源（格式：file_id:relative_path）]:specs:'
    '--prompt-suggestions[啟用提示建議（喺列印/SDK 模式下發出預測嘅下一個提示）]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[將子代理文字同思考區塊轉發做訊息（配合 --print 同 stream-json）]'
    '--include-hook-events[喺輸出串流入面包含所有 hook 生命週期事件（配合 stream-json）]'
    '--exclude-dynamic-system-prompt-sections[將每台機器嘅區段移到第一個用戶訊息以改善提示快取重用]'
    '--brief[啟用 SendUserMessage 工具以進行代理對用戶嘅通訊]'
    '--safe-mode[停用所有自訂項目嚟啟動（適合排解損壞嘅設定）]'
    '--bare[最小模式：略過 hooks、LSP、插件同步、屬性標示、自動記憶同 CLAUDE.md 自動探索]'
    '--ax-screen-reader[呈現螢幕助讀程式友善嘅輸出（純文字，冇裝飾性邊框或動畫）]'
    '(-v --version)'{-v,--version}'[輸出版本號]'
    '(-h --help)'{-h,--help}'[顯示命令說明]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude commands' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "冇引數"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:啟動 Claude Code MCP 伺服器'
    'add:將 MCP 伺服器添加到 Claude Code'
    'remove:移除 MCP 伺服器'
    'list:列出已設定嘅 MCP 伺服器'
    'get:攞 MCP 伺服器詳情'
    'add-json:使用 JSON 字串添加 MCP 伺服器（stdio 或 SSE）'
    'add-from-claude-desktop:由 Claude Desktop 匯入 MCP 伺服器（只限 Mac 同 WSL）'
    'reset-project-choices:重設呢個專案入面所有已批准/已拒絕嘅專案範圍（.mcp.json）伺服器'
    'login:向 MCP 伺服器認證（HTTP、SSE 或 claude.ai 連接器）'
    'logout:清除 MCP 伺服器已儲存嘅 OAuth 認證'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp commands' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[啟用除錯模式]' \
            '--verbose[覆寫設定檔入面嘅詳細模式設定]' \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project）]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[傳輸類型（stdio、sse、http）]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[設定環境變數（例如 -e KEY=value）]:env:' \
            '(-H --header)'{-H,--header}'[設定 WebSocket 標頭]:header:' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project） - 若冇指定就由現有範圍移除]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project）]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[設定範圍（local、user、project）]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:驗證插件或市集清單'
    'marketplace:管理 Claude Code 市集'
    'list:列出已安裝嘅插件'
    'details:顯示插件嘅元件清單同預估令牌成本'
    'install:由可用市集安裝插件'
    'i:由可用市集安裝插件（install 嘅簡寫）'
    'init:建立新插件嘅骨架（下次會話自動載入）'
    'uninstall:解除安裝已安裝嘅插件'
    'remove:解除安裝已安裝嘅插件（uninstall 嘅別名）'
    'enable:啟用已停用嘅插件'
    'disable:停用已啟用嘅插件'
    'update:將插件更新到最新版本'
    'eval:對插件執行評估案例並回報評分結果'
    'prune:移除唔再需要嘅自動安裝相依項目'
    'tag:為插件版本建立 {name}--v{version} git 標籤'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin commands' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[安裝範圍]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:由 URL、路徑或 GitHub 儲存庫添加市集'
    'list:列出已設定嘅市集'
    'remove:移除已設定嘅市集'
    'rm:移除已設定嘅市集（remove 嘅別名）'
    'update:由來源更新市集 - 如冇指定名稱就更新全部'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace commands' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示說明]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[就算已經安裝咗都強制安裝]' \
    '(-h --help)'{-h,--help}'[顯示說明]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[喺派發嘅會話中允許工具存取嘅額外目錄]:directory:_directories' \
    '--agent[由代理檢視派發嘅會話嘅預設代理]:agent:' \
    '--all[配合 --json：同時包含已完成嘅背景會話]' \
    '--allow-dangerously-skip-permissions[令派發嘅會話可以使用略過權限模式]' \
    '--cwd[只顯示喺路徑下啟動嘅背景會話]:path:_directories' \
    '--dangerously-skip-permissions[--permission-mode bypassPermissions 嘅別名]' \
    '--effort[派發嘅會話嘅預設努力程度]:level:(low medium high xhigh max)' \
    '--json[將作用中會話列印為 JSON 陣列並結束]' \
    '*--mcp-config[要套用到派發嘅會話嘅 MCP 伺服器設定]:config:' \
    '--model[由代理檢視派發嘅會話嘅預設模型]:model:' \
    '--permission-mode[派發嘅會話嘅預設權限模式]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[為代理檢視同派發嘅會話由目錄載入插件]:path:_directories' \
    '--setting-sources[以逗號分隔嘅要載入嘅設定來源列表（user、project、local）]:sources:' \
    '--settings[要套用嘅設定檔或 JSON 字串]:file-or-json:_files' \
    '--strict-mcp-config[喺派發嘅會話中只使用 --mcp-config 入面嘅 MCP 伺服器]' \
    '(-h --help)'{-h,--help}'[顯示命令說明]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:登入你嘅 Anthropic 帳戶'
    'logout:登出你嘅 Anthropic 帳戶'
    'status:顯示認證狀態'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth commands' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示命令說明]'
          ;;
      esac
      ;;
  esac
}

_claude_auto_mode() {
  local -a auto_mode_commands
  auto_mode_commands=(
    'config:將有效嘅自動模式設定列印為 JSON'
    'critique:攞 AI 對你嘅自訂自動模式規則嘅回饋'
    'defaults:將預設嘅自動模式規則列印為 JSON'
    'reset:將自動模式設定重設為出廠預設值'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode commands' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示命令說明]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[閘道 YAML 設定嘅路徑]:path:_files' \
    '(-h --help)'{-h,--help}'[顯示命令說明]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:刪除專案嘅所有 Claude Code 狀態（對話記錄、工作、檔案歷史記錄、設定項目）'
    'help:顯示說明'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[顯示命令說明]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[列印原始 bugs.json 承載而非格式化嘅結果]' \
    '--timeout[等待審查完成嘅最長分鐘數]:minutes:' \
    '(-h --help)'{-h,--help}'[顯示命令說明]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
