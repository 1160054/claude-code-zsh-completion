_claude_ultrareview() {
  _arguments \
    '--json[Cetak payload bugs.json mentah alih-alih temuan yang diformat]' \
    '--timeout[Menit maksimum untuk menunggu tinjauan selesai]:minutes:' \
    '(-h --help)'{-h,--help}'[Tampilkan bantuan untuk perintah]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
