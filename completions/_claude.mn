#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:MCP серверүүдийг тохируулах ба удирдах'
    'plugin:Claude Code нэмэлт програмуудыг удирдах'
    'agents:Фон дахь агентуудыг удирдах'
    'auth:Баталгаажуулалтыг удирдах'
    'auto-mode:Авто горимын ангилагчийн тохиргоог шалгах эсвэл дахин тохируулах'
    'gateway:Байгууллагын баталгаажуулалт/телеметрийн gateway ажиллуулах'
    'project:Claude Code төслийн төлөвийг удирдах'
    'ultrareview:Үүлэн дэх олон агентын кодын хяналт ажиллуулж, үр дүнг хэвлэх'
    'setup-token:Урт хугацааны баталгаажуулалтын токен тохируулах (Claude захиалга шаардлагатай)'
    'doctor:Claude Code автомат шинэчлэлийн эрүүл мэндийн шалгалт'
    'update:Шинэчлэлтийг шалгах ба суулгах'
    'install:Claude Code төрөлх бүтээгдэхүүнийг суулгах'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Дебаг горимыг идэвхжүүлэх, сонголттой ангилал шүүлтүүр (жишээ нь "api,hooks" эсвэл "!statsig,!file")]:filter:'
    '--verbose[Тохиргооны файлын нарийвчилсан горимын тохиргоог дарж бичих]'
    '(-p --print)'{-p,--print}'[Хариуг хэвлээд гарах (хоолойнд ашиглах). Анхаар: зөвхөн итгэмжлэгдсэн лавлахад ашиглана уу]'
    '--output-format[Гаралтын формат (--print-тэй хамт): "text" (үндсэн), "json" (нэг үр дүн) эсвэл "stream-json" (бодит цаг хугацааны урсгал)]:format:(text json stream-json)'
    '--json-schema[Бүтэцлэгдсэн гаралтын баталгаажуулалтын JSON схем]:schema:'
    '--include-partial-messages[Хэсэгчилсэн мессежийн хэсгүүдийг оруулах (--print болон --output-format=stream-json-тэй хамт)]'
    '--input-format[Оролтын формат (--print-тэй хамт): "text" (үндсэн) эсвэл "stream-json" (бодит цаг хугацааны урсгалын оролт)]:format:(text stream-json)'
    '--mcp-debug[\[Хуучирсан. --debug ашиглана уу\] MCP дебаг горимыг идэвхжүүлэх (MCP серверийн алдаануудыг харуулах)]'
    '--dangerously-skip-permissions[Бүх зөвшөөрлийн шалгалтыг алгасах. Зөвхөн интернет нэвтрэх эрхгүй sandbox-д зориулагдсан]'
    '--allow-dangerously-skip-permissions[Зөвшөөрлийн шалгалтыг алгасах сонголтыг идэвхжүүлэх, гэхдээ үндсэн утга биш]'
    '--max-budget-usd[API дуудлагад зарцуулах дээд доллар (зөвхөн --print)]:amount:'
    '--replay-user-messages[Баталгаажуулалтын тулд stdin-ээс хэрэглэгчийн мессежүүдийг stdout-д дахин илгээх]'
    '--allowed-tools[Зөвшөөрөгдсөн багажийн нэрийн жагсаалт (таслал эсвэл зайгаар тусгаарлагдсан, жишээ нь "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Зөвшөөрөгдсөн багажийн нэрийн жагсаалт (camelCase формат)]:tools:'
    '--tools[Өгөгдмөл багцаас боломжтой багажуудын жагсаалтыг зааж өгөх. Зөвхөн хэвлэх горим]:tools:'
    '--disallowed-tools[Хориглосон багажийн нэрийн жагсаалт (таслал эсвэл зайгаар тусгаарлагдсан, жишээ нь "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Хориглосон багажийн нэрийн жагсаалт (camelCase формат)]:tools:'
    '--mcp-config[MCP серверүүдийг JSON файл эсвэл мөрөөс ачаалах (зайгаар тусгаарлагдсан)]:configs:'
    '--system-prompt[Сессид ашиглах системийн дохио]:prompt:'
    '--append-system-prompt[Системийн дохиог үндсэн системийн дохионд нэмэх]:prompt:'
    '--permission-mode[Сессид ашиглах зөвшөөрлийн горим]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Хамгийн сүүлийн ярианы үргэлжлүүлэх]'
    '(-r --resume)'{-r,--resume}'[Ярианы үргэлжлүүлэх - сессийн ID заах эсвэл интерактив сонгох]:sessionId:_claude_sessions'
    '--fork-session[Үргэлжлүүлэхэд анхны сессийн ID дахин ашиглахын оронд шинэ сессийн ID үүсгэх (--resume эсвэл --continue-тэй хамт)]'
    '--no-session-persistence[Сессийн хадгалалтыг идэвхгүй болгох - сессүүд хадгалагдахгүй (зөвхөн --print)]'
    '--model[Одоогийн сессийн загвар. Хамгийн сүүлийн загварын нэрийг зааж өгөх (жишээ нь '\''sonnet'\'' эсвэл '\''opus'\'')]:model:'
    '--agent[Одоогийн сессийн агент. '\''agent'\'' тохиргоог дарж бичнэ]:agent:'
    '--betas[API хүсэлтэд оруулах бета толгойнууд (зөвхөн API түлхүүр хэрэглэгчид)]:betas:'
    '--fallback-model[Үндсэн загвар ачаалалтай үед заасан загвар руу автоматаар буцах (зөвхөн --print)]:model:'
    '--settings[Нэмэлт тохиргоо ачаалах JSON файлын зам эсвэл JSON мөр]:file-or-json:_files'
    '--add-dir[Багажийн хандалтыг зөвшөөрөх нэмэлт лавлахууд]:directories:_directories'
    '--ide[Эхлэхэд зөвхөн нэг хүчинтэй IDE байвал автоматаар IDE-д холбогдох]'
    '--strict-mcp-config[Зөвхөн --mcp-config дотор байгаа MCP серверүүдийг ашиглаж, бусад бүх MCP тохиргоог үл хэрэгсэх]'
    '--session-id[Ярианд ашиглах тодорхой сессийн ID (хүчинтэй UUID байх ёстой)]:uuid:'
    '--agents[Өөрчилсөн агентуудыг тодорхойлох JSON объект]:json:'
    '--setting-sources[Ачаалах тохиргооны эх үүсвэрийн жагсаалт (таслалаар тусгаарлагдсан: user, project, local)]:sources:'
    '--plugin-dir[Зөвхөн энэ сессид нэмэлт програм ачаалах лавлах (давтагдах боломжтой)]:paths:_directories'
    '--disable-slash-commands[Бүх слаш командыг идэвхгүй болгох]'
    '(--bg --background)'{--bg,--background}'[Сессийг фон агент болгон эхлүүлж, шууд буцах]'
    '(-w --worktree)'{-w,--worktree}'[Энэ сессид зориулж шинэ git worktree үүсгэх (сонголтоор нэр зааж болно)]::name:'
    '--tmux[worktree-д зориулж tmux сесс үүсгэх (--worktree шаардлагатай)]'
    '(-n --name)'{-n,--name}'[Энэ сессид харагдах нэр тохируулах]:name:'
    '--effort[Одоогийн сессийн хүчин чармайлтын түвшин]:level:(low medium high xhigh max)'
    '--debug-file[Дебаг лог-ыг тодорхой файлын замд бичих (дебаг горимыг далд идэвхжүүлнэ)]:path:_files'
    '--from-pr[Дугаар/URL-ээр PR-тэй холбогдсон сессийг үргэлжлүүлэх, эсвэл интерактив сонгогч нээх]::value:'
    '--remote-control[Remote Control идэвхжүүлсэн интерактив сесс эхлүүлэх (сонголтоор нэрлэж болно)]::name:'
    '--remote-control-session-name-prefix[Автоматаар үүсгэсэн Remote Control сессийн нэрийн угтвар]:prefix:'
    '--chrome[Chrome дахь Claude интеграцийг идэвхжүүлэх]'
    '--no-chrome[Chrome дахь Claude интеграцийг идэвхгүй болгох]'
    '--plugin-url[Зөвхөн энэ сессид URL-ээс нэмэлт програмын .zip татах (давтагдах боломжтой)]:url:'
    '--file[Эхлэхэд татах файлын нөөцүүд (формат: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Дохионы саналуудыг идэвхжүүлэх (print/SDK горимд дараагийн таамагласан дохиог гаргана)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Дэд агентын текст ба сэтгэлгээний блокуудыг мессеж болгон дамжуулах (--print болон stream-json-тэй хамт)]'
    '--include-hook-events[Гаралтын урсгалд бүх hook-ийн амьдралын мөчлөгийн үйл явдлуудыг оруулах (stream-json-тэй хамт)]'
    '--exclude-dynamic-system-prompt-sections[Машин тус бүрийн хэсгүүдийг эхний хэрэглэгчийн мессеж рүү зөөж, дохионы кэшийн дахин ашиглалтыг сайжруулах]'
    '--brief[Агентаас хэрэглэгч рүү харилцах SendUserMessage багажийг идэвхжүүлэх]'
    '--safe-mode[Бүх өөрчлөлтийг идэвхгүй болгож эхлүүлэх (эвдэрсэн тохиргоог засахад тустай)]'
    '--bare[Хамгийн бага горим: hook, LSP, нэмэлт програмын синк, атрибуци, авто-санах ой, CLAUDE.md автомат илрүүлэлтийг алгасах]'
    '--ax-screen-reader[Дэлгэц уншигчид ээлтэй гаралт гаргах (хавтгай текст, чимэглэлийн хүрээ эсвэл анимацгүй)]'
    '(-v --version)'{-v,--version}'[Хувилбарын дугаарыг гаргах]'
    '(-h --help)'{-h,--help}'[Командын тусламжийг харуулах]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude commands' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "аргумент байхгүй"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Claude Code MCP серверийг эхлүүлэх'
    'add:MCP серверийг Claude Code-д нэмэх'
    'remove:MCP серверийг устгах'
    'list:Тохируулагдсан MCP серверүүдийг жагсаах'
    'get:MCP серверийн дэлгэрэнгүй мэдээллийг авах'
    'add-json:JSON мөрөөр MCP сервер нэмэх (stdio эсвэл SSE)'
    'add-from-claude-desktop:Claude Desktop-оос MCP серверүүдийг импортлох (зөвхөн Mac ба WSL)'
    'reset-project-choices:Энэ төсөлд баталсан/татгалзсан төслийн хүрээтэй (.mcp.json) бүх серверүүдийг дахин тохируулах'
    'login:MCP серверт баталгаажих (HTTP, SSE эсвэл claude.ai коннектор)'
    'logout:MCP серверийн хадгалагдсан OAuth итгэмжлэлийг цэвэрлэх'
    'help:Тусламж харуулах'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp commands' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Дебаг горимыг идэвхжүүлэх]' \
            '--verbose[Тохиргооны файлын нарийвчилсан горимын тохиргоог дарж бичих]' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Тохиргооны хүрээ (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Дамжуулалтын төрөл (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Орчны хувьсагчийг тохируулах (жишээ нь -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[WebSocket толгой тохируулах]:header:' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Тохиргооны хүрээ (local, user, project) - заагаагүй бол одоо байгаа хүрээнээс устгах]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Тохиргооны хүрээ (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Тохиргооны хүрээ (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Нэмэлт програм эсвэл маркетын манифестийг баталгаажуулах'
    'marketplace:Claude Code маркетуудыг удирдах'
    'list:Суулгасан нэмэлт програмуудыг жагсаах'
    'details:Нэмэлт програмын бүрэлдэхүүн хэсгийн жагсаалт ба төлөвлөсөн токены зардлыг харуулах'
    'install:Боломжтой маркетуудаас нэмэлт програм суулгах'
    'i:Боломжтой маркетуудаас нэмэлт програм суулгах (install-ын богино хэлбэр)'
    'init:Шинэ нэмэлт програмын суурь үүсгэх (дараагийн сессид автоматаар ачаална)'
    'uninstall:Суулгасан нэмэлт программыг устгах'
    'remove:Суулгасан нэмэлт программыг устгах (uninstall-ын өөр нэр)'
    'enable:Идэвхгүй болгосон нэмэлт программыг идэвхжүүлэх'
    'disable:Идэвхтэй нэмэлт программыг идэвхгүй болгох'
    'update:Нэмэлт програмыг хамгийн сүүлийн хувилбар руу шинэчлэх'
    'eval:Нэмэлт програмын эсрэг eval тохиолдлуудыг ажиллуулж, оноолсон үр дүнг тайлагнах'
    'prune:Шаардлагагүй болсон автоматаар суулгасан хамаарлуудыг устгах'
    'tag:Нэмэлт програмын хувилбарт {name}--v{version} git тэг үүсгэх'
    'help:Тусламж харуулах'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin commands' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Суулгах хүрээ]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Суулгах хүрээ]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Суулгах хүрээ]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Суулгах хүрээ]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:URL, зам эсвэл GitHub репозитороос маркет нэмэх'
    'list:Тохируулагдсан маркетуудыг жагсаах'
    'remove:Тохируулагдсан маркетийг устгах'
    'rm:Тохируулагдсан маркетийг устгах (remove-ын өөр нэр)'
    'update:Эх үүсвэрээс маркетийг шинэчлэх - нэр заагаагүй бол бүгдийг шинэчлэх'
    'help:Тусламж харуулах'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace commands' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Тусламж харуулах]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

