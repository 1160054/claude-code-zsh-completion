_claude_agents() {
  _arguments \
    '*--add-dir[Илгээгдсэн сессүүдэд багажийн хандалтыг зөвшөөрөх нэмэлт лавлах]:directory:_directories' \
    '--agent[Агент харагдацаас илгээгдсэн сессүүдэд зориулсан үндсэн агент]:agent:' \
    '--all[--json-тэй: дууссан фон сессүүдийг мөн оруулах]' \
    '--allow-dangerously-skip-permissions[Илгээгдсэн сессүүдэд bypass-permissions горимыг ашиглах боломжтой болгох]' \
    '--cwd[Зөвхөн замын дор эхэлсэн фон сессүүдийг харуулах]:path:_directories' \
    '--dangerously-skip-permissions[--permission-mode bypassPermissions-ийн өөр нэр]' \
    '--effort[Илгээгдсэн сессүүдийн үндсэн хүчин чармайлтын түвшин]:level:(low medium high xhigh max)' \
    '--json[Идэвхтэй сессүүдийг JSON массив болгон хэвлээд гарах]' \
    '*--mcp-config[Илгээгдсэн сессүүдэд хэрэглэх MCP серверийн тохиргоо]:config:' \
    '--model[Агент харагдацаас илгээгдсэн сессүүдэд зориулсан үндсэн загвар]:model:' \
    '--permission-mode[Илгээгдсэн сессүүдийн үндсэн зөвшөөрлийн горим]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Агент харагдац ба илгээгдсэн сессүүдэд лавлахаас нэмэлт програм ачаалах]:path:_directories' \
    '--setting-sources[Ачаалах тохиргооны эх үүсвэрийн жагсаалт (таслалаар тусгаарлагдсан: user, project, local)]:sources:' \
    '--settings[Хэрэглэх тохиргооны файл эсвэл JSON мөр]:file-or-json:_files' \
    '--strict-mcp-config[Илгээгдсэн сессүүдэд зөвхөн --mcp-config дотор байгаа MCP серверүүдийг ашиглах]' \
    '(-h --help)'{-h,--help}'[Командын тусламжийг харуулах]'
}

