  local -a auto_mode_commands
  auto_mode_commands=(
    'config:Druk die effektiewe outomatiese-modus-konfigurasie as JSON'
    'critique:Kry KI-terugvoer oor jou pasgemaakte outomatiese-modus-reëls'
    'defaults:Druk die verstek-outomatiese-modus-reëls as JSON'
    'reset:Herstel die outomatiese-modus-konfigurasie na die verskeepte verstekwaardes'
    'help:Vertoon hulp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'outo-modus-bevele' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Pad na die poort se YAML-konfigurasie]:path:_files' \
    '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Vee alle Claude Code-toestand vir '\''n projek uit (transkripsies, take, lêergeskiedenis, konfigurasie-inskrywing)'
    'help:Vertoon hulp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'projek-bevele' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Druk die rou bugs.json-loonvrag in plaas van geformatteerde bevindinge]' \
    '--timeout[Maksimum minute om te wag vir die hersiening om te voltooi]:minutes:' \
    '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
