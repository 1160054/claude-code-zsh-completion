#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Stel MCP-bedieners op en bestuur hulle'
    'plugin:Bestuur Claude Code-inproppe'
    'agents:Bestuur agtergrondagente'
    'auth:Bestuur verifikasie'
    'auto-mode:Inspekteer of herstel die outomatiese-modus-klassifiseerder se konfigurasie'
    'gateway:Laat die onderneming se verifikasie-/telemetrie-poort loop'
    'project:Bestuur Claude Code-projektoestand'
    'ultrareview:Laat '\''n wolk-gehuisveste multi-agent-kodehersiening loop en druk die bevindinge'
    'setup-token:Stel '\''n langtermyn-verifikasietoken op (vereis '\''n Claude-intekening)'
    'doctor:Gesondheidskontrole vir Claude Code se outo-bywerker'
    'update:Kontroleer vir en installeer opdaterings'
    'install:Installeer die inheemse Claude Code-bou'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Aktiveer ontfoutmodus met opsionele kategoriefiltrering (bv. "api,hooks" of "!statsig,!file")]:filter:'
    '--verbose[Oorheers die uitvoerige-modus-instelling van die konfigurasielêer]'
    '(-p --print)'{-p,--print}'[Druk die antwoord en sluit af (vir gebruik met pype). Let wel: gebruik slegs in vertroude gidse]'
    '--output-format[Afvoerformaat (met --print): "text" (verstek), "json" (enkele resultaat), of "stream-json" (intydse stroom)]:format:(text json stream-json)'
    '--json-schema[JSON-skema vir gestruktureerde afvoervalidering]:schema:'
    '--include-partial-messages[Sluit gedeeltelike boodskapstukke in soos hulle aankom (met --print en --output-format=stream-json)]'
    '--input-format[Toevoerformaat (met --print): "text" (verstek) of "stream-json" (intydse stroomtoevoer)]:format:(text stream-json)'
    '--mcp-debug[\[Verouderd. Gebruik --debug in plaas daarvan\] Aktiveer MCP-ontfoutmodus (wys MCP-bedienerfoute)]'
    '--dangerously-skip-permissions[Omseil alle toestemmingskontroles. Word slegs aanbeveel vir sandput-omgewings sonder internettoegang]'
    '--allow-dangerously-skip-permissions[Aktiveer die opsie om toestemmingskontroles te omseil sonder om dit by verstek te aktiveer]'
    '--max-budget-usd[Maksimum dollarbedrag om aan API-oproepe te bestee (slegs --print)]:amount:'
    '--replay-user-messages[Stuur gebruikersboodskappe van stdin weer op stdout vir bevestiging]'
    '--allowed-tools[Komma- of spasiegeskeide lys van toegelate gereedskapname (bv. "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Komma- of spasiegeskeide lys van toegelate gereedskapname (camelCase-formaat)]:tools:'
    '--tools[Spesifiseer die lys van beskikbare gereedskap uit die ingeboude stel. Slegs drukmodus]:tools:'
    '--disallowed-tools[Komma- of spasiegeskeide lys van verbode gereedskapname (bv. "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Komma- of spasiegeskeide lys van verbode gereedskapname (camelCase-formaat)]:tools:'
    '--mcp-config[Laai MCP-bedieners uit '\''n JSON-lêer of -string (spasiegeskei)]:configs:'
    '--system-prompt[Stelselopdrag om vir die sessie te gebruik]:prompt:'
    '--append-system-prompt[Voeg stelselopdrag by die verstek-stelselopdrag]:prompt:'
    '--permission-mode[Toestemmingsmodus om vir die sessie te gebruik]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Sit die mees onlangse gesprek voort]'
    '(-r --resume)'{-r,--resume}'[Hervat '\''n gesprek - spesifiseer die sessie-ID of kies interaktief]:sessionId:_claude_sessions'
    '--fork-session[Skep '\''n nuwe sessie-ID in plaas daarvan om die oorspronklike sessie-ID te hergebruik wanneer jy hervat (met --resume of --continue)]'
    '--no-session-persistence[Deaktiveer sessievolharding - sessies sal nie gestoor word nie (slegs --print)]'
    '--model[Model vir die huidige sessie. Spesifiseer '\''n alias vir die nuutste model (bv. '\''sonnet'\'' of '\''opus'\'')]:model:'
    '--agent[Agent vir die huidige sessie. Oorheers die '\''agent'\''-instelling]:agent:'
    '--betas[Beta-opskrifte om in API-versoeke in te sluit (slegs API-sleutelgebruikers)]:betas:'
    '--fallback-model[Aktiveer outomatiese terugval na die gespesifiseerde model wanneer die verstekmodel oorlaai is (slegs --print)]:model:'
    '--settings[Pad na '\''n instellings-JSON-lêer of JSON-string om bykomende instellings te laai]:file-or-json:_files'
    '--add-dir[Bykomende gidse om gereedskaptoegang toe te laat]:directories:_directories'
    '--ide[Koppel outomaties aan die IDE met aanvang as presies een geldige IDE beskikbaar is]'
    '--strict-mcp-config[Gebruik slegs MCP-bedieners van --mcp-config en ignoreer alle ander MCP-instellings]'
    '--session-id[Spesifieke sessie-ID om vir die gesprek te gebruik (moet '\''n geldige UUID wees)]:uuid:'
    '--agents[JSON-objek wat pasgemaakte agente definieer]:json:'
    '--setting-sources[Kommageskeide lys van instellingsbronne om te laai (user, project, local)]:sources:'
    '--plugin-dir[Gids om inproppe slegs vir hierdie sessie uit te laai (herhaalbaar)]:paths:_directories'
    '--disable-slash-commands[Deaktiveer alle skuinsstreepbevele]'
    '(--bg --background)'{--bg,--background}'[Begin die sessie as '\''n agtergrondagent en keer onmiddellik terug]'
    '(-w --worktree)'{-w,--worktree}'[Skep '\''n nuwe git-werkboom vir hierdie sessie (spesifiseer opsioneel '\''n naam)]::name:'
    '--tmux[Skep '\''n tmux-sessie vir die werkboom (vereis --worktree)]'
    '(-n --name)'{-n,--name}'[Stel '\''n vertoonnaam vir hierdie sessie]:name:'
    '--effort[Inspanningsvlak vir die huidige sessie]:level:(low medium high xhigh max)'
    '--debug-file[Skryf ontfoutlogboeke na '\''n spesifieke lêerpad (aktiveer implisiet die ontfoutmodus)]:path:_files'
    '--from-pr[Hervat '\''n sessie wat aan '\''n PR gekoppel is volgens nommer/URL, of open die interaktiewe kieser]::value:'
    '--remote-control[Begin '\''n interaktiewe sessie met Afstandsbeheer geaktiveer (opsioneel benoem)]::name:'
    '--remote-control-session-name-prefix[Voorvoegsel vir outomaties gegenereerde Afstandsbeheer-sessiename]:prefix:'
    '--chrome[Aktiveer Claude-in-Chrome-integrasie]'
    '--no-chrome[Deaktiveer Claude-in-Chrome-integrasie]'
    '--plugin-url[Haal '\''n inprop-.zip van '\''n URL slegs vir hierdie sessie (herhaalbaar)]:url:'
    '--file[Lêerhulpbronne om met aanvang af te laai (formaat: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Aktiveer opdragvoorstelle (gee '\''n voorspelde volgende opdrag in druk-/SDK-modus af)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Stuur subagent-teks en denkblokke as boodskappe aan (met --print en stream-json)]'
    '--include-hook-events[Sluit alle haak-lewensiklusgebeurtenisse in die afvoerstroom in (met stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Skuif per-masjien-afdelings na die eerste gebruikersboodskap om opdragkas-hergebruik te verbeter]'
    '--brief[Aktiveer die SendUserMessage-gereedskap vir agent-tot-gebruiker-kommunikasie]'
    '--safe-mode[Begin met alle aanpassings gedeaktiveer (nuttig om '\''n gebroke konfigurasie op te los)]'
    '--bare[Minimale modus: slaan hake, LSP, inpropsinkronisasie, toeskrywing, outo-geheue en CLAUDE.md-outo-ontdekking oor]'
    '--ax-screen-reader[Lewer skermleser-vriendelike afvoer (plat teks, geen dekoratiewe rande of animasies nie)]'
    '(-v --version)'{-v,--version}'[Voer die weergawenommer uit]'
    '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude-bevele' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "geen argumente"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Begin '\''n Claude Code MCP-bediener'
    'add:Voeg '\''n MCP-bediener by Claude Code'
    'remove:Verwyder '\''n MCP-bediener'
    'list:Lys opgestelde MCP-bedieners'
    'get:Kry MCP-bedienerbesonderhede'
    'add-json:Voeg '\''n MCP-bediener (stdio of SSE) met '\''n JSON-string by'
    'add-from-claude-desktop:Voer MCP-bedieners uit Claude Desktop in (slegs Mac en WSL)'
    'reset-project-choices:Herstel alle goedgekeurde/verwerpte projek-omvang (.mcp.json) bedieners in hierdie projek'
    'login:Verifieer met '\''n MCP-bediener (HTTP, SSE, of claude.ai-verbinder)'
    'logout:Vee gestoorde OAuth-legitimasie vir '\''n MCP-bediener uit'
    'help:Vertoon hulp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vertoon hulp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp-bevele' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Aktiveer ontfoutmodus]' \
            '--verbose[Oorheers die uitvoerige-modus-instelling van die konfigurasielêer]' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasie-omvang (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Vervoertipe (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Stel '\''n omgewingsveranderlike (bv. -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[Stel '\''n WebSocket-opskrif]:header:' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasie-omvang (local, user, project) - verwyder uit bestaande omvang indien nie gespesifiseer nie]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasie-omvang (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Konfigurasie-omvang (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Valideer '\''n inprop- of markplein-manifes'
    'marketplace:Bestuur Claude Code-markpleine'
    'list:Lys geïnstalleerde inproppe'
    'details:Wys die komponentinventaris en geprojekteerde tokenkoste vir '\''n inprop'
    'install:Installeer '\''n inprop uit beskikbare markpleine'
    'i:Installeer '\''n inprop uit beskikbare markpleine (kort vir install)'
    'init:Steier '\''n nuwe inprop (laai outomaties in die volgende sessie)'
    'uninstall:Deïnstalleer '\''n geïnstalleerde inprop'
    'remove:Deïnstalleer '\''n geïnstalleerde inprop (alias vir uninstall)'
    'enable:Aktiveer '\''n gedeaktiveerde inprop'
    'disable:Deaktiveer '\''n geaktiveerde inprop'
    'update:Werk '\''n inprop by na die nuutste weergawe'
    'eval:Laat evalueringsgevalle teen '\''n inprop loop en rapporteer die getelde resultate'
    'prune:Verwyder outo-geïnstalleerde afhanklikhede wat nie meer nodig is nie'
    'tag:Skep '\''n {name}--v{version} git-etiket vir '\''n inpropvrystelling'
    'help:Vertoon hulp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vertoon hulp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'inprop-bevele' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasie-omvang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasie-omvang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasie-omvang]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Installasie-omvang]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Voeg '\''n markplein by vanaf '\''n URL, pad, of GitHub-bewaarplek'
    'list:Lys opgestelde markpleine'
    'remove:Verwyder '\''n opgestelde markplein'
    'rm:Verwyder '\''n opgestelde markplein (alias vir remove)'
    'update:Werk markplein by vanaf bron - werk almal by as geen naam gespesifiseer is nie'
    'help:Vertoon hulp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vertoon hulp]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'markplein-bevele' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Forseer installasie selfs al is dit reeds geïnstalleer]' \
    '(-h --help)'{-h,--help}'[Vertoon hulp]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Bykomende gids om gereedskaptoegang toe te laat in versonde sessies]:directory:_directories' \
    '--agent[Verstekagent vir sessies wat vanaf die agentaansig versend word]:agent:' \
    '--all[Met --json: sluit ook voltooide agtergrondsessies in]' \
    '--allow-dangerously-skip-permissions[Maak omseil-toestemmings-modus beskikbaar vir versonde sessies]' \
    '--cwd[Wys slegs agtergrondsessies wat onder die pad begin is]:path:_directories' \
    '--dangerously-skip-permissions[Alias vir --permission-mode bypassPermissions]' \
    '--effort[Verstek-inspanningsvlak vir versonde sessies]:level:(low medium high xhigh max)' \
    '--json[Druk aktiewe sessies as '\''n JSON-skikking en sluit af]' \
    '*--mcp-config[MCP-bedienerkonfigurasie om op versonde sessies toe te pas]:config:' \
    '--model[Verstekmodel vir sessies wat vanaf die agentaansig versend word]:model:' \
    '--permission-mode[Verstek-toestemmingsmodus vir versonde sessies]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Laai inproppe uit die gids vir die agentaansig en versonde sessies]:path:_directories' \
    '--setting-sources[Kommageskeide lys van instellingsbronne om te laai (user, project, local)]:sources:' \
    '--settings[Instellingslêer of JSON-string om toe te pas]:file-or-json:_files' \
    '--strict-mcp-config[Gebruik slegs MCP-bedieners van --mcp-config in versonde sessies]' \
    '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:Meld by jou Anthropic-rekening aan'
    'logout:Meld by jou Anthropic-rekening af'
    'status:Wys verifikasiestatus'
    'help:Vertoon hulp'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth-bevele' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[Vertoon hulp vir die bevel]'
          ;;
      esac
      ;;
  esac
}

