  local -a auto_mode_commands
  auto_mode_commands=(
    'config:Afficher la configuration effective du mode automatique au format JSON'
    'critique:Obtenir un retour de l'\''IA sur vos règles de mode automatique personnalisées'
    'defaults:Afficher les règles par défaut du mode automatique au format JSON'
