      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Chemin vers le fichier de configuration YAML de la passerelle]:path:_files' \
    '(-h --help)'{-h,--help}'[Afficher l'\''aide pour la commande]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Supprimer tout l'\''état Claude Code d'\''un projet (transcriptions, tâches, historique des fichiers, entrée de configuration)'
    'help:Afficher l'\''aide'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Afficher l'\''aide pour la commande]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'commandes project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Afficher l'\''aide pour la commande]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Afficher la charge utile brute bugs.json au lieu des résultats formatés]' \
    '--timeout[Nombre maximum de minutes à attendre la fin de la revue]:minutes:' \
    '(-h --help)'{-h,--help}'[Afficher l'\''aide pour la commande]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
