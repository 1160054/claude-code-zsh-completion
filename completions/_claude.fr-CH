  _arguments -C \
    '(-h --help)'{-h,--help}'[Afficher l'\''aide pour la commande]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'commandes auto-mode' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Afficher l'\''aide pour la commande]'
