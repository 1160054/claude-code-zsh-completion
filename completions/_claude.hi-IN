#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:MCP सर्वरों को कॉन्फ़िगर और प्रबंधित करें'
    'plugin:Claude Code प्लगइन्स प्रबंधित करें'
    'agents:बैकग्राउंड एजेंट प्रबंधित करें'
    'auth:प्रमाणीकरण प्रबंधित करें'
    'auto-mode:ऑटो मोड क्लासिफायर कॉन्फ़िगरेशन का निरीक्षण या रीसेट करें'
    'gateway:एंटरप्राइज़ ऑथ/टेलीमेट्री गेटवे चलाएं'
    'project:Claude Code प्रोजेक्ट स्थिति प्रबंधित करें'
    'ultrareview:क्लाउड-होस्टेड मल्टी-एजेंट कोड समीक्षा चलाएं और निष्कर्ष प्रिंट करें'
    'setup-token:दीर्घकालिक प्रमाणीकरण टोकन सेट करें (Claude सदस्यता आवश्यक)'
    'doctor:Claude Code ऑटो-अपडेटर के लिए स्वास्थ्य जांच'
    'update:अपडेट की जांच करें और इंस्टॉल करें'
    'install:Claude Code नेटिव बिल्ड इंस्टॉल करें'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[वैकल्पिक श्रेणी फ़िल्टरिंग के साथ डिबग मोड सक्षम करें (जैसे, "api,hooks" या "!statsig,!file")]:filter:'
    '--verbose[कॉन्फ़िग फ़ाइल से वर्बोज़ मोड सेटिंग को ओवरराइड करें]'
    '(-p --print)'{-p,--print}'[प्रतिक्रिया प्रिंट करें और बाहर निकलें (पाइप के साथ उपयोग के लिए)। नोट: केवल विश्वसनीय निर्देशिकाओं में उपयोग करें]'
    '--output-format[आउटपुट प्रारूप (--print के साथ): "text" (डिफ़ॉल्ट), "json" (एकल परिणाम), या "stream-json" (रीयल-टाइम स्ट्रीमिंग)]:format:(text json stream-json)'
    '--json-schema[संरचित आउटपुट सत्यापन के लिए JSON स्कीमा]:schema:'
    '--include-partial-messages[आंशिक संदेश खंडों को शामिल करें जैसे वे आते हैं (--print और --output-format=stream-json के साथ)]'
    '--input-format[इनपुट प्रारूप (--print के साथ): "text" (डिफ़ॉल्ट) या "stream-json" (रीयल-टाइम स्ट्रीमिंग इनपुट)]:format:(text stream-json)'
    '--mcp-debug[\[अप्रचलित। इसके बजाय --debug का उपयोग करें\] MCP डिबग मोड सक्षम करें (MCP सर्वर त्रुटियां दिखाता है)]'
    '--dangerously-skip-permissions[सभी अनुमति जांचों को बायपास करें। केवल इंटरनेट एक्सेस के बिना सैंडबॉक्स के लिए अनुशंसित]'
    '--allow-dangerously-skip-permissions[डिफ़ॉल्ट रूप से सक्षम किए बिना अनुमति जांच को बायपास करने के विकल्प को सक्षम करें]'
    '--max-budget-usd[API कॉल पर खर्च करने के लिए अधिकतम डॉलर राशि (केवल --print)]:amount:'
    '--replay-user-messages[पुष्टि के लिए stdin से stdout पर उपयोगकर्ता संदेशों को फिर से भेजें]'
    '--allowed-tools[अनुमत टूल नामों की अल्पविराम या स्पेस-पृथक सूची (जैसे, "Bash(git:*) Edit")]:tools:'
    '--allowedTools[अनुमत टूल नामों की अल्पविराम या स्पेस-पृथक सूची (camelCase प्रारूप)]:tools:'
    '--tools[बिल्ट-इन सेट से उपलब्ध टूल की सूची निर्दिष्ट करें। केवल प्रिंट मोड]:tools:'
    '--disallowed-tools[अस्वीकृत टूल नामों की अल्पविराम या स्पेस-पृथक सूची (जैसे, "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[अस्वीकृत टूल नामों की अल्पविराम या स्पेस-पृथक सूची (camelCase प्रारूप)]:tools:'
    '--mcp-config[JSON फ़ाइल या स्ट्रिंग से MCP सर्वर लोड करें (स्पेस-पृथक)]:configs:'
    '--system-prompt[सत्र के लिए उपयोग करने के लिए सिस्टम प्रॉम्प्ट]:prompt:'
    '--append-system-prompt[डिफ़ॉल्ट सिस्टम प्रॉम्प्ट में सिस्टम प्रॉम्प्ट जोड़ें]:prompt:'
    '--permission-mode[सत्र के लिए उपयोग करने के लिए अनुमति मोड]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[सबसे हालिया बातचीत जारी रखें]'
    '(-r --resume)'{-r,--resume}'[एक बातचीत फिर से शुरू करें - सत्र ID निर्दिष्ट करें या इंटरैक्टिव रूप से चुनें]:sessionId:_claude_sessions'
    '--fork-session[फिर से शुरू करते समय मूल सत्र ID का पुन: उपयोग करने के बजाय नया सत्र ID बनाएं (--resume या --continue के साथ)]'
    '--no-session-persistence[सत्र स्थायित्व अक्षम करें - सत्र सहेजे नहीं जाएंगे (केवल --print)]'
    '--model[वर्तमान सत्र के लिए मॉडल। नवीनतम मॉडल के लिए उपनाम निर्दिष्ट करें (जैसे, '\''sonnet'\'' या '\''opus'\'')]:model:'
    '--agent[वर्तमान सत्र के लिए एजेंट। '\''agent'\'' सेटिंग को ओवरराइड करता है]:agent:'
    '--betas[API अनुरोधों में शामिल करने के लिए बीटा हेडर (केवल API key उपयोगकर्ता)]:betas:'
    '--fallback-model[जब डिफ़ॉल्ट मॉडल ओवरलोड हो तो निर्दिष्ट मॉडल में स्वचालित फ़ॉलबैक सक्षम करें (केवल --print)]:model:'
    '--settings[सेटिंग्स JSON फ़ाइल या अतिरिक्त सेटिंग्स लोड करने के लिए JSON स्ट्रिंग का पथ]:file-or-json:_files'
    '--add-dir[टूल एक्सेस की अनुमति देने के लिए अतिरिक्त निर्देशिकाएं]:directories:_directories'
    '--ide[यदि बिल्कुल एक मान्य IDE उपलब्ध है तो स्टार्टअप पर IDE से ऑटो-कनेक्ट करें]'
    '--strict-mcp-config[केवल --mcp-config से MCP सर्वर का उपयोग करें और अन्य सभी MCP सेटिंग्स को अनदेखा करें]'
    '--session-id[बातचीत के लिए उपयोग करने के लिए विशिष्ट सत्र ID (मान्य UUID होना चाहिए)]:uuid:'
    '--agents[कस्टम एजेंटों को परिभाषित करने वाला JSON ऑब्जेक्ट]:json:'
    '--setting-sources[लोड करने के लिए सेटिंग स्रोतों की अल्पविराम-पृथक सूची (user, project, local)]:sources:'
    '--plugin-dir[केवल इस सत्र के लिए प्लगइन्स लोड करने के लिए निर्देशिका (दोहराने योग्य)]:paths:_directories'
    '--disable-slash-commands[सभी स्लैश कमांड अक्षम करें]'
    '(--bg --background)'{--bg,--background}'[सत्र को बैकग्राउंड एजेंट के रूप में प्रारंभ करें और तुरंत लौटें]'
    '(-w --worktree)'{-w,--worktree}'[इस सत्र के लिए नया git worktree बनाएं (वैकल्पिक रूप से नाम निर्दिष्ट करें)]::name:'
    '--tmux[worktree के लिए tmux सत्र बनाएं (--worktree आवश्यक)]'
    '(-n --name)'{-n,--name}'[इस सत्र के लिए प्रदर्शन नाम सेट करें]:name:'
    '--effort[वर्तमान सत्र के लिए प्रयास स्तर]:level:(low medium high xhigh max)'
    '--debug-file[विशिष्ट फ़ाइल पथ पर डिबग लॉग लिखें (परोक्ष रूप से डिबग मोड सक्षम करता है)]:path:_files'
    '--from-pr[संख्या/URL द्वारा PR से जुड़ा सत्र फिर से शुरू करें, या इंटरैक्टिव पिकर खोलें]::value:'
    '--remote-control[Remote Control सक्षम के साथ इंटरैक्टिव सत्र प्रारंभ करें (वैकल्पिक रूप से नामित)]::name:'
    '--remote-control-session-name-prefix[स्वतः-जनित Remote Control सत्र नामों के लिए उपसर्ग]:prefix:'
    '--chrome[Chrome में Claude एकीकरण सक्षम करें]'
    '--no-chrome[Chrome में Claude एकीकरण अक्षम करें]'
    '--plugin-url[केवल इस सत्र के लिए URL से प्लगइन .zip प्राप्त करें (दोहराने योग्य)]:url:'
    '--file[स्टार्टअप पर डाउनलोड करने के लिए फ़ाइल संसाधन (प्रारूप: file_id:relative_path)]:specs:'
    '--prompt-suggestions[प्रॉम्प्ट सुझाव सक्षम करें (print/SDK मोड में अनुमानित अगला प्रॉम्प्ट उत्सर्जित करता है)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[सबएजेंट टेक्स्ट और थिंकिंग ब्लॉक को संदेश के रूप में फ़ॉरवर्ड करें (--print और stream-json के साथ)]'
    '--include-hook-events[आउटपुट स्ट्रीम में सभी hook लाइफसाइकल इवेंट शामिल करें (stream-json के साथ)]'
    '--exclude-dynamic-system-prompt-sections[prompt-cache पुन: उपयोग सुधारने के लिए प्रति-मशीन अनुभागों को पहले उपयोगकर्ता संदेश में स्थानांतरित करें]'
    '--brief[एजेंट-से-उपयोगकर्ता संचार के लिए SendUserMessage टूल सक्षम करें]'
    '--safe-mode[सभी कस्टमाइज़ेशन अक्षम के साथ प्रारंभ करें (टूटे कॉन्फ़िगरेशन के समस्या निवारण के लिए उपयोगी)]'
    '--bare[न्यूनतम मोड: hooks, LSP, प्लगइन सिंक, एट्रिब्यूशन, ऑटो-मेमोरी, और CLAUDE.md ऑटो-डिस्कवरी छोड़ें]'
    '--ax-screen-reader[स्क्रीन-रीडर अनुकूल आउटपुट रेंडर करें (सपाट टेक्स्ट, कोई सजावटी बॉर्डर या एनिमेशन नहीं)]'
    '(-v --version)'{-v,--version}'[संस्करण संख्या आउटपुट करें]'
    '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'claude commands' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "कोई तर्क नहीं"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Claude Code MCP सर्वर प्रारंभ करें'
    'add:Claude Code में एक MCP सर्वर जोड़ें'
    'remove:एक MCP सर्वर हटाएं'
    'list:कॉन्फ़िगर किए गए MCP सर्वरों की सूची बनाएं'
    'get:MCP सर्वर विवरण प्राप्त करें'
    'add-json:JSON स्ट्रिंग के साथ एक MCP सर्वर (stdio या SSE) जोड़ें'
    'add-from-claude-desktop:Claude Desktop से MCP सर्वर आयात करें (केवल Mac और WSL)'
    'reset-project-choices:इस परियोजना में सभी स्वीकृत/अस्वीकृत परियोजना-स्कोप्ड (.mcp.json) सर्वरों को रीसेट करें'
    'login:MCP सर्वर के साथ प्रमाणीकरण करें (HTTP, SSE, या claude.ai कनेक्टर)'
    'logout:MCP सर्वर के लिए संग्रहीत OAuth क्रेडेंशियल साफ़ करें'
    'help:सहायता प्रदर्शित करें'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'mcp commands' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[डिबग मोड सक्षम करें]' \
            '--verbose[कॉन्फ़िग फ़ाइल से वर्बोज़ मोड सेटिंग को ओवरराइड करें]' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[कॉन्फ़िग स्कोप (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[परिवहन प्रकार (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[पर्यावरण चर सेट करें (जैसे, -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[WebSocket हेडर सेट करें]:header:' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[कॉन्फ़िग स्कोप (local, user, project) - यदि अनिर्दिष्ट हो तो मौजूदा स्कोप से हटाएं]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[कॉन्फ़िग स्कोप (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[कॉन्फ़िग स्कोप (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:एक प्लगइन या मार्केटप्लेस मैनिफेस्ट को मान्य करें'
    'marketplace:Claude Code मार्केटप्लेस प्रबंधित करें'
    'list:इंस्टॉल किए गए प्लगइन्स की सूची बनाएं'
    'details:किसी प्लगइन के लिए कंपोनेंट इन्वेंटरी और अनुमानित टोकन लागत दिखाएं'
    'install:उपलब्ध मार्केटप्लेस से एक प्लगइन इंस्टॉल करें'
    'i:उपलब्ध मार्केटप्लेस से एक प्लगइन इंस्टॉल करें (install के लिए संक्षिप्त)'
    'init:एक नया प्लगइन स्कैफ़ोल्ड करें (अगले सत्र में ऑटो-लोड होता है)'
    'uninstall:एक इंस्टॉल किया गया प्लगइन अनइंस्टॉल करें'
    'remove:एक इंस्टॉल किया गया प्लगइन अनइंस्टॉल करें (uninstall के लिए उपनाम)'
    'enable:एक अक्षम प्लगइन सक्षम करें'
    'disable:एक सक्षम प्लगइन अक्षम करें'
    'update:एक प्लगइन को नवीनतम संस्करण में अपडेट करें'
    'eval:किसी प्लगइन के विरुद्ध eval केस चलाएं और स्कोर किए गए परिणाम रिपोर्ट करें'
    'prune:अब आवश्यक न रहीं ऑटो-इंस्टॉल की गई निर्भरताएं हटाएं'
    'tag:प्लगइन रिलीज़ के लिए {name}--v{version} git टैग बनाएं'
    'help:सहायता प्रदर्शित करें'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'plugin commands' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[इंस्टॉलेशन स्कोप]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[इंस्टॉलेशन स्कोप]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[इंस्टॉलेशन स्कोप]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[इंस्टॉलेशन स्कोप]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:URL, पथ, या GitHub रिपॉजिटरी से एक मार्केटप्लेस जोड़ें'
    'list:कॉन्फ़िगर किए गए मार्केटप्लेस की सूची बनाएं'
    'remove:एक कॉन्फ़िगर किया गया मार्केटप्लेस हटाएं'
    'rm:एक कॉन्फ़िगर किया गया मार्केटप्लेस हटाएं (remove के लिए उपनाम)'
    'update:स्रोत से मार्केटप्लेस अपडेट करें - यदि कोई नाम निर्दिष्ट नहीं है तो सभी को अपडेट करें'
    'help:सहायता प्रदर्शित करें'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'marketplace commands' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[पहले से इंस्टॉल होने पर भी फोर्स इंस्टॉल करें]' \
    '(-h --help)'{-h,--help}'[सहायता प्रदर्शित करें]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[डिस्पैच किए गए सत्रों में टूल एक्सेस की अनुमति देने के लिए अतिरिक्त निर्देशिका]:directory:_directories' \
    '--agent[एजेंट व्यू से डिस्पैच किए गए सत्रों के लिए डिफ़ॉल्ट एजेंट]:agent:' \
    '--all[--json के साथ: पूर्ण बैकग्राउंड सत्रों को भी शामिल करें]' \
    '--allow-dangerously-skip-permissions[डिस्पैच किए गए सत्रों के लिए bypass-permissions मोड उपलब्ध कराएं]' \
    '--cwd[केवल पथ के अंतर्गत प्रारंभ किए गए बैकग्राउंड सत्र दिखाएं]:path:_directories' \
    '--dangerously-skip-permissions[--permission-mode bypassPermissions के लिए उपनाम]' \
    '--effort[डिस्पैच किए गए सत्रों के लिए डिफ़ॉल्ट प्रयास स्तर]:level:(low medium high xhigh max)' \
    '--json[सक्रिय सत्रों को JSON सरणी के रूप में प्रिंट करें और बाहर निकलें]' \
    '*--mcp-config[डिस्पैच किए गए सत्रों पर लागू करने के लिए MCP सर्वर कॉन्फ़िगरेशन]:config:' \
    '--model[एजेंट व्यू से डिस्पैच किए गए सत्रों के लिए डिफ़ॉल्ट मॉडल]:model:' \
    '--permission-mode[डिस्पैच किए गए सत्रों के लिए डिफ़ॉल्ट अनुमति मोड]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[एजेंट व्यू और डिस्पैच किए गए सत्रों के लिए निर्देशिका से प्लगइन्स लोड करें]:path:_directories' \
    '--setting-sources[लोड करने के लिए सेटिंग स्रोतों की अल्पविराम-पृथक सूची (user, project, local)]:sources:' \
    '--settings[लागू करने के लिए सेटिंग्स फ़ाइल या JSON स्ट्रिंग]:file-or-json:_files' \
    '--strict-mcp-config[डिस्पैच किए गए सत्रों में केवल --mcp-config से MCP सर्वर का उपयोग करें]' \
    '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:अपने Anthropic खाते में साइन इन करें'
    'logout:अपने Anthropic खाते से लॉग आउट करें'
    'status:प्रमाणीकरण स्थिति दिखाएं'
    'help:सहायता प्रदर्शित करें'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auth commands' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]'
          ;;
      esac
      ;;
  esac
}

_claude_auto_mode() {
  local -a auto_mode_commands
  auto_mode_commands=(
    'config:प्रभावी ऑटो मोड कॉन्फ़िग को JSON के रूप में प्रिंट करें'
    'critique:अपने कस्टम ऑटो मोड नियमों पर AI फ़ीडबैक प्राप्त करें'
    'defaults:डिफ़ॉल्ट ऑटो मोड नियमों को JSON के रूप में प्रिंट करें'
    'reset:ऑटो मोड कॉन्फ़िगरेशन को शिप किए गए डिफ़ॉल्ट पर रीसेट करें'
    'help:सहायता प्रदर्शित करें'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode commands' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[गेटवे YAML कॉन्फ़िग का पथ]:path:_files' \
    '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:किसी प्रोजेक्ट के लिए सभी Claude Code स्थिति हटाएं (ट्रांसक्रिप्ट, कार्य, फ़ाइल इतिहास, कॉन्फ़िग प्रविष्टि)'
    'help:सहायता प्रदर्शित करें'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[फ़ॉर्मेट किए गए निष्कर्षों के बजाय कच्चा bugs.json पेलोड प्रिंट करें]' \
    '--timeout[समीक्षा पूर्ण होने की प्रतीक्षा के लिए अधिकतम मिनट]:minutes:' \
    '(-h --help)'{-h,--help}'[कमांड के लिए सहायता प्रदर्शित करें]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
