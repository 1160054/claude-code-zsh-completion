#compdef claude

# Dynamic completion functions
_claude_mcp_servers() {
  local config_file
  local -a server_list

  # Parse config files using grep/sed (no external dependencies)
  for config_file in ~/.claude.json ~/.claude/mcp.json ~/.config/claude/mcp.json; do
    [[ -f "$config_file" ]] || continue
    # Find entries with "command", "type", or "url" (MCP server signature)
    server_list+=(${(f)"$(grep -B 1 -E '"(command|type|url)"[[:space:]]*:' "$config_file" 2>/dev/null | \
      grep -E '"[^"]+": \{' | sed 's/.*"\([^"]*\)".*/\1/' | grep -v '/')"})
  done
  server_list=(${(u)server_list})

  # Fallback to claude mcp list
  if [[ ${#server_list[@]} -eq 0 ]]; then
    server_list=(${(f)"$(claude mcp list 2>/dev/null | sed -n 's/^\([^:]*\):.*/\1/p' | grep -v '^Checking')"})
  fi

  compadd -a server_list
}

_claude_installed_plugins() {
  local -a plugins
  local config_file plugin_dir

  # Check plugin directories directly
  for plugin_dir in ~/.claude/plugins ~/.config/claude/plugins; do
    [[ -d "$plugin_dir" ]] || continue
    plugins+=(${plugin_dir}/*(N:t))
  done

  # Remove duplicates
  plugins=(${(u)plugins})

  compadd -a plugins
}

_claude_sessions() {
  local -a sessions
  local session_dir

  # Check session directory
  for session_dir in ~/.claude/sessions ~/.config/claude/sessions; do
    [[ -d "$session_dir" ]] || continue

    # Extract UUIDs directly from filenames
    sessions+=(${session_dir}/*~*.zwc(N:t:r))
  done

  # Filter only valid UUIDs
  sessions=(${(M)sessions:#[0-9a-f](#c8)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c4)-[0-9a-f](#c12)})

  compadd -a sessions
}

_claude() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a main_commands
  main_commands=(
    'mcp:Konfiguriranje i upravljanje MCP serverima'
    'plugin:Upravljanje dodacima Claude Code'
    'agents:Upravljanje pozadinskim agentima'
    'auth:Upravljanje autentifikacijom'
    'auto-mode:Pregledaj ili resetuj konfiguraciju klasifikatora automatskog režima'
    'gateway:Pokreni enterprise gateway za autentifikaciju/telemetriju'
    'project:Upravljanje stanjem projekta Claude Code'
    'ultrareview:Pokreni multi-agentski pregled koda hostovan u oblaku i ispiši nalaze'
    'setup-token:Postavljanje tokena za dugotrajnu autentifikaciju (zahtijeva Claude pretplatu)'
    'doctor:Provjera zdravlja sistema automatskih ažuriranja Claude Code'
    'update:Provjera i instalacija ažuriranja'
    'install:Instalacija izvorne verzije Claude Code'
  )

  local -a main_options
  main_options=(
    '(-d --debug)'{-d,--debug}'[Uključi režim otklanjanja grešaka sa opcionalnim filtriranjem kategorija (npr. "api,hooks" ili "!statsig,!file")]:filter:'
    '--verbose[Prepiši postavku detaljnog režima iz konfiguracione datoteke]'
    '(-p --print)'{-p,--print}'[Ispiši odgovor i izlaz (za korištenje sa pipe). Napomena: koristite samo u pouzdanim direktorijima]'
    '--output-format[Format izlaza (sa --print): "text" (podrazumijevano), "json" (jedan rezultat), ili "stream-json" (streamanje u realnom vremenu)]:format:(text json stream-json)'
    '--json-schema[JSON shema za validaciju strukturiranog izlaza]:schema:'
    '--include-partial-messages[Uključi djelomične fragmente poruka prilikom njihovog dolaska (sa --print i --output-format=stream-json)]'
    '--input-format[Format unosa (sa --print): "text" (podrazumijevano) ili "stream-json" (streamani unos u realnom vremenu)]:format:(text stream-json)'
    '--mcp-debug[\[Zastarjelo. Koristite --debug umjesto toga\] Uključi režim otklanjanja grešaka MCP (prikazuje greške MCP servera)]'
    '--dangerously-skip-permissions[Zaobiđi sve provjere dozvola. Preporučeno samo za sandbox okruženja bez pristupa internetu]'
    '--allow-dangerously-skip-permissions[Omogući opciju zaobilaženja provjera dozvola bez omogućavanja po podrazumijevanom]'
    '--max-budget-usd[Maksimalni iznos u dolarima za potrošnju na API pozive (samo --print)]:amount:'
    '--replay-user-messages[Ponovno pošalji korisničke poruke iz stdin na stdout za potvrdu]'
    '--allowed-tools[Lista dozvoljenih imena alata odvojenih zarezom ili razmakom (npr. "Bash(git:*) Edit")]:tools:'
    '--allowedTools[Lista dozvoljenih imena alata odvojenih zarezom ili razmakom (format camelCase)]:tools:'
    '--tools[Navedi listu dostupnih alata iz ugrađenog skupa. Samo u režimu print]:tools:'
    '--disallowed-tools[Lista zabranjenih imena alata odvojenih zarezom ili razmakom (npr. "Bash(git:*) Edit")]:tools:'
    '--disallowedTools[Lista zabranjenih imena alata odvojenih zarezom ili razmakom (format camelCase)]:tools:'
    '--mcp-config[Učitaj MCP servere iz JSON datoteke ili niza (odvojeni razmacima)]:configs:'
    '--system-prompt[Sistemski prompt za korištenje u sesiji]:prompt:'
    '--append-system-prompt[Dodaj sistemski prompt podrazumijevanom sistemskom promptu]:prompt:'
    '--permission-mode[Režim dozvola za korištenje u sesiji]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)'
    '(-c --continue)'{-c,--continue}'[Nastavi posljednji razgovor]'
    '(-r --resume)'{-r,--resume}'[Nastavi razgovor - navedite identifikator sesije ili odaberite interaktivno]:sessionId:_claude_sessions'
    '--fork-session[Kreiraj novi identifikator sesije umjesto ponovne upotrebe originalnog prilikom nastavka (sa --resume ili --continue)]'
    '--no-session-persistence[Onemogući postojanost sesije - sesije neće biti sačuvane (samo --print)]'
    '--model[Model za trenutnu sesiju. Navedite nadimak za najnoviji model (npr. '\''sonnet'\'' ili '\''opus'\'')]:model:'
    '--agent[Agent za trenutnu sesiju. Prepisuje postavku '\''agent'\'']:agent:'
    '--betas[Beta zaglavlja za uključivanje u API zahtjeve (samo za korisnike API ključa)]:betas:'
    '--fallback-model[Omogući automatsko prebacivanje na navedeni model kada je podrazumijevani model preopterećen (samo --print)]:model:'
    '--settings[Putanja do JSON datoteke sa postavkama ili JSON niz za učitavanje dodatnih postavki]:file-or-json:_files'
    '--add-dir[Dodatni direktoriji za pružanje pristupa alatima]:directories:_directories'
    '--ide[Automatski se poveži sa IDE prilikom pokretanja ako je dostupan tačno jedan validan IDE]'
    '--strict-mcp-config[Koristi samo MCP servere iz --mcp-config i zanemari sva druga MCP podešavanja]'
    '--session-id[Određeni identifikator sesije za korištenje u razgovoru (mora biti validan UUID)]:uuid:'
    '--agents[JSON objekt koji definiše prilagođene agente]:json:'
    '--setting-sources[Lista izvora postavki odvojenih zarezom za učitavanje (user, project, local)]:sources:'
    '--plugin-dir[Direktorij za učitavanje dodataka samo za ovu sesiju (može se ponavljati)]:paths:_directories'
    '--disable-slash-commands[Onemogući sve slash naredbe]'
    '(--bg --background)'{--bg,--background}'[Pokreni sesiju kao pozadinski agent i odmah se vrati]'
    '(-w --worktree)'{-w,--worktree}'[Kreiraj novi git worktree za ovu sesiju (opcionalno navedite ime)]::name:'
    '--tmux[Kreiraj tmux sesiju za worktree (zahtijeva --worktree)]'
    '(-n --name)'{-n,--name}'[Postavi prikazno ime za ovu sesiju]:name:'
    '--effort[Nivo napora za trenutnu sesiju]:level:(low medium high xhigh max)'
    '--debug-file[Zapiši debug logove u određenu putanju datoteke (implicitno omogućava debug režim)]:path:_files'
    '--from-pr[Nastavi sesiju povezanu sa PR-om po broju/URL-u, ili otvori interaktivni izbornik]::value:'
    '--remote-control[Pokreni interaktivnu sesiju sa omogućenim Remote Control-om (opcionalno imenovanu)]::name:'
    '--remote-control-session-name-prefix[Prefiks za automatski generirana imena Remote Control sesija]:prefix:'
    '--chrome[Omogući integraciju Claude u Chrome]'
    '--no-chrome[Onemogući integraciju Claude u Chrome]'
    '--plugin-url[Preuzmi .zip dodatka sa URL-a samo za ovu sesiju (može se ponavljati)]:url:'
    '--file[Datotečni resursi za preuzimanje pri pokretanju (format: file_id:relative_path)]:specs:'
    '--prompt-suggestions[Omogući prijedloge prompta (emituje predviđeni sljedeći prompt u print/SDK režimu)]::value:(true false 1 0 yes no on off)'
    '--forward-subagent-text[Proslijedi tekst podagenta i blokove razmišljanja kao poruke (sa --print i stream-json)]'
    '--include-hook-events[Uključi sve hook događaje životnog ciklusa u izlazni stream (sa stream-json)]'
    '--exclude-dynamic-system-prompt-sections[Premjesti sekcije specifične za mašinu u prvu korisničku poruku radi bolje ponovne upotrebe prompt-keša]'
    '--brief[Omogući alat SendUserMessage za komunikaciju agent-korisnik]'
    '--safe-mode[Pokreni sa svim prilagodbama onemogućenim (korisno za rješavanje problema sa neispravnom konfiguracijom)]'
    '--bare[Minimalni režim: preskoči hookove, LSP, sinhronizaciju dodataka, atribuciju, auto-memoriju i automatsko otkrivanje CLAUDE.md]'
    '--ax-screen-reader[Prikaži izlaz prilagođen čitaču ekrana (ravan tekst, bez dekorativnih okvira ili animacija)]'
    '(-v --version)'{-v,--version}'[Ispiši broj verzije]'
    '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]'
  )

  _arguments -C \
    $main_options \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'naredbe claude' main_commands
      ;;
    args)
      case $words[1] in
        mcp)
          _claude_mcp
          ;;
        plugin)
          _claude_plugin
          ;;
        install)
          _claude_install
          ;;
        agents)
          _claude_agents
          ;;
        auth)
          _claude_auth
          ;;
        auto-mode)
          _claude_auto_mode
          ;;
        gateway)
          _claude_gateway
          ;;
        project)
          _claude_project
          ;;
        ultrareview)
          _claude_ultrareview
          ;;
        setup-token|doctor|update)
          _message "bez argumenata"
          ;;
      esac
      ;;
  esac
}

_claude_mcp() {
  local -a mcp_commands
  mcp_commands=(
    'serve:Pokreni MCP server Claude Code'
    'add:Dodaj MCP server u Claude Code'
    'remove:Ukloni MCP server'
    'list:Prikaži listu konfiguriranih MCP servera'
    'get:Preuzmi detalje MCP servera'
    'add-json:Dodaj MCP server (stdio ili SSE) sa JSON nizom'
    'add-from-claude-desktop:Uvezi MCP servere iz Claude Desktop (samo Mac i WSL)'
    'reset-project-choices:Resetuj sve odobrene/odbijene servere sa opsegom projekta (.mcp.json) u ovom projektu'
    'login:Autentifikuj se sa MCP serverom (HTTP, SSE ili claude.ai konektor)'
    'logout:Obriši sačuvane OAuth vjerodajnice za MCP server'
    'help:Prikaži pomoć'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'naredbe mcp' mcp_commands
      ;;
    args)
      case $words[1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Uključi režim otklanjanja grešaka]' \
            '--verbose[Prepiši postavku detaljnog režima iz konfiguracione datoteke]' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]'
          ;;
        add)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg konfiguracije (local, user, project)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Tip prijenosa (stdio, sse, http)]:transport:(stdio sse http)' \
            '(-e --env)'{-e,--env}'[Postavi varijablu okoline (npr. -e KEY=value)]:env:' \
            '(-H --header)'{-H,--header}'[Postavi WebSocket zaglavlje]:header:' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:name:' \
            '2:commandOrUrl:' \
            '*:args:'
          ;;
        remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg konfiguracije (local, user, project) - ukloni iz postojećeg opsega ako nije navedeno]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:name:_claude_mcp_servers'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:name:_claude_mcp_servers'
          ;;
        add-json)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg konfiguracije (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:name:' \
            '2:json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg konfiguracije (local, user, project)]:scope:(local user project)' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]'
          ;;
        reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]'
          ;;
        login|logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:name:_claude_mcp_servers'
          ;;
      esac
      ;;
  esac
}

_claude_plugin() {
  local -a plugin_commands
  plugin_commands=(
    'validate:Validiraj dodatak ili manifest tržišta'
    'marketplace:Upravljanje tržištima Claude Code'
    'list:Prikaži listu instaliranih dodataka'
    'details:Prikaži inventar komponenti i projektovani trošak tokena za dodatak'
    'install:Instaliraj dodatak iz dostupnih tržišta'
    'i:Instaliraj dodatak iz dostupnih tržišta (kratica za install)'
    'init:Skeletiraj novi dodatak (automatski se učitava u sljedećoj sesiji)'
    'uninstall:Deinstaliraj instalirani dodatak'
    'remove:Deinstaliraj instalirani dodatak (nadimak za uninstall)'
    'enable:Omogući onemogućeni dodatak'
    'disable:Onemogući omogućeni dodatak'
    'update:Ažuriraj dodatak na najnoviju verziju'
    'eval:Pokreni eval slučajeve nad dodatkom i izvijesti o ocijenjenim rezultatima'
    'prune:Ukloni automatski instalirane zavisnosti koje više nisu potrebne'
    'tag:Kreiraj git tag {name}--v{version} za izdanje dodatka'
    'help:Prikaži pomoć'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'naredbe plugin' plugin_commands
      ;;
    args)
      case $words[1] in
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:path:_files'
          ;;
        marketplace)
          _claude_plugin_marketplace
          ;;
        install|i)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg instalacije]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg instalacije]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        enable|disable)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg instalacije]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        update)
          _arguments \
            '(-s --scope)'{-s,--scope}'[Opseg instalacije]:scope:(user project local managed)' \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        list|prune)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]'
          ;;
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:plugin:_claude_installed_plugins'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:name:'
          ;;
        eval)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:target:'
          ;;
        tag)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_claude_plugin_marketplace() {
  local -a marketplace_commands
  marketplace_commands=(
    'add:Dodaj tržište iz URL, putanje ili GitHub repozitorija'
    'list:Prikaži listu konfiguriranih tržišta'
    'remove:Ukloni konfigurirano tržište'
    'rm:Ukloni konfigurirano tržište (nadimak za remove)'
    'update:Ažuriraj tržište iz izvora - ažuriraj sve ako ime nije navedeno'
    'help:Prikaži pomoć'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'naredbe marketplace' marketplace_commands
      ;;
    args)
      case $words[1] in
        add)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:source:'
          ;;
        list)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]'
          ;;
        remove|rm)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '1:name:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
            '::name:'
          ;;
      esac
      ;;
  esac
}

_claude_install() {
  _arguments \
    '--force[Prisilna instalacija čak i ako je već instalirano]' \
    '(-h --help)'{-h,--help}'[Prikaži pomoć]' \
    '::target:(stable latest)'
}

_claude_agents() {
  _arguments \
    '*--add-dir[Dodatni direktorij za pružanje pristupa alatima u dispečovanim sesijama]:directory:_directories' \
    '--agent[Podrazumijevani agent za sesije dispečovane iz prikaza agenata]:agent:' \
    '--all[Sa --json: uključi i završene pozadinske sesije]' \
    '--allow-dangerously-skip-permissions[Učini režim zaobilaženja dozvola dostupnim dispečovanim sesijama]' \
    '--cwd[Prikaži samo pozadinske sesije pokrenute pod putanjom]:path:_directories' \
    '--dangerously-skip-permissions[Nadimak za --permission-mode bypassPermissions]' \
    '--effort[Podrazumijevani nivo napora za dispečovane sesije]:level:(low medium high xhigh max)' \
    '--json[Ispiši aktivne sesije kao JSON niz i izađi]' \
    '*--mcp-config[Konfiguracija MCP servera za primjenu na dispečovane sesije]:config:' \
    '--model[Podrazumijevani model za sesije dispečovane iz prikaza agenata]:model:' \
    '--permission-mode[Podrazumijevani režim dozvola za dispečovane sesije]:mode:(acceptEdits auto bypassPermissions manual dontAsk plan)' \
    '*--plugin-dir[Učitaj dodatke iz direktorija za prikaz agenata i dispečovane sesije]:path:_directories' \
    '--setting-sources[Lista izvora postavki odvojenih zarezom za učitavanje (user, project, local)]:sources:' \
    '--settings[Datoteka postavki ili JSON niz za primjenu]:file-or-json:_files' \
    '--strict-mcp-config[Koristi samo MCP servere iz --mcp-config u dispečovanim sesijama]' \
    '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]'
}

_claude_auth() {
  local -a auth_commands
  auth_commands=(
    'login:Prijavi se na svoj Anthropic račun'
    'logout:Odjavi se sa svog Anthropic računa'
    'status:Prikaži status autentifikacije'
    'help:Prikaži pomoć'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'naredbe auth' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]'
          ;;
      esac
      ;;
  esac
}

_claude_auto_mode() {
  local -a auto_mode_commands
  auto_mode_commands=(
    'config:Ispiši efektivnu konfiguraciju automatskog režima kao JSON'
    'critique:Dobij AI povratne informacije o vašim prilagođenim pravilima automatskog režima'
    'defaults:Ispiši podrazumijevana pravila automatskog režima kao JSON'
    'reset:Resetuj konfiguraciju automatskog režima na isporučene podrazumijevane vrijednosti'
    'help:Prikaži pomoć'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'naredbe auto-mode' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Putanja do YAML konfiguracije gateway-a]:path:_files' \
    '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Obriši sve stanje Claude Code za projekat (transkripti, zadaci, historija datoteka, unos konfiguracije)'
    'help:Prikaži pomoć'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'naredbe project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Ispiši sirovi bugs.json payload umjesto formatiranih nalaza]' \
    '--timeout[Maksimalni broj minuta za čekanje da se pregled završi]:minutes:' \
    '(-h --help)'{-h,--help}'[Prikaži pomoć za naredbu]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
