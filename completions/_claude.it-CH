  _arguments -C \
    '(-h --help)'{-h,--help}'[Visualizzare aiuto per il comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project commands' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Visualizzare aiuto per il comando]' \
            '1:path:_directories'
