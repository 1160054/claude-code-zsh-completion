  auto_mode_commands=(
    'config:Stampare la configurazione effettiva della modalità automatica come JSON'
    'critique:Ottenere feedback AI sulle tue regole personalizzate della modalità automatica'
    'defaults:Stampare le regole predefinite della modalità automatica come JSON'
