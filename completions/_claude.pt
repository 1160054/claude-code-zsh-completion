  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandos project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Imprimir o payload bruto bugs.json em vez dos resultados formatados]' \
    '--timeout[Máximo de minutos a aguardar pela conclusão da revisão]:minutes:' \
    '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
