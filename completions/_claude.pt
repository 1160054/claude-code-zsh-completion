  local -a auto_mode_commands
  auto_mode_commands=(
    'config:Imprimir a configuração efetiva do modo automático como JSON'
    'critique:Obter feedback de IA sobre suas regras personalizadas do modo automático'
    'defaults:Imprimir as regras padrão do modo automático como JSON'
    'reset:Redefinir a configuração do modo automático para os padrões de fábrica'
    'help:Exibir ajuda'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandos auto-mode' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Caminho para o arquivo de configuração YAML do gateway]:path:_files' \
    '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]'
}

