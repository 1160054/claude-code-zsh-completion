  local -a auth_commands
  auth_commands=(
    'login:Entrar na sua conta Anthropic'
    'logout:Sair da sua conta Anthropic'
    'status:Mostrar status de autenticação'
    'help:Exibir ajuda'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandos auth' auth_commands
      ;;
    args)
      case $words[1] in
        login|logout|status)
          _arguments \
            '(-h --help)'{-h,--help}'[Exibir ajuda para o comando]'
          ;;
      esac
      ;;
  esac
}

