    '(-h --help)'{-h,--help}'[Mostrar ajuda per a la comanda]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandes auto-mode' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Mostrar ajuda per a la comanda]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Ruta al fitxer de configuració YAML de la passarel·la]:path:_files' \
    '(-h --help)'{-h,--help}'[Mostrar ajuda per a la comanda]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Eliminar tot l'\''estat de Claude Code d'\''un projecte (transcripcions, tasques, historial de fitxers, entrada de configuració)'
    'help:Mostrar ajuda'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Mostrar ajuda per a la comanda]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'comandes project' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Mostrar ajuda per a la comanda]' \
            '1:path:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Imprimir la càrrega útil bugs.json en brut en lloc dels resultats formatats]' \
    '--timeout[Minuts màxims a esperar que finalitzi la revisió]:minutes:' \
    '(-h --help)'{-h,--help}'[Mostrar ajuda per a la comanda]' \
    '1:target:'
}

(( $+_comps[claude] )) || compdef _claude claude
