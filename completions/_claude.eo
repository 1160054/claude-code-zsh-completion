  local -a auto_mode_commands
  auto_mode_commands=(
    'config:Presi la efektivan aŭtomatreĝiman agordon kiel JSON'
    'critique:Akiri AI-reagon pri viaj propraj aŭtomatreĝimaj reguloj'
    'defaults:Presi la defaŭltajn aŭtomatreĝimajn regulojn kiel JSON'
    'reset:Reagordi aŭtomatreĝiman agordon al la liveritaj defaŭltoj'
    'help:Montri helpon'
