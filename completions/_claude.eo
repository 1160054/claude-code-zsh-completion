  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Montri helpon por komando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'auto-mode-komandoj' auto_mode_commands
      ;;
    args)
      case $words[1] in
        config|critique|defaults|reset)
          _arguments \
            '(-h --help)'{-h,--help}'[Montri helpon por komando]'
          ;;
      esac
      ;;
  esac
}

_claude_gateway() {
  _arguments \
    '--config[Vojo al kluza YAML-agordo]:vojo:_files' \
    '(-h --help)'{-h,--help}'[Montri helpon por komando]'
}

_claude_project() {
  local -a project_commands
  project_commands=(
    'purge:Forigi ĉian Claude Code staton por projekto (transskriboj, taskoj, dosier-historio, agord-enigo)'
    'help:Montri helpon'
  )

  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Montri helpon por komando]' \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'project-komandoj' project_commands
      ;;
    args)
      case $words[1] in
        purge)
          _arguments \
            '(-h --help)'{-h,--help}'[Montri helpon por komando]' \
            '1:vojo:_directories'
          ;;
      esac
      ;;
  esac
}

_claude_ultrareview() {
  _arguments \
    '--json[Presi la krudan bugs.json ŝarĝon anstataŭ formatitaj trovoj]' \
    '--timeout[Maksimumaj minutoj por atendi ke la revizio finiĝu]:minutoj:' \
    '(-h --help)'{-h,--help}'[Montri helpon por komando]' \
    '1:celo:'
}

(( $+_comps[claude] )) || compdef _claude claude
